@model List<AIInsights.SuperAdmin.Controllers.LicensesController.LicenseRowViewModel>
@{
    ViewData["Title"] = "License Management";
    ViewData["ActivePage"] = "licenses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .badge-gray { background: rgba(100,116,139,.12); color: #64748b; }
    .drawer-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:400; }
    .drawer-overlay.open { display:block; }
    .drawer {
        position:fixed; top:0; right:-520px; bottom:0; width:500px; max-width:95vw;
        background:#fff; z-index:401; box-shadow:-4px 0 24px rgba(0,0,0,.15);
        display:flex; flex-direction:column; transition:right .25s ease;
    }
    .drawer.open { right:0; }
    .drawer-header {
        padding:1.25rem 1.5rem; border-bottom:1px solid var(--border);
        display:flex; align-items:center; justify-content:space-between;
    }
    .drawer-body { flex:1; overflow-y:auto; padding:1.25rem 1.5rem; }
    .hist-item {
        border-left:3px solid var(--border); padding:.6rem .75rem;
        margin-bottom:.6rem; border-radius:0 8px 8px 0;
        background:rgba(74,142,201,.04);
    }
    .hist-item.PlanChange  { border-left-color:#4a8ec9; }
    .hist-item.LicenseGrant  { border-left-color:#34d399; }
    .hist-item.LicenseRevoke { border-left-color:#fb7185; }
    .hist-item.TermUpdate    { border-left-color:#fbbf24; }
    .modal-body .form-label { font-size:.82rem; font-weight:600; color:var(--text-dim); }
</style>

<div class="page-header d-flex align-items-start justify-content-between">
    <div>
        <h1 class="page-title">License Management</h1>
        <p class="page-desc">View utilization, grant or revoke licenses, set license terms per organization.</p>
    </div>
</div>

<!-- Filter bar -->
<div class="card-panel" style="padding:.85rem 1.25rem;margin-bottom:1rem">
    <form method="get" action="/superadmin/licenses" class="d-flex flex-wrap gap-2 align-items-end">
        <div>
            <label class="form-label" style="font-size:.75rem;font-weight:600;color:var(--text-muted)">Search</label>
            <input name="search" class="form-control form-control-sm" placeholder="Organization name…"
                   value="@ViewBag.Search" style="min-width:180px" />
        </div>
        <div>
            <label class="form-label" style="font-size:.75rem;font-weight:600;color:var(--text-muted)">Plan</label>
            <select name="plan" class="form-select form-select-sm" style="min-width:130px">
                <option value="">All plans</option>
                @foreach (var p in new[]{"Free","FreeTrial","Professional","Enterprise"})
                {
                    <option value="@p" selected="@(ViewBag.PlanFilter == p ? "selected" : null)">@p</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label" style="font-size:.75rem;font-weight:600;color:var(--text-muted)">Status</label>
            <select name="status" class="form-select form-select-sm" style="min-width:130px">
                <option value="">All statuses</option>
                @foreach (var s in new[]{"Active","ExpiringSoon","Expired","None"})
                {
                    <option value="@s" selected="@(ViewBag.StatusFilter == s ? "selected" : null)">@s</option>
                }
            </select>
        </div>
        <button type="submit" class="btn-primary-sm"><i class="bi bi-search"></i> Filter</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.PlanFilter as string) || !string.IsNullOrEmpty(ViewBag.StatusFilter as string))
        {
            <a href="/superadmin/licenses" class="btn-ghost-sm">Clear</a>
        }
    </form>
</div>

<!-- Table -->
<div class="card-panel" style="overflow-x:auto;padding:0">
    <table class="tbl">
        <thead>
            <tr>
                <th>Organization</th>
                <th>Plan</th>
                <th title="Purchased">Purch.</th>
                <th title="Assigned to users">Assigned</th>
                <th title="Available">Free</th>
                <th>Term (Starts → Ends)</th>
                <th>Auto-Renew</th>
                <th>Status</th>
                <th style="text-align:right">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model)
            {
                <tr id="lic-row-@row.Id">
                    <td style="font-weight:600;color:#1e3a5f">@row.Name</td>
                    <td>
                        @{
                            var planBadge = row.Plan switch {
                                "Enterprise"   => "badge-sky",
                                "Professional" => "badge-indigo",
                                "FreeTrial"    => "badge-amber",
                                _              => "badge-gray"
                            };
                        }
                        <span class="badge-sm @planBadge">@row.Plan</span>
                    </td>
                    <td id="lic-purch-@row.Id">@row.PurchasedLicenses</td>
                    <td id="lic-assigned-@row.Id">@row.AssignedLicenses</td>
                    <td id="lic-free-@row.Id">@row.FreeLicenses</td>
                    <td style="color:var(--text-muted);white-space:nowrap" id="lic-term-@row.Id">
                        @(row.LicenseStartsAt?.ToString("MMM d, yyyy") ?? "—")
                        →
                        @(row.LicenseEndsAt?.ToString("MMM d, yyyy") ?? "∞")
                    </td>
                    <td id="lic-renew-@row.Id">
                        @if (row.AutoRenew)
                        {
                            <i class="bi bi-arrow-repeat text-success" title="Auto-renew on"></i>
                        }
                        else
                        {
                            <i class="bi bi-dash text-muted"></i>
                        }
                    </td>
                    <td id="lic-status-@row.Id">
                        @{
                            var (statusCss, statusIcon) = row.Status switch {
                                "Active"       => ("badge-emerald", "bi-check-circle-fill"),
                                "ExpiringSoon" => ("badge-amber",   "bi-exclamation-circle-fill"),
                                "Expired"      => ("badge-rose",    "bi-x-circle-fill"),
                                _              => ("badge-gray",    "bi-dash-circle")
                            };
                        }
                        <span class="badge-sm @statusCss"><i class="bi @statusIcon"></i> @row.Status</span>
                    </td>
                    <td style="text-align:right;white-space:nowrap">
                        <button class="btn-primary-sm" style="font-size:.75rem;padding:.3rem .65rem"
                                onclick="openGrant(@row.Id, '@row.Name.Replace("'","\\'")')">
                            <i class="bi bi-plus-circle"></i> Grant
                        </button>
                        <button class="btn-ghost-sm" style="font-size:.75rem;padding:.3rem .65rem;border-color:#ef4444;color:#ef4444"
                                onclick="openRevoke(@row.Id, '@row.Name.Replace("'","\\'")', @row.PurchasedLicenses, @row.AssignedLicenses)">
                            <i class="bi bi-dash-circle"></i> Revoke
                        </button>
                        <button class="btn-ghost-sm" style="font-size:.75rem;padding:.3rem .65rem"
                                onclick="openTerm(@row.Id, '@row.Name.Replace("'","\\'")',
                                    '@(row.LicenseStartsAt?.ToString("yyyy-MM-dd") ?? "")',
                                    '@(row.LicenseEndsAt?.ToString("yyyy-MM-dd") ?? "")',
                                    @(row.AutoRenew ? "true" : "false"),
                                    '@(row.LicenseNotes ?? "")')">
                            <i class="bi bi-calendar2-range"></i> Term
                        </button>
                        <button class="btn-ghost-sm" style="font-size:.75rem;padding:.3rem .65rem"
                                onclick="openHistory(@row.Id, '@row.Name.Replace("'","\\'")')">
                            <i class="bi bi-clock-history"></i> History
                        </button>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="9" style="text-align:center;color:var(--text-muted);padding:2rem">No organizations found.</td></tr>
            }
        </tbody>
    </table>
</div>

<!-- Grant Modal -->
<div class="modal fade" id="grantModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:12px">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle text-success me-2"></i>Grant Licenses — <span id="grantOrgName"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Number of licenses to grant *</label>
                    <input type="number" id="grantCount" class="form-control" min="1" value="1" />
                </div>
                <div class="mb-3">
                    <label class="form-label">License expires at (optional)</label>
                    <input type="date" id="grantExpiresAt" class="form-control" />
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="grantAutoRenew" />
                    <label class="form-check-label form-label" for="grantAutoRenew">Auto-renew</label>
                </div>
                <div class="mb-2">
                    <label class="form-label">Reason (optional)</label>
                    <input type="text" id="grantReason" class="form-control" placeholder="e.g. Annual contract renewal" />
                </div>
                <div id="grantError" class="text-danger small" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-ghost-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn-primary-sm" id="grantBtn" onclick="confirmGrant()">
                    <i class="bi bi-plus-circle"></i> Grant
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Revoke Modal -->
<div class="modal fade" id="revokeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:12px">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-dash-circle text-danger me-2"></i>Revoke Licenses — <span id="revokeOrgName"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="small text-muted" id="revokeInfo"></p>
                <div class="mb-3">
                    <label class="form-label">Number of licenses to revoke *</label>
                    <input type="number" id="revokeCount" class="form-control" min="1" value="1" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Reason (optional)</label>
                    <input type="text" id="revokeReason" class="form-control" placeholder="e.g. Contract ended" />
                </div>
                <div id="revokeError" class="text-danger small" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-ghost-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn-primary-sm" style="background:#ef4444" id="revokeBtn" onclick="confirmRevoke()">
                    <i class="bi bi-dash-circle"></i> Revoke
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Term Modal -->
<div class="modal fade" id="termModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:12px">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-calendar2-range text-primary me-2"></i>License Term — <span id="termOrgName"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Starts at (optional)</label>
                    <input type="date" id="termStartsAt" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Ends at (optional)</label>
                    <input type="date" id="termEndsAt" class="form-control" />
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="termAutoRenew" />
                    <label class="form-check-label form-label" for="termAutoRenew">Auto-renew</label>
                </div>
                <div class="mb-2">
                    <label class="form-label">Notes (optional)</label>
                    <textarea id="termNotes" class="form-control" rows="2" placeholder="Internal notes about this license term…"></textarea>
                </div>
                <div id="termError" class="text-danger small" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-ghost-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn-primary-sm" id="termBtn" onclick="confirmTerm()">
                    <i class="bi bi-save"></i> Save Term
                </button>
            </div>
        </div>
    </div>
</div>

<!-- History Drawer -->
<div class="drawer-overlay" id="histOverlay" onclick="closeHistory()"></div>
<div class="drawer" id="histDrawer">
    <div class="drawer-header">
        <div>
            <div style="font-weight:700;font-size:1rem;color:#1e3a5f">Plan & License History</div>
            <div id="histOrgName" style="font-size:.82rem;color:var(--text-muted)"></div>
        </div>
        <button class="btn-ghost-sm" style="padding:.3rem .6rem" onclick="closeHistory()"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="drawer-body" id="histBody">
        <div class="text-center text-muted py-4">Loading…</div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
let _activeOrgId = null;

// ── Grant ──────────────────────────────────────────────────────────────────
function openGrant(id, name) {
    _activeOrgId = id;
    document.getElementById('grantOrgName').textContent = name;
    document.getElementById('grantCount').value = 1;
    document.getElementById('grantExpiresAt').value = '';
    document.getElementById('grantAutoRenew').checked = false;
    document.getElementById('grantReason').value = '';
    document.getElementById('grantError').style.display = 'none';
    document.getElementById('grantBtn').disabled = false;
    new bootstrap.Modal('#grantModal').show();
}

async function confirmGrant() {
    const count = parseInt(document.getElementById('grantCount').value, 10);
    const expiresAt = document.getElementById('grantExpiresAt').value || null;
    const autoRenew = document.getElementById('grantAutoRenew').checked;
    const reason = document.getElementById('grantReason').value.trim() || null;
    const errEl = document.getElementById('grantError');
    const btn = document.getElementById('grantBtn');

    if (!count || count < 1) { errEl.textContent = 'Count must be ≥ 1.'; errEl.style.display = ''; return; }

    btn.disabled = true;
    errEl.style.display = 'none';
    try {
        const r = await fetch(`/api/superadmin/orgs/${_activeOrgId}/licenses/grant`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ count, expiresAt, autoRenew, reason })
        });
        const data = await r.json();
        if (!r.ok) { errEl.textContent = data.error || 'Error.'; errEl.style.display = ''; btn.disabled = false; return; }
        bootstrap.Modal.getInstance('#grantModal').hide();
        updateRow(_activeOrgId, data);
        showToast('Licenses granted successfully.', 'success');
    } catch { errEl.textContent = 'Network error.'; errEl.style.display = ''; btn.disabled = false; }
}

// ── Revoke ─────────────────────────────────────────────────────────────────
function openRevoke(id, name, purchased, assigned) {
    _activeOrgId = id;
    document.getElementById('revokeOrgName').textContent = name;
    document.getElementById('revokeInfo').textContent = `Purchased: ${purchased} | Assigned: ${assigned} | Max revocable: ${purchased - assigned}`;
    document.getElementById('revokeCount').value = 1;
    document.getElementById('revokeReason').value = '';
    document.getElementById('revokeError').style.display = 'none';
    document.getElementById('revokeBtn').disabled = false;
    new bootstrap.Modal('#revokeModal').show();
}

async function confirmRevoke() {
    const count = parseInt(document.getElementById('revokeCount').value, 10);
    const reason = document.getElementById('revokeReason').value.trim() || null;
    const errEl = document.getElementById('revokeError');
    const btn = document.getElementById('revokeBtn');

    if (!count || count < 1) { errEl.textContent = 'Count must be ≥ 1.'; errEl.style.display = ''; return; }

    btn.disabled = true;
    errEl.style.display = 'none';
    try {
        const r = await fetch(`/api/superadmin/orgs/${_activeOrgId}/licenses/revoke`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ count, reason })
        });
        const data = await r.json();
        if (!r.ok) { errEl.textContent = data.error || 'Error.'; errEl.style.display = ''; btn.disabled = false; return; }
        bootstrap.Modal.getInstance('#revokeModal').hide();
        updateRow(_activeOrgId, data);
        showToast('Licenses revoked successfully.', 'success');
    } catch { errEl.textContent = 'Network error.'; errEl.style.display = ''; btn.disabled = false; }
}

// ── Term ───────────────────────────────────────────────────────────────────
function openTerm(id, name, startsAt, endsAt, autoRenew, notes) {
    _activeOrgId = id;
    document.getElementById('termOrgName').textContent = name;
    document.getElementById('termStartsAt').value = startsAt;
    document.getElementById('termEndsAt').value = endsAt;
    document.getElementById('termAutoRenew').checked = autoRenew;
    document.getElementById('termNotes').value = notes;
    document.getElementById('termError').style.display = 'none';
    document.getElementById('termBtn').disabled = false;
    new bootstrap.Modal('#termModal').show();
}

async function confirmTerm() {
    const startsAt = document.getElementById('termStartsAt').value || null;
    const endsAt = document.getElementById('termEndsAt').value || null;
    const autoRenew = document.getElementById('termAutoRenew').checked;
    const notes = document.getElementById('termNotes').value.trim() || null;
    const errEl = document.getElementById('termError');
    const btn = document.getElementById('termBtn');

    btn.disabled = true;
    errEl.style.display = 'none';
    try {
        const r = await fetch(`/api/superadmin/orgs/${_activeOrgId}/licenses/term`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ startsAt, endsAt, autoRenew, notes })
        });
        const data = await r.json();
        if (!r.ok) { errEl.textContent = data.error || 'Error.'; errEl.style.display = ''; btn.disabled = false; return; }
        bootstrap.Modal.getInstance('#termModal').hide();
        // Refresh row term cell
        const termCell = document.getElementById(`lic-term-${_activeOrgId}`);
        if (termCell) {
            const s = data.licenseStartsAt ? new Date(data.licenseStartsAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '—';
            const e = data.licenseEndsAt   ? new Date(data.licenseEndsAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '∞';
            termCell.textContent = `${s} → ${e}`;
        }
        const renewCell = document.getElementById(`lic-renew-${_activeOrgId}`);
        if (renewCell) renewCell.innerHTML = data.autoRenew ? '<i class="bi bi-arrow-repeat text-success"></i>' : '<i class="bi bi-dash text-muted"></i>';
        showToast('License term updated.', 'success');
    } catch { errEl.textContent = 'Network error.'; errEl.style.display = ''; btn.disabled = false; }
}

// ── History ────────────────────────────────────────────────────────────────
async function openHistory(id, name) {
    _activeOrgId = id;
    document.getElementById('histOrgName').textContent = name;
    document.getElementById('histBody').innerHTML = '<div class="text-center text-muted py-4">Loading…</div>';
    document.getElementById('histOverlay').classList.add('open');
    document.getElementById('histDrawer').classList.add('open');
    try {
        const r = await fetch(`/api/superadmin/orgs/${id}/licenses/history`);
        const data = await r.json();
        renderHistory(data.logs || []);
    } catch { document.getElementById('histBody').innerHTML = '<div class="text-danger small">Failed to load history.</div>'; }
}

function closeHistory() {
    document.getElementById('histOverlay').classList.remove('open');
    document.getElementById('histDrawer').classList.remove('open');
}

function renderHistory(logs) {
    const body = document.getElementById('histBody');
    if (!logs.length) { body.innerHTML = '<div class="text-muted small text-center py-4">No history yet.</div>'; return; }
    const ctLabel = { PlanChange:'Plan Change', LicenseGrant:'License Grant', LicenseRevoke:'License Revoke', TermUpdate:'Term Update' };
    body.innerHTML = logs.map(l => {
        const dt = new Date(l.createdAt).toLocaleString();
        const who = l.changedByEmail || l.changedByUserId || 'SuperAdmin';
        let detail = '';
        if (l.changeType === 'PlanChange')
            detail = `Plan: <b>${l.fromPlan}</b> → <b>${l.toPlan}</b>`;
        else if (l.changeType === 'LicenseGrant' || l.changeType === 'LicenseRevoke')
            detail = `Licenses: <b>${l.fromPurchasedLicenses ?? 0}</b> → <b>${l.toPurchasedLicenses}</b>`;
        else if (l.changeType === 'TermUpdate') {
            const fe = l.fromLicenseEndsAt ? new Date(l.fromLicenseEndsAt).toLocaleDateString() : '∞';
            const te = l.toLicenseEndsAt   ? new Date(l.toLicenseEndsAt).toLocaleDateString() : '∞';
            detail = `Expiry: <b>${fe}</b> → <b>${te}</b>`;
        }
        const reason = l.reason ? `<div class="small text-muted mt-1">Reason: ${l.reason}</div>` : '';
        return `<div class="hist-item ${l.changeType}">
            <div class="d-flex justify-content-between align-items-start">
                <span class="badge-sm badge-indigo">${ctLabel[l.changeType] || l.changeType}</span>
                <span class="small text-muted">${dt}</span>
            </div>
            <div class="small mt-1">${detail}</div>
            <div class="small text-muted">by ${who}</div>
            ${reason}
        </div>`;
    }).join('');
}

// ── Helpers ────────────────────────────────────────────────────────────────
function updateRow(id, data) {
    const p = document.getElementById(`lic-purch-${id}`);
    if (p && data.purchasedLicenses !== undefined) p.textContent = data.purchasedLicenses;
    const a = document.getElementById(`lic-assigned-${id}`);
    if (a && data.assignedLicenses !== undefined) a.textContent = data.assignedLicenses;
    const f = document.getElementById(`lic-free-${id}`);
    if (f && data.freeLicenses !== undefined) f.textContent = data.freeLicenses;
}

function showToast(msg, type) {
    const el = document.createElement('div');
    el.style.cssText = `position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;padding:.65rem 1.1rem;
        border-radius:10px;font-size:.85rem;font-weight:500;color:#fff;
        background:${type === 'error' ? '#ef4444' : '#34d399'};
        box-shadow:0 4px 16px rgba(0,0,0,.18);transition:opacity .3s;`;
    el.textContent = msg;
    document.body.appendChild(el);
    setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.remove(), 320); }, 3000);
}
</script>
}
