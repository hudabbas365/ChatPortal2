@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<!-- Hero Section -->
<section class="cp-hero">
    <div class="container px-4 px-lg-5">
        <div class="row align-items-center g-5">

            <!-- Left column -->
            <div class="col-lg-6">
                <div class="hero-badge mb-3">
                    <i class="bi bi-stars me-2"></i>✦ Trusted by 1,200+ data teams
                </div>
                <h1 class="hero-title">
                    Turn Any Data Into<br/>
                    <span class="hero-highlight">Decisions — Instantly</span>
                </h1>
                <p class="hero-subtitle">
                    AIInsights connects to 70+ datasources, deploys custom AI Agents, and generates beautiful charts in seconds. No SQL. No dashboards. Just answers.
                </p>
                <div class="hero-actions">
                    <a href="/auth/register" class="btn cp-btn-gradient btn-lg">
                        <i class="bi bi-rocket-takeoff me-2"></i>Start Free Trial
                    </a>
                    <a href="/chat" class="btn btn-outline-cp btn-lg">
                        <i class="bi bi-play-circle me-2"></i>Watch 2-min Demo
                    </a>
                </div>
                <!-- Stat row -->
                <div class="hero-stats mb-3">
                    <div class="hero-stat-item">
                        <span class="stat-number">70+</span>
                        <span class="stat-label">Datasources</span>
                    </div>
                    <div class="hero-stat-divider"></div>
                    <div class="hero-stat-item">
                        <span class="stat-number">72+</span>
                        <span class="stat-label">Chart Types</span>
                    </div>
                    <div class="hero-stat-divider"></div>
                    <div class="hero-stat-item">
                        <span class="stat-number">10×</span>
                        <span class="stat-label">Faster insights</span>
                    </div>
                </div>
                <!-- Trust badges -->
                <div class="hero-trust">
                    <span class="trust-item"><i class="bi bi-shield-check me-1"></i>GDPR Compliant</span>
                    <span class="trust-item"><i class="bi bi-clock me-1"></i>30-day Free Trial</span>
                    <span class="trust-item"><i class="bi bi-credit-card me-1"></i>No Credit Card</span>
                    <span class="trust-item"><i class="bi bi-patch-check me-1"></i>SOC 2 Ready</span>
                </div>
            </div>

            <!-- Right column — AI Insights Panel -->
            <div class="col-lg-6">
                <div class="hero-insights-panel">

                    <!-- Ask Anything bar -->
                    <div class="hero-ask-bar">
                        <i class="bi bi-search text-muted me-2"></i>
                        <span class="hero-ask-placeholder">Ask your data anything…</span>
                        <button class="btn cp-btn-gradient hero-ask-send">Send</button>
                    </div>
                    <div class="hero-quick-chips">
                        <button class="hero-chip"><i class="bi bi-graph-up me-1"></i>Top revenue this month</button>
                        <button class="hero-chip"><i class="bi bi-person-x me-1"></i>Churn risk users</button>
                    </div>

                    <!-- Metrics grid (2×2) -->
                    <div class="hero-metrics-grid">
                        <div class="hero-metric-card glass-card">
                            <i class="bi bi-graph-up-arrow metric-icon" style="color:var(--cp-primary)"></i>
                            <div class="metric-value">$2.4M</div>
                            <div class="metric-label">Total Revenue</div>
                            <span class="metric-trend up"><i class="bi bi-arrow-up-short"></i>13.3% vs last qtr</span>
                        </div>
                        <div class="hero-metric-card glass-card">
                            <i class="bi bi-people-fill metric-icon" style="color:var(--cp-accent)"></i>
                            <div class="metric-value">18,420</div>
                            <div class="metric-label">Active Users</div>
                            <span class="metric-trend up"><i class="bi bi-arrow-up-short"></i>9.7% this month</span>
                        </div>
                        <div class="hero-metric-card glass-card">
                            <i class="bi bi-lightning-charge-fill metric-icon" style="color:var(--cp-orange)"></i>
                            <div class="metric-value">0.8s</div>
                            <div class="metric-label">Avg Query Time</div>
                            <span class="metric-trend down"><i class="bi bi-arrow-down-short"></i>62% faster</span>
                        </div>
                        <div class="hero-metric-card glass-card">
                            <i class="bi bi-bar-chart-fill metric-icon" style="color:var(--cp-purple)"></i>
                            <div class="metric-value">72</div>
                            <div class="metric-label">Chart Types</div>
                            <span class="metric-trend up"><i class="bi bi-plus"></i>Sankey · Treemap · +70</span>
                        </div>
                    </div>

                    <!-- Live AI response strip -->
                    <div class="hero-ai-strip">
                        <div class="hero-ai-msg">
                            🤖 <strong>AI Insight</strong>: <em>"North region leads $145K (+13%), East $101K (+9.7%). Recommend reallocating 15% budget from South → North for Q3 max ROI."</em>
                        </div>
                        <div class="hero-ai-footer">Generated in 0.4s · Powered by GPT-4</div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>

<!-- Features Section -->
<section class="cp-section cp-features">
    <div class="container">
        <div class="section-header text-center mb-5">
            <h2 class="section-title">Everything You Need</h2>
            <p class="section-subtitle">A complete analytics platform powered by AI</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="bi bi-database-fill-gear"></i>
                    </div>
                    <h3 class="feature-title">70+ Datasources</h3>
                    <p class="feature-desc">Connect SQL Server, PostgreSQL, MySQL, APIs, CSV files, and 65 more data sources with zero configuration.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="bi bi-robot"></i>
                    </div>
                    <h3 class="feature-title">AI Agents</h3>
                    <p class="feature-desc">Create custom AI agents with specific knowledge, system prompts, and datasource connections. Chat naturally.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="bi bi-bar-chart-line-fill"></i>
                    </div>
                    <h3 class="feature-title">72+ Chart Types</h3>
                    <p class="feature-desc">From basic bar charts to Sankey diagrams, candlesticks, treemaps, and more. Drag-and-drop report designer.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How to Use AI Insights — User Guide -->
<section class="cp-section cp-how-to" id="how-to">
    <div class="container">
        <div class="section-header text-center mb-5">
            <h2 class="section-title">How to Use AI Insights</h2>
            <p class="section-subtitle">Get started in 4 simple steps — no technical knowledge required</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="howto-card glass-card">
                    <div class="howto-step-num">1</div>
                    <div class="howto-icon"><i class="bi bi-folder-plus"></i></div>
                    <h4 class="howto-title">Create a Workspace</h4>
                    <p class="howto-desc">Click <strong>+ New Workspace</strong> in the left panel and give it a name. A workspace is your project space where everything lives.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="howto-card glass-card">
                    <div class="howto-step-num">2</div>
                    <div class="howto-icon"><i class="bi bi-database-add"></i></div>
                    <h4 class="howto-title">Connect Your Data</h4>
                    <p class="howto-desc">Follow the guided wizard to connect a data source. Just paste your connection details — we'll handle the rest.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="howto-card glass-card">
                    <div class="howto-step-num">3</div>
                    <div class="howto-icon"><i class="bi bi-chat-dots"></i></div>
                    <h4 class="howto-title">Ask Questions</h4>
                    <p class="howto-desc">Click on your AI Agent and start chatting. Ask things like <em>"What were our top sales last month?"</em> — the AI understands plain English.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="howto-card glass-card">
                    <div class="howto-step-num">4</div>
                    <div class="howto-icon"><i class="bi bi-bar-chart-line"></i></div>
                    <h4 class="howto-title">View & Share Reports</h4>
                    <p class="howto-desc">Charts and insights are created automatically. Open the Dashboard to drag, resize, and save reports — then share them with your team.</p>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-lg-8 mx-auto">
                <div class="howto-tips glass-card">
                    <h5><i class="bi bi-lightbulb me-2"></i>Tips for Best Results</h5>
                    <ul class="howto-tips-list">
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>Ask clear, specific questions — e.g. <em>"Show me revenue by region this quarter"</em></li>
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>Use the <strong>suggestion chips</strong> that appear below the chat for quick ideas</li>
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>Click <strong>"Add to Dashboard"</strong> on any chart to save it to your report</li>
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>Invite team members from <strong>Settings → Users</strong> so everyone can explore the data</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Pricing Preview -->
<section class="cp-section cp-pricing-preview" id="pricing">
    <div class="container">
        <div class="section-header text-center mb-5">
            <h2 class="section-title">Simple, Transparent Pricing</h2>
            <p class="section-subtitle">Start free, scale as you grow</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="pricing-card glass-card">
                    <div class="pricing-tier">Free Trial</div>
                    <div class="pricing-price">$0 <span class="pricing-period">/ 30 days</span></div>
                    <ul class="pricing-features">
                        <li><i class="bi bi-check-circle-fill me-2"></i>10 Workspaces</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>5 AI Agents</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>All 72 chart types</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>1,000 messages</li>
                    </ul>
                    <a href="/auth/register" class="btn cp-btn-gradient w-100">Start 30-Day Free Trial</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="pricing-card glass-card pricing-featured">
                    <div class="pricing-badge">Most Popular</div>
                    <div class="pricing-tier">Professional</div>
                    <div class="pricing-price">$49 <span class="pricing-period">/ month</span></div>
                    <ul class="pricing-features">
                        <li><i class="bi bi-check-circle-fill me-2"></i>50 Workspaces</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>20 AI Agents</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>All chart types + exports</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>10,000 messages</li>
                    </ul>
                    <button class="btn cp-btn-gradient w-100" data-bs-toggle="modal" data-bs-target="#paymentModal">Get Started</button>
                </div>
            </div>
            <div class="col-md-4">
                <div class="pricing-card glass-card">
                    <div class="pricing-tier">Enterprise</div>
                    <div class="pricing-price">Custom</div>
                    <ul class="pricing-features">
                        <li><i class="bi bi-check-circle-fill me-2"></i>Unlimited everything</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>SSO / SAML</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Dedicated support</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>On-premise option</li>
                    </ul>
                    <a href="/about" class="btn btn-outline-cp w-100">Contact Sales</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-labelledby="paymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="paymentModalLabel"><i class="bi bi-credit-card me-2"></i>Subscribe — Professional Plan ($49/mo)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="paymentAlert" class="alert d-none"></div>
                <ul class="nav nav-tabs mb-3" id="paymentTabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#tabCreditCard"><i class="bi bi-credit-card me-1"></i>Credit Card</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tabPayPal"><i class="bi bi-paypal me-1"></i>PayPal</a>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="tabCreditCard">
                        <div class="mb-3">
                            <label class="form-label">Card Number</label>
                            <input type="text" class="form-control" id="cardNumber" placeholder="4242 4242 4242 4242" maxlength="19" />
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label">Expiration</label>
                                <input type="text" class="form-control" id="cardExpiry" placeholder="MM / YY" maxlength="7" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">CVC</label>
                                <input type="text" class="form-control" id="cardCvc" placeholder="123" maxlength="4" />
                            </div>
                        </div>
                        <button class="btn cp-btn-gradient w-100" id="stripeSubscribeBtn">
                            <i class="bi bi-lock me-2"></i>Subscribe Now
                        </button>
                    </div>
                    <div class="tab-pane fade" id="tabPayPal">
                        <div class="text-center py-4">
                            <p class="text-muted mb-4">Click below to pay securely with PayPal.</p>
                            <button class="btn btn-lg w-100" id="paypalPayBtn" style="background:#0070ba;border-color:#0070ba;color:#fff">
                                <i class="bi bi-paypal me-2"></i>Pay with PayPal
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    function subscribeUpgrade(btn) {
        var user = JSON.parse(localStorage.getItem('cp_user') || 'null');
        if (!user) { window.location.href = '/auth/register'; return; }
        btn.disabled = true;
        var alertEl = document.getElementById('paymentAlert');
        fetch('/api/subscription/upgrade', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: user.id, plan: 2 })
        }).then(function(r) { return r.json(); }).then(function() {
            if (alertEl) { alertEl.className = 'alert alert-success'; alertEl.textContent = 'Subscription upgraded to Professional! Enjoy your plan.'; alertEl.classList.remove('d-none'); }
        }).catch(function() {
            if (alertEl) { alertEl.className = 'alert alert-danger'; alertEl.textContent = 'Could not process payment. Please try again.'; alertEl.classList.remove('d-none'); }
        }).finally(function() { btn.disabled = false; });
    }
    document.getElementById('stripeSubscribeBtn')?.addEventListener('click', function() { subscribeUpgrade(this); });
    document.getElementById('paypalPayBtn')?.addEventListener('click', function() { subscribeUpgrade(this); });
})();
</script>
}
