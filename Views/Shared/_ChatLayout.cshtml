<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — AI Insights" : "Chat — AI Insights")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/workspace-flow.css" />
    <link rel="stylesheet" href="~/css/workspace-enhanced.css" />
    <link rel="stylesheet" href="~/css/chat-agent-context.css" />
    <link rel="stylesheet" href="~/css/workspace-roles.css" />
    <link rel="stylesheet" href="~/css/workspace-settings.css" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect x='2' y='18' width='6' height='12' rx='1' fill='%236366f1'/%3E%3Crect x='11' y='10' width='6' height='20' rx='1' fill='%236366f1'/%3E%3Crect x='20' y='4' width='6' height='26' rx='1' fill='%236366f1' opacity='0.8'/%3E%3C/svg%3E">
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-M7E9RXEQL5"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-M7E9RXEQL5');
    </script>
</head>
<body class="chat-layout-body">
    <div class="chat-shell">
        @await Html.PartialAsync("~/Views/Partials/_LeftPanel.cshtml")
        <div class="chat-main">
            @await Html.PartialAsync("~/Views/Partials/_TrialBanner.cshtml")
            <div class="chat-topbar">
                <button class="btn btn-icon sidebar-toggle-btn" id="sidebarToggle">
                    <i class="bi bi-layout-sidebar"></i>
                </button>
                <span class="chat-topbar-title" id="chatWorkspaceTitle">Workspace</span>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <button id="chatLayoutLogoutBtn" class="btn btn-sm btn-outline-danger text-nowrap" title="Sign Out" style="display:none">
                        <i class="bi bi-box-arrow-right"></i> <span class="d-none d-sm-inline">Sign Out</span>
                    </button>
                    <div class="dropdown d-none" id="newArtifactDropdown">
                        <button class="btn btn-sm cp-btn-gradient dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-plus-lg me-1"></i>New
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#" id="newDashboardBtn"><i class="bi bi-bar-chart-fill me-2"></i>New Dashboard</a></li>
                            <li><a class="dropdown-item" href="#" id="newDatasourceBtn"><i class="bi bi-database me-2"></i>New Data Source</a></li>
                            <li><a class="dropdown-item" href="#" id="newAgentBtn"><i class="bi bi-robot me-2"></i>New AI Agent</a></li>
                        </ul>
                    </div>
                    <a href="/auth/login" class="btn btn-sm cp-btn-gradient" id="chatAuthBtn">Sign In</a>
                </div>
            </div>
            <div class="chat-subnav" id="chatSubnav">
                <div class="chat-subnav-brand">
                    <i class="bi bi-folder-fill me-1"></i>
                    <span id="chatSubnavWorkspaceName">Select a workspace</span>
                    <span class="chat-subnav-ds" id="chatSubnavDs" style="display:none">
                        <i class="bi bi-database me-1"></i><span id="chatSubnavDsName"></span>
                    </span>
                    <span class="chat-subnav-role" id="chatSubnavRole" style="display:none"></span>
                </div>
                <div class="chat-subnav-tabs" id="chatSubnavTabs">
                    <button class="chat-subnav-tab active" data-tab="chat">
                        <i class="bi bi-chat-dots me-1"></i>Chat
                    </button>
                </div>
            </div>
            <div class="wf-home-panel" id="workspaceHomePanel"></div>
            @RenderBody()
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/js/workspaceFlow.js" asp-append-version="true"></script>
    <script src="~/js/workspaceWizard.js" asp-append-version="true"></script>
    <script src="~/js/workspaceEnhanced.js" asp-append-version="true"></script>
    <script src="~/js/workspaceRoles.js" asp-append-version="true"></script>
    <script src="~/js/workspaceSettings.js" asp-append-version="true"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    <script src="~/js/chat-agent-context.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (window.workspaceSettings) window.workspaceSettings.init();
            if (window.workspaceRoles) window.workspaceRoles.init();
            if (window.workspaceEnhanced) window.workspaceEnhanced.init();
            if (window.workspaceFlow) window.workspaceFlow.init();
            document.querySelectorAll('input:not([autocomplete]), textarea:not([autocomplete])').forEach(function(el) {
                el.setAttribute('autocomplete', 'off');
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
