<script>
(function() {
    function resolvePlanInfo(plan) {
        if (!plan) return { isPaid: false, planStr: '', planNum: 0, label: '' };
        var raw = (plan.licenseType != null ? plan.licenseType : plan.plan);
        var planStr = String(raw == null ? '' : raw).toLowerCase();
        var planNum = (typeof raw === 'number') ? raw : Number(raw);
        if (isNaN(planNum)) planNum = -1;
        var isPro        = planStr === 'pro' || planStr === 'professional' || planNum === 1;
        var isEnterprise = planStr === 'enterprise' || planNum === 2;
        var isFreeTrial  = planStr === 'freetrial' || planStr === 'free' || planStr === 'trial' || planNum === 0;
        var isPaid = isPro || isEnterprise ||
            (!isFreeTrial && planNum > 0) ||
            (plan.hasUsedTrial === true && plan.isTrialActive === false && plan.isTrialExpired === false);
        var label = isEnterprise ? 'Enterprise'
                  : isPro ? 'Pro'
                  : isPaid ? (planNum >= 2 ? 'Enterprise' : 'Pro')
                  : 'Free Trial';
        return { isPaid: isPaid, isEnterprise: isEnterprise, isPro: isPro, planStr: planStr, planNum: planNum, label: label };
    }

    function renderLicenseBadge(plan) {
        var el = document.getElementById('navLicenseBadge');
        if (!el) return;
        var info = resolvePlanInfo(plan);
        el.classList.remove('cp-license-badge-trial', 'cp-license-badge-pro', 'cp-license-badge-enterprise');
        if (info.isEnterprise) el.classList.add('cp-license-badge-enterprise');
        else if (info.isPro || info.isPaid) el.classList.add('cp-license-badge-pro');
        else el.classList.add('cp-license-badge-trial');
        el.textContent = info.label;
        el.style.display = 'inline-flex';
    }

    // Public: re-fetch the current user's plan, refresh cache, and redraw the license badge.
    // Trial / email-verify notices are now delivered via the notification bell (see NotificationSeedingService).
    window.refreshTrialBanner = function() {
        var user = null;
        try { user = JSON.parse(localStorage.getItem('cp_user') || 'null'); } catch {}
        if (!user || !user.id) return Promise.resolve();
        return fetch('/api/subscription/' + user.id, { credentials: 'same-origin' })
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(fresh) {
                if (!fresh) return;
                try { localStorage.setItem('cp_plan', JSON.stringify(fresh)); } catch {}
                renderLicenseBadge(fresh);
            })
            .catch(function() {});
    };

    var user = null;
    try { user = JSON.parse(localStorage.getItem('cp_user') || 'null'); } catch {}
    if (!user) return;

    var cached = null;
    try { cached = JSON.parse(localStorage.getItem('cp_plan') || 'null'); } catch {}
    renderLicenseBadge(cached);
    window.refreshTrialBanner();
})();
</script>
