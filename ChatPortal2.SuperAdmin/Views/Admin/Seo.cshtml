@model List<AIInsights.Models.SeoEntry>
@{
    ViewData["Title"] = "SEO Management";
    ViewData["ActivePage"] = "seo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title">SEO Management</h1>
        <p class="page-desc">Manage page metadata and search optimization</p>
    </div>
    <button class="btn-primary-sm" onclick="openAddModal()"><i class="bi bi-plus-lg"></i> Add Entry</button>
    <button class="btn-ghost-sm" style="margin-left:.5rem" onclick="autoFillSeo()"><i class="bi bi-magic"></i> Auto-Fill Pages</button>
</div>

<div id="saveAlert" style="display:none;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.2);color:#34d399;border-radius:10px;font-size:.85rem;padding:.7rem 1rem;margin-bottom:1rem">
    <i class="bi bi-check-circle me-1"></i>Changes saved successfully.
</div>

<div class="card-panel" style="overflow-x:auto">
    <table class="tbl">
        <thead>
            <tr>
                <th>Page URL</th>
                <th>Title</th>
                <th>Meta Description</th>
                <th>Updated</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in Model)
            {
                <tr>
                    <td><code style="color:#4a8ec9;font-size:.82rem">@entry.PageUrl</code></td>
                    <td style="color:#1e3a5f">@entry.Title</td>
                    <td style="font-size:.8rem">@(entry.MetaDescription?.Length > 80 ? entry.MetaDescription[..80] + "…" : entry.MetaDescription)</td>
                    <td style="color:var(--text-muted)">@entry.LastModified.ToString("MMM d, yyyy")</td>
                    <td>
                        <button class="btn-ghost-sm" style="padding:.35rem .65rem;font-size:.78rem" onclick='editEntry(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(entry, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase })))'>
                            <i class="bi bi-pencil-square"></i> Edit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Edit/Add Modal -->
<div class="modal fade" id="seoModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="background:#ffffff;color:#2d3748;border:1px solid #cdd8e4;border-radius:12px">
            <div class="modal-header" style="border-bottom:1px solid #cdd8e4">
                <h5 class="modal-title" style="font-weight:700;font-size:1rem" id="modalTitle">Edit SEO Entry</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="entryId" value="0" />
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" style="font-size:.78rem;color:#596d82;font-weight:500">Page URL</label>
                        <input type="text" id="entryPageUrl" class="form-control form-control-sm seo-input" placeholder="/page-path" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:.78rem;color:#596d82;font-weight:500">Title</label>
                        <input type="text" id="entryTitle" class="form-control form-control-sm seo-input" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:.78rem;color:#596d82;font-weight:500">OG Title</label>
                        <input type="text" id="entryOgTitle" class="form-control form-control-sm seo-input" />
                    </div>
                    <div class="col-12">
                        <label class="form-label" style="font-size:.78rem;color:#596d82;font-weight:500">Meta Description</label>
                        <textarea id="entryMetaDescription" class="form-control form-control-sm seo-input" rows="2"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label" style="font-size:.78rem;color:#596d82;font-weight:500">OG Description</label>
                        <textarea id="entryOgDescription" class="form-control form-control-sm seo-input" rows="2"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:.78rem;color:#596d82;font-weight:500">Meta Keywords</label>
                        <input type="text" id="entryMetaKeywords" class="form-control form-control-sm seo-input" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:.78rem;color:#596d82;font-weight:500">Robots Directive</label>
                        <select id="entryRobots" class="form-select form-select-sm seo-input">
                            <option>index, follow</option>
                            <option>noindex, follow</option>
                            <option>index, nofollow</option>
                            <option>noindex, nofollow</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid #cdd8e4;justify-content:space-between">
                <button type="button" class="btn-ghost-sm" id="aiSuggestBtn" onclick="aiSuggest()" style="color:#4a8ec9"><i class="bi bi-stars"></i> AI Suggest</button>
                <div style="display:flex;gap:.5rem">
                    <button type="button" class="btn-ghost-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn-primary-sm" onclick="saveSeoEntry()"><i class="bi bi-check-lg"></i> Save</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<style>
    .seo-input { background: #f0f4f8; border: 1px solid #cdd8e4; color: #2d3748; border-radius: 8px; font-family: 'Inter', sans-serif; }
    .seo-input:focus { background: #ffffff; color: #2d3748; border-color: #4a8ec9; box-shadow: 0 0 0 3px rgba(74,142,201,.12); }
    .seo-input option { background: #ffffff; color: #2d3748; }
</style>
<script>
var seoModal;
document.addEventListener('DOMContentLoaded', function () {
    seoModal = new bootstrap.Modal(document.getElementById('seoModal'));
});

function openAddModal() {
    document.getElementById('modalTitle').textContent = 'Add SEO Entry';
    document.getElementById('entryId').value = 0;
    document.getElementById('entryPageUrl').value = '';
    document.getElementById('entryTitle').value = '';
    document.getElementById('entryOgTitle').value = '';
    document.getElementById('entryMetaDescription').value = '';
    document.getElementById('entryOgDescription').value = '';
    document.getElementById('entryMetaKeywords').value = '';
    document.getElementById('entryRobots').value = 'index, follow';
    seoModal.show();
}

function editEntry(entry) {
    document.getElementById('modalTitle').textContent = 'Edit SEO Entry';
    document.getElementById('entryId').value = entry.id;
    document.getElementById('entryPageUrl').value = entry.pageUrl || '';
    document.getElementById('entryTitle').value = entry.title || '';
    document.getElementById('entryOgTitle').value = entry.ogTitle || '';
    document.getElementById('entryMetaDescription').value = entry.metaDescription || '';
    document.getElementById('entryOgDescription').value = entry.ogDescription || '';
    document.getElementById('entryMetaKeywords').value = entry.metaKeywords || '';
    document.getElementById('entryRobots').value = entry.robotsDirective || 'index, follow';
    seoModal.show();
}

async function saveSeoEntry() {
    var payload = {
        id: parseInt(document.getElementById('entryId').value),
        pageUrl: document.getElementById('entryPageUrl').value,
        title: document.getElementById('entryTitle').value,
        ogTitle: document.getElementById('entryOgTitle').value,
        metaDescription: document.getElementById('entryMetaDescription').value,
        ogDescription: document.getElementById('entryOgDescription').value,
        metaKeywords: document.getElementById('entryMetaKeywords').value,
        robotsDirective: document.getElementById('entryRobots').value
    };
    try {
        var res = await fetch('/superadmin/seo/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        if (res.ok) {
            seoModal.hide();
            var alertEl = document.getElementById('saveAlert');
            alertEl.style.display = 'block';
            setTimeout(function() { alertEl.style.display = 'none'; location.reload(); }, 1500);
        } else {
            alert('Save failed. Please try again.');
        }
    } catch (e) {
        alert('Network error: ' + e.message);
    }
}

async function aiSuggest() {
    var pageUrl = document.getElementById('entryPageUrl').value;
    if (!pageUrl) { alert('Enter a Page URL first.'); return; }
    var btn = document.getElementById('aiSuggestBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Generating...';
    try {
        var res = await fetch('/superadmin/seo/ai-suggest', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ pageUrl: pageUrl, context: document.getElementById('entryTitle').value })
        });
        if (res.ok) {
            var data = await res.json();
            if (data.title) document.getElementById('entryTitle').value = data.title;
            if (data.metaDescription) document.getElementById('entryMetaDescription').value = data.metaDescription;
            if (data.metaKeywords) document.getElementById('entryMetaKeywords').value = data.metaKeywords;
            if (data.ogTitle) document.getElementById('entryOgTitle').value = data.ogTitle;
            if (data.ogDescription) document.getElementById('entryOgDescription').value = data.ogDescription;
            if (data.robotsDirective) document.getElementById('entryRobots').value = data.robotsDirective;
        } else {
            alert('AI suggestion failed. Please try again.');
        }
    } catch (e) {
        alert('Network error: ' + e.message);
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-stars"></i> AI Suggest';
    }
}

async function autoFillSeo() {
    if (!confirm('Auto-fill SEO entries for all known app pages? Existing entries will not be overwritten.')) return;
    try {
        var res = await fetch('/superadmin/seo/autofill', { method: 'POST' });
        if (res.ok) {
            var data = await res.json();
            var alertEl = document.getElementById('saveAlert');
            alertEl.innerHTML = '<i class="bi bi-check-circle me-1"></i>' + data.added + ' page(s) added.';
            alertEl.style.display = 'block';
            setTimeout(function() { alertEl.style.display = 'none'; location.reload(); }, 1500);
        } else {
            alert('Auto-fill failed. Please try again.');
        }
    } catch (e) {
        alert('Network error: ' + e.message);
    }
}
</script>
}
