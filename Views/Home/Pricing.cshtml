@{
    ViewData["Title"] = "Pricing";
    var salesEmail = (Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration)?["App:SalesEmail"] ?? "sales@aiinsights.io";
}

<section class="cp-section cp-page-hero">
    <div class="container text-center">
        <h1 class="page-title">Pricing Plans</h1>
        <p class="page-subtitle">Choose the plan that fits your needs. Start with a 30-day free trial — no credit card required.</p>
    </div>
</section>

<section class="cp-section">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="pricing-card glass-card text-center h-100">
                    <div class="pricing-tier">Free Trial</div>
                    <div class="pricing-price">$0 <span class="pricing-period">/ 30 days</span></div>
                    <p class="text-muted small mb-3">Evaluate every Pro feature — no card required.</p>
                    <ul class="pricing-features text-start">
                        <li><i class="bi bi-check-circle-fill me-2"></i><strong>1 workspace</strong></li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Up to <strong>3 AI agents</strong></li>
                        <li><i class="bi bi-check-circle-fill me-2"></i><strong>2,000,000 AI tokens</strong> / month (trial pool)</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>AI chat over SQL &amp; file datasources</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>72+ interactive chart types</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Auto Report Generator</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Q&amp;A floating panel on reports</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Pin-to-dashboard</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Share links (tokenized)</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Email notifications</li>
                        <li><i class="bi bi-x-circle me-2 text-muted"></i>Community support only</li>
                        <li><i class="bi bi-x-circle me-2 text-muted"></i>No API / webhooks</li>
                        <li><i class="bi bi-x-circle me-2 text-muted"></i>No SSO / on-prem gateway</li>
                    </ul>
                    <button class="btn cp-btn-gradient w-100" id="startTrialBtn">Start 30-Day Free Trial</button>
                </div>
            </div>

            <div class="col-md-4">
                <div class="pricing-card glass-card pricing-featured text-center h-100">
                    <div class="pricing-badge">Most Popular</div>
                    <div class="pricing-tier">Professional</div>
                    <div class="pricing-price">$25 <span class="pricing-period">/ user / month</span></div>
                    <p class="text-muted small mb-3">Everything a growing team needs to run on AI-powered analytics.</p>
                    <ul class="pricing-features text-start">
                        <li><i class="bi bi-check-circle-fill me-2"></i>Up to <strong>10 workspaces</strong></li>
                        <li><i class="bi bi-check-circle-fill me-2"></i><strong>Unlimited AI agents</strong></li>
                        <li><i class="bi bi-check-circle-fill me-2"></i><strong>5,000,000 AI tokens</strong> / org / month</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Top-up token packs when you run out</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>All Free Trial features</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Role-based workspace permissions</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Scheduled reports + email delivery</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Public REST API + webhooks</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Export to PDF / Excel / CSV</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Custom branding (logo + colors)</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Activity logs &amp; audit trail</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Priority email support (24h SLA)</li>
                        <li><i class="bi bi-x-circle me-2 text-muted"></i>No SSO / SAML</li>
                        <li><i class="bi bi-x-circle me-2 text-muted"></i>No on-prem data gateway</li>
                    </ul>
                    <button class="btn cp-btn-gradient w-100" data-bs-toggle="modal" data-bs-target="#pricingPaymentModal">Get Professional</button>
                </div>
            </div>

            <div class="col-md-4">
                <div class="pricing-card glass-card text-center h-100">
                    <div class="pricing-tier">Enterprise</div>
                    <div class="pricing-price">$45 <span class="pricing-period">/ user / month</span></div>
                    <p class="text-muted small mb-3">Advanced security, governance &amp; private deployment for large orgs.</p>
                    <ul class="pricing-features text-start">
                        <li><i class="bi bi-check-circle-fill me-2"></i>Everything in Professional</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i><strong>Unlimited workspaces</strong></li>
                        <li><i class="bi bi-check-circle-fill me-2"></i><strong>10,000,000 AI tokens</strong> / org / month (top-up packs available)</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i><strong>SSO / SAML / OIDC</strong></li>
                        <li><i class="bi bi-check-circle-fill me-2"></i><strong>On-Prem Data Gateway</strong> (Phase 2)</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>15+ enterprise connectors (Snowflake, BigQuery, Databricks, Redshift, Oracle, SAP HANA, MongoDB, Elasticsearch, ClickHouse, Salesforce, HubSpot, GA4, Stripe, Shopify, REST)</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Custom AI models &amp; fine-tuning hooks</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Row-level security &amp; query allow-lists</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Private cloud / on-premise deployment</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Dedicated Customer Success Manager</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>99.9% uptime SLA</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>24/7 priority support (4h SLA)</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Custom contract &amp; invoicing</li>
                    </ul>
                    <a href="mailto:@salesEmail" class="btn btn-outline-cp w-100">Contact Sales</a>
                </div>
            </div>
        </div>

        <p class="text-center text-muted small mt-4 mb-0">
            All paid plans are billed monthly and renew automatically. You can cancel any time from
            <em>Organization Settings &rarr; Users &amp; Licensing</em>. Payments are final — <a href="/terms#refund-policy">no refund</a>
            is issued for the current paying period.
        </p>
    </div>
</section>

<!-- Payment Modal -->
<div class="modal fade" id="pricingPaymentModal" tabindex="-1" aria-labelledby="pricingPaymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="pricingPaymentModalLabel"><i class="bi bi-credit-card me-2"></i>Subscribe — Professional Plan ($25/mo)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="pricingPaymentAlert" class="alert d-none"></div>
                <ul class="nav nav-tabs mb-3">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#pricingTabCC"><i class="bi bi-credit-card me-1"></i>Credit Card</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#pricingTabPayPal"><i class="bi bi-paypal me-1"></i>PayPal</a>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="pricingTabCC">
                        <div class="mb-3">
                            <label class="form-label">Card Number</label>
                            <input type="text" class="form-control" id="pricingCardNumber" placeholder="4242 4242 4242 4242" maxlength="19" autocomplete="cc-number" />
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label">Expiration</label>
                                <input type="text" class="form-control" id="pricingCardExpiry" placeholder="MM / YY" maxlength="7" autocomplete="cc-exp" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">CVC</label>
                                <input type="text" class="form-control" id="pricingCardCvc" placeholder="123" maxlength="4" autocomplete="cc-csc" />
                            </div>
                        </div>
                        <button class="btn cp-btn-gradient w-100" id="pricingStripeBtn">
                            <i class="bi bi-lock me-2"></i>Subscribe Now
                        </button>
                    </div>
                    <div class="tab-pane fade" id="pricingTabPayPal">
                        <div class="text-center py-4">
                            <p class="text-muted mb-4">Click below to pay securely with PayPal.</p>
                            <button class="btn btn-lg w-100" id="pricingPayPalBtn" style="background:#0070ba;border-color:#0070ba;color:#fff">
                                <i class="bi bi-paypal me-2"></i>Pay with PayPal
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('startTrialBtn')?.addEventListener('click', function() {
    var user = JSON.parse(localStorage.getItem('cp_user') || 'null');
    if (!user) { window.location.href = '/auth/register'; return; }
    $.post('/api/subscription/activate-trial', JSON.stringify({ userId: user.id }), function(r) {
        alert('Trial activated! You have ' + r.daysRemaining + ' days remaining.');
    }, 'json').fail(function(e) {
        alert(e.responseJSON?.error || 'Could not activate trial.');
    });
});

(function() {
    function subscribeUpgrade(btn) {
        var user = JSON.parse(localStorage.getItem('cp_user') || 'null');
        if (!user) { window.location.href = '/auth/register'; return; }
        btn.disabled = true;
        var alertEl = document.getElementById('pricingPaymentAlert');
        fetch('/api/subscription/upgrade', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: user.id, plan: 2 })
        }).then(function(r) { return r.json(); }).then(function() {
            if (alertEl) { alertEl.className = 'alert alert-success'; alertEl.textContent = 'Subscription upgraded to Professional! Enjoy your plan.'; alertEl.classList.remove('d-none'); }
        }).catch(function() {
            if (alertEl) { alertEl.className = 'alert alert-danger'; alertEl.textContent = 'Could not process payment. Please try again.'; alertEl.classList.remove('d-none'); }
        }).finally(function() { btn.disabled = false; });
    }
    document.getElementById('pricingStripeBtn')?.addEventListener('click', function() { subscribeUpgrade(this); });
    document.getElementById('pricingPayPalBtn')?.addEventListener('click', function() { subscribeUpgrade(this); });
})();
</script>
}
