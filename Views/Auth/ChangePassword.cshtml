@{
    ViewData["Title"] = "Change Password";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="container">
        <div class="row justify-content-center min-vh-100 align-items-center">
            <div class="col-md-5">
                <div class="auth-card glass-card">
                    <div class="auth-header text-center mb-4">
                        <div class="auth-logo">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>
                        <h2 class="auth-title">Change Password</h2>
                        <p class="text-muted small">Your account requires a new password before continuing.</p>
                    </div>
                    <div id="authAlert" class="alert d-none"></div>
                    <form id="changePasswordForm">
                        <div class="mb-3">
                            <label class="form-label-cp">Current Password</label>
                            <div class="input-group-cp">
                                <i class="bi bi-lock input-icon"></i>
                                <input type="password" class="form-control cp-input" id="currentPassword"
                                       placeholder="••••••••" required autocomplete="current-password" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label-cp">New Password</label>
                            <div class="input-group-cp">
                                <i class="bi bi-lock-fill input-icon"></i>
                                <input type="password" class="form-control cp-input" id="newPassword"
                                       placeholder="••••••••" required autocomplete="new-password" />
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label-cp">Confirm New Password</label>
                            <div class="input-group-cp">
                                <i class="bi bi-lock-fill input-icon"></i>
                                <input type="password" class="form-control cp-input" id="confirmPassword"
                                       placeholder="••••••••" required autocomplete="new-password" />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 cp-btn-primary">
                            <i class="bi bi-check-circle me-1"></i> Update Password
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('changePasswordForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const alert = document.getElementById('authAlert');
    alert.className = 'alert d-none';

    const currentPassword = document.getElementById('currentPassword').value;
    const newPassword = document.getElementById('newPassword').value;
    const confirmPassword = document.getElementById('confirmPassword').value;

    if (newPassword !== confirmPassword) {
        alert.className = 'alert alert-danger';
        alert.textContent = 'New passwords do not match.';
        return;
    }

    try {
        const token = localStorage.getItem('authToken') || sessionStorage.getItem('authToken');
        const headers = { 'Content-Type': 'application/json' };
        if (token) headers['Authorization'] = 'Bearer ' + token;

        const r = await fetch('/api/auth/change-password', {
            method: 'POST',
            headers,
            body: JSON.stringify({ currentPassword, newPassword })
        });
        const data = await r.json();
        if (r.ok) {
            alert.className = 'alert alert-success';
            alert.textContent = 'Password changed successfully. Redirecting…';
            setTimeout(() => { window.location.href = data.redirectUrl || '/chat'; }, 1000);
        } else {
            alert.className = 'alert alert-danger';
            alert.textContent = data.error || 'Failed to change password.';
        }
    } catch (err) {
        alert.className = 'alert alert-danger';
        alert.textContent = 'Network error. Please try again.';
    }
});
</script>
}
