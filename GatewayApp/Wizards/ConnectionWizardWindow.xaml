<Window x:Class="GatewayApp.Wizards.ConnectionWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="Datasource Connection Wizard"
        Height="460"
        Width="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}">
    <DockPanel Margin="16">
        <TabControl SelectedIndex="{Binding StepIndex}" IsEnabled="False" BorderThickness="0" Background="Transparent">
            <TabItem Header="Step 1">
                <StackPanel Margin="10">
                    <TextBlock Text="Choose Connection Type" FontWeight="Bold" Margin="0,0,0,8" />
                    <ComboBox SelectedItem="{Binding ConnectionType}" Width="220">
                        <sys:String>OnPremises</sys:String>
                        <sys:String>Online</sys:String>
                    </ComboBox>
                </StackPanel>
            </TabItem>
            <TabItem Header="Step 2">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                    <PasswordBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" PasswordChanged="PasswordBox_OnPasswordChanged" />
                </Grid>
            </TabItem>
            <TabItem Header="Step 3">
                <StackPanel Margin="10">
                    <TextBlock Text="Test &amp; Confirm" FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBlock Text="Click Next to test the connection and save datasource." />
                    <TextBlock Text="{Binding Status}" Margin="0,10,0,0" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Back" Width="80" Margin="0,0,8,0" Command="{Binding BackCommand}" />
            <Button Content="Next" Width="80" Margin="0,0,8,0" Command="{Binding NextCommand}" />
            <Button Content="Cancel" Width="80" Command="{Binding CancelCommand}" />
        </StackPanel>
    </DockPanel>
</Window>
