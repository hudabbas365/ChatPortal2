    // Nice Bootstrap-based confirm (replaces native confirm()).
    // Returns a Promise<boolean>.
    window.cpConfirm = function(opts) {
        return new Promise(resolve => {
            const modalEl = document.getElementById('confirmActionModal');
            const iconEl  = document.getElementById('confirmActionIcon');
            const titleEl = document.getElementById('confirmActionTitle');
            const msgEl   = document.getElementById('confirmActionMessage');
            const subEl   = document.getElementById('confirmActionSubtext');
            const btn     = document.getElementById('confirmActionBtn');
            const btnLbl  = document.getElementById('confirmActionBtnLabel');

            titleEl.textContent = opts.title || 'Confirm Action';
            msgEl.textContent   = opts.message || 'Are you sure?';
            subEl.textContent   = opts.subtext || '';
            btnLbl.textContent  = opts.confirmText || 'Confirm';
            iconEl.className    = 'bi me-2 ' + (opts.icon || 'bi-question-circle');
            btn.className       = 'btn btn-' + (opts.variant || 'danger');

            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            const onConfirm = () => { cleanup(); modal.hide(); resolve(true); };
            const onHide    = () => { cleanup(); resolve(false); };
            function cleanup() {
                btn.removeEventListener('click', onConfirm);
                modalEl.removeEventListener('hidden.bs.modal', onHide);
            }
            btn.addEventListener('click', onConfirm, { once: true });
            modalEl.addEventListener('hidden.bs.modal', onHide, { once: true });
            modal.show();
        });
    };

    window.changeRole = function(uid, current) {
