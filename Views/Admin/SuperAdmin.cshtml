@{
    ViewData["Title"] = "Super Admin Overview";
    Layout = "_Layout";
}

<div class="admin-page">
    <div class="container-fluid py-4">
        <div class="admin-header mb-4">
            <h1 class="admin-title">
                <i class="bi bi-stars me-2"></i>Super Admin Overview
            </h1>
            <p class="admin-subtitle">System-wide metrics, content, and communication management</p>
        </div>

        <!-- System-Wide Metrics -->
        <h5 class="fw-semibold mb-3 text-muted">System-Wide Metrics</h5>
        <div class="row g-4 mb-5">
            <div class="col-md-2 col-sm-4">
                <div class="stat-card glass-card text-center">
                    <div class="stat-icon stat-icon-blue mx-auto">
                        <i class="bi bi-building"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">@ViewBag.TotalOrgs</div>
                        <div class="stat-label">Organizations</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-sm-4">
                <div class="stat-card glass-card text-center">
                    <div class="stat-icon stat-icon-green mx-auto">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">@ViewBag.TotalUsers</div>
                        <div class="stat-label">Total Users</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-sm-4">
                <div class="stat-card glass-card text-center">
                    <div class="stat-icon stat-icon-purple mx-auto">
                        <i class="bi bi-folder-fill"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">@ViewBag.TotalWorkspaces</div>
                        <div class="stat-label">Workspaces</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-sm-4">
                <div class="stat-card glass-card text-center">
                    <div class="stat-icon stat-icon-orange mx-auto">
                        <i class="bi bi-chat-dots-fill"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">@ViewBag.TotalMessages</div>
                        <div class="stat-label">Messages</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-sm-4">
                <div class="stat-card glass-card text-center">
                    <div class="stat-icon stat-icon-blue mx-auto">
                        <i class="bi bi-robot"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">@ViewBag.TotalAgents</div>
                        <div class="stat-label">Agents</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-sm-4">
                <div class="stat-card glass-card text-center">
                    <div class="stat-icon stat-icon-green mx-auto">
                        <i class="bi bi-database-fill"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">@ViewBag.TotalDatasources</div>
                        <div class="stat-label">Datasources</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Blog & Updates -->
        <h5 class="fw-semibold mb-3 text-muted">Blog &amp; Updates</h5>
        <div class="row g-4 mb-5">
            <div class="col-md-6">
                <div class="admin-action-card glass-card">
                    <div class="admin-action-icon">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <h4>Publish Blog Post</h4>
                    <p>Create and publish new blog articles, tutorials, or product updates to engage your users.</p>
                    <a href="#" class="btn cp-btn-gradient">
                        <i class="bi bi-pencil-square me-2"></i>Write Post
                    </a>
                </div>
            </div>
            <div class="col-md-6">
                <div class="admin-action-card glass-card">
                    <div class="admin-action-icon">
                        <i class="bi bi-megaphone"></i>
                    </div>
                    <h4>System Announcements</h4>
                    <p>Post platform-wide announcements, maintenance notices, or feature release notes.</p>
                    <a href="#" class="btn cp-btn-gradient">
                        <i class="bi bi-megaphone me-2"></i>Post Announcement
                    </a>
                </div>
            </div>
        </div>

        <!-- Communication -->
        <h5 class="fw-semibold mb-3 text-muted">Communication</h5>
        <div class="row g-4 mb-5">
            <div class="col-md-6">
                <div class="admin-action-card glass-card">
                    <div class="admin-action-icon">
                        <i class="bi bi-envelope-fill"></i>
                    </div>
                    <h4>Send Broadcast Email</h4>
                    <p>Send a broadcast email to all users, a specific plan tier, or a selected organization.</p>
                    <a href="#" class="btn cp-btn-gradient">
                        <i class="bi bi-envelope-fill me-2"></i>Compose Broadcast
                    </a>
                </div>
            </div>
            <div class="col-md-6">
                <div class="admin-action-card glass-card">
                    <div class="admin-action-icon">
                        <i class="bi bi-arrow-left-circle"></i>
                    </div>
                    <h4>Back to Admin Dashboard</h4>
                    <p>Return to the main Admin Dashboard for day-to-day operational management.</p>
                    <a href="/admin" class="btn btn-outline-cp">
                        <i class="bi bi-arrow-left-circle me-2"></i>Admin Dashboard
                    </a>
                </div>
            </div>
        </div>

        <!-- Platform Users Management -->
        <h5 class="fw-semibold mb-3 text-muted">Platform Users</h5>
        <div class="glass-card p-4 mb-5">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="input-group input-group-sm" style="max-width:300px">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" id="superUserSearch" placeholder="Search users...">
                </div>
                <span class="text-muted small" id="superUserCount"></span>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0" id="superUsersTable">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Organization</th>
                            <th>Role</th>
                            <th style="width:120px">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="superUsersBody">
                        <tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-hourglass-split me-1"></i>Loading users...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    let _allUsers = [];

    async function loadUsers() {
        try {
            const r = await fetch('/api/admin/super/users');
            if (!r.ok) throw new Error();
            _allUsers = await r.json();
            renderUsers(_allUsers);
        } catch {
            document.getElementById('superUsersBody').innerHTML =
                '<tr><td colspan="5" class="text-center text-danger py-4">Failed to load users.</td></tr>';
        }
    }

    function esc(s) {
        const d = document.createElement('div');
        d.textContent = s || '';
        return d.innerHTML;
    }

    function renderUsers(users) {
        const tbody = document.getElementById('superUsersBody');
        const countEl = document.getElementById('superUserCount');
        if (countEl) countEl.textContent = users.length + ' users';
        if (!users.length) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">No users found.</td></tr>';
            return;
        }
        tbody.innerHTML = users.map(u => `
            <tr data-user-id="${esc(u.id)}">
                <td>${esc(u.fullName || '—')}</td>
                <td>${esc(u.email)}</td>
                <td>${esc(u.organizationName || '—')}</td>
                <td>
                    <select class="form-select form-select-sm super-role-sel" data-user-id="${esc(u.id)}" style="width:130px">
                        <option value="User" ${u.role === 'User' ? 'selected' : ''}>User</option>
                        <option value="OrgAdmin" ${u.role === 'OrgAdmin' ? 'selected' : ''}>Org Admin</option>
                        <option value="SuperAdmin" ${u.role === 'SuperAdmin' ? 'selected' : ''}>Super Admin</option>
                    </select>
                </td>
                <td>
                    <button class="btn btn-xs btn-outline-primary super-save-role" data-user-id="${esc(u.id)}">
                        <i class="bi bi-check-lg"></i> Save
                    </button>
                </td>
            </tr>
        `).join('');

        tbody.querySelectorAll('.super-save-role').forEach(btn => {
            btn.addEventListener('click', async () => {
                const userId = btn.dataset.userId;
                const sel = tbody.querySelector(`.super-role-sel[data-user-id="${userId}"]`);
                if (!sel) return;
                btn.disabled = true;
                try {
                    const r = await fetch('/api/admin/super/users/' + encodeURIComponent(userId) + '/role', {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ role: sel.value })
                    });
                    if (!r.ok) throw new Error();
                    btn.innerHTML = '<i class="bi bi-check-circle-fill"></i> Saved';
                    setTimeout(() => { btn.innerHTML = '<i class="bi bi-check-lg"></i> Save'; btn.disabled = false; }, 1500);
                } catch {
                    alert('Failed to update role.');
                    btn.disabled = false;
                }
            });
        });
    }

    document.getElementById('superUserSearch')?.addEventListener('input', function() {
        const q = this.value.toLowerCase().trim();
        if (!q) { renderUsers(_allUsers); return; }
        renderUsers(_allUsers.filter(u =>
            (u.fullName || '').toLowerCase().includes(q) ||
            (u.email || '').toLowerCase().includes(q) ||
            (u.organizationName || '').toLowerCase().includes(q)
        ));
    });

    document.addEventListener('DOMContentLoaded', loadUsers);
})();
</script>
