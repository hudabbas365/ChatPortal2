@{
    ViewData["Title"] = "Revenue & Income";
    ViewData["ActivePage"] = "revenue";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h1 class="page-title">Revenue &amp; Income</h1>
    <p class="page-desc">Subscription revenue breakdown and payment details</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="stat">
            <div class="stat-icon" style="background:rgba(52,211,153,.1);color:#34d399"><i class="bi bi-cash-coin"></i></div>
            <div class="stat-val">$@(((decimal)ViewBag.PaymentsCollectedAll).ToString("N2"))</div>
            <div class="stat-label">Total Collected (all-time)</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat">
            <div class="stat-icon" style="background:rgba(74,142,201,.1);color:#4a8ec9"><i class="bi bi-calendar-check"></i></div>
            <div class="stat-val">$@(((decimal)ViewBag.PaymentsCollectedThisMonth).ToString("N2"))</div>
            <div class="stat-label">Collected This Month</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat">
            <div class="stat-icon" style="background:rgba(168,85,247,.1);color:#a855f7"><i class="bi bi-graph-up"></i></div>
            <div class="stat-val">$@ViewBag.TotalIncome.ToString("N2")</div>
            <div class="stat-label">Current MRR (active plans)</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat">
            <div class="stat-icon" style="background:rgba(245,158,11,.1);color:#fbbf24"><i class="bi bi-clock"></i></div>
            <div class="stat-val">@ViewBag.ActiveTrials</div>
            <div class="stat-label">Active Free Trials</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="stat">
            <div class="stat-icon" style="background:rgba(74,142,201,.1);color:#4a8ec9"><i class="bi bi-award"></i></div>
            <div class="stat-val">@ViewBag.ProCount</div>
            <div class="stat-label">Professional ($@AIInsights.Models.PlanPricing.ProPricePerUser/user)</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat">
            <div class="stat-icon" style="background:rgba(14,165,233,.1);color:#38bdf8"><i class="bi bi-building-fill-gear"></i></div>
            <div class="stat-val">@ViewBag.EnterpriseCount</div>
            <div class="stat-label">Enterprise ($@AIInsights.Models.PlanPricing.EnterprisePricePerUser/user)</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat">
            <div class="stat-icon" style="background:rgba(99,102,241,.1);color:#6366f1"><i class="bi bi-receipt"></i></div>
            <div class="stat-val">@ViewBag.PaymentsCount</div>
            <div class="stat-label">Successful Payments</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card-panel">
            <div class="card-panel-title">Revenue Breakdown</div>
            <table class="tbl">
                <thead>
                    <tr>
                        <th>Plan</th>
                        <th>Users</th>
                        <th>Price/User</th>
                        <th>Monthly</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="badge-sm badge-indigo">Professional</span></td>
                        <td>@ViewBag.ProCount</td>
                        <td>$@AIInsights.Models.PlanPricing.ProPricePerUser</td>
                        <td style="color:#1e3a5f;font-weight:600">$@ViewBag.ProRevenue.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td><span class="badge-sm badge-emerald">Enterprise</span></td>
                        <td>@ViewBag.EnterpriseCount</td>
                        <td>$@AIInsights.Models.PlanPricing.EnterprisePricePerUser</td>
                        <td style="color:#1e3a5f;font-weight:600">$@ViewBag.EnterpriseRevenue.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td><span class="badge-sm badge-amber">Free Trial</span></td>
                        <td>@ViewBag.ActiveTrials</td>
                        <td>—</td>
                        <td style="color:var(--text-muted)">$0.00</td>
                    </tr>
                    <tr>
                        <td colspan="3" style="color:#1e3a5f;font-weight:700">Total</td>
                        <td style="color:#4a8ec9;font-weight:700">$@ViewBag.TotalIncome.ToString("N2")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card-panel">
            <div class="card-panel-title">Plan Distribution</div>
            <div id="planChart" style="min-height:160px"></div>
        </div>
    </div>
</div>

<div class="card-panel">
    <div class="card-panel-title">Users with Payment Methods</div>
    @{
        var paidUsers = ViewBag.PaidUsers as IEnumerable<dynamic>;
    }
    @if (paidUsers == null || !paidUsers.Any())
    {
        <p style="color:var(--text-muted);font-size:.85rem">No payment methods on file yet.</p>
    }
    else
    {
        <div style="overflow-x:auto">
        <table class="tbl">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Card Brand</th>
                    <th>Masked Number</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in paidUsers)
                {
                    <tr>
                        <td style="color:#1e3a5f;font-weight:500">@user.FullName</td>
                        <td>@user.Email</td>
                        <td><span class="badge-sm badge-indigo">@user.CardBrand</span></td>
                        <td>**** **** **** @user.CardLast4</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

<div class="card-panel">
    <div class="card-panel-title">Recent Payments</div>
    @{
        var recent = ViewBag.RecentPayments as IEnumerable<dynamic>;
    }
    @if (recent == null || !recent.Any())
    {
        <p style="color:var(--text-muted);font-size:.85rem">No payments recorded yet.</p>
    }
    else
    {
        <div style="overflow-x:auto">
        <table class="tbl">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Invoice</th>
                    <th>Type</th>
                    <th>Method</th>
                    <th>Payer</th>
                    <th>Status</th>
                    <th style="text-align:right">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in recent)
                {
                    <tr>
                        <td>@(((DateTime)p.CreatedAt).ToString("yyyy-MM-dd HH:mm"))</td>
                        <td><code style="color:#4a8ec9">@(p.InvoiceNumber ?? "—")</code></td>
                        <td>@p.PaymentType</td>
                        <td>@p.PaymentMethod</td>
                        <td>@(p.PayerEmail ?? "—")</td>
                        <td>
                            @if ((string)p.Status == "succeeded")
                            {
                                <span class="badge-sm badge-emerald">succeeded</span>
                            }
                            else if ((string)p.Status == "refunded")
                            {
                                <span class="badge-sm badge-amber">refunded</span>
                            }
                            else
                            {
                                <span class="badge-sm" style="background:rgba(239,68,68,.1);color:#ef4444">@p.Status</span>
                            }
                        </td>
                        <td style="text-align:right;font-weight:600;color:#1e3a5f">@p.Currency $@(((decimal)p.Amount).ToString("N2"))</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/apexcharts@3.54.0/dist/apexcharts.min.js"></script>
<script>
(function () {
    var el = document.getElementById('planChart');
    if (!el) return;
    new ApexCharts(el, {
        chart: { type: 'donut', height: 220, fontFamily: 'Inter, sans-serif', toolbar: { show: false }, animations: { speed: 500 } },
        series: [@ViewBag.ProCount, @ViewBag.EnterpriseCount, @ViewBag.ActiveTrials],
        labels: ['Professional', 'Enterprise', 'Free Trial'],
        colors: ['rgba(74,142,201,0.9)', 'rgba(52,211,153,0.9)', 'rgba(245,158,11,0.85)'],
        plotOptions: { pie: { donut: { size: '65%' } } },
        legend: { labels: { colors: '#596d82' }, fontFamily: 'Inter', fontSize: '12px' },
        dataLabels: { enabled: false },
        tooltip: { theme: 'dark' }
    }).render();
})();
</script>
}
