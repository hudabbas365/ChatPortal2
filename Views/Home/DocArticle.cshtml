@model AIInsights.Models.DocArticle
@{
    ViewData["Title"] = Model.Title;
}

<section class="cp-section cp-page-hero">
    <div class="container">
        <h1 class="page-title">@Model.Title</h1>
        <p class="page-subtitle">
            @if (!string.IsNullOrWhiteSpace(Model.Author))
            {
                <span>By @Model.Author · </span>
            }
            <span>Last updated @Model.UpdatedAt.ToString("MMMM dd, yyyy")</span>
        </p>
    </div>
</section>

<section class="cp-section">
    <div class="container">
        <div class="docs-content glass-card p-4 p-md-5">
            @Html.Raw(Model.Content)
            <div class="mt-4">
                <a href="/docs" class="blog-read-more">← Back to Documentation</a>
            </div>
        </div>
    </div>
</section>
