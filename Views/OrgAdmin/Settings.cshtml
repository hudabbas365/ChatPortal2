@{
    ViewData["Title"] = "Organization Settings";
    Layout = "_Layout";
}

<div class="org-settings-page">
    <div class="org-settings-shell">
        <!-- Left sidebar navigation -->
        <aside class="org-settings-nav">
            <div class="org-settings-nav-header">
                <i class="bi bi-gear"></i>
                <span>Settings</span>
            </div>
            <button class="org-settings-nav-item active" data-tab="org">
                <i class="bi bi-building"></i><span>Organization</span>
            </button>
            <button class="org-settings-nav-item" data-tab="users">
                <i class="bi bi-people"></i><span>Users</span>
            </button>
            <button class="org-settings-nav-item" data-tab="ws-members">
                <i class="bi bi-person-badge"></i><span>Workspace Members</span>
            </button>
            <button class="org-settings-nav-item" data-tab="billing">
                <i class="bi bi-credit-card-2-front"></i><span>Billing</span>
            </button>
            <button class="org-settings-nav-item" data-tab="compliance">
                <i class="bi bi-shield-check"></i><span>Compliance</span>
            </button>
            <button class="org-settings-nav-item" data-tab="activity">
                <i class="bi bi-activity"></i><span>Activity</span>
            </button>
        </aside>

        <!-- Right content area -->
        <div class="org-settings-content">
            <!-- Organization Tab -->
            <div class="org-settings-panel active" data-panel="org">
                <div class="org-panel-header">
                    <h2>Organization Profile</h2>
                    <p>Manage your organization identity and branding</p>
                </div>
                <div class="org-form-card">
                    <div class="org-form-section">
                        <div class="org-form-section-label">
                            <i class="bi bi-building"></i>Details
                        </div>
                        <div class="org-form-group">
                            <label class="org-form-label" for="orgNameInput">Organization Name</label>
                            <input type="text" class="org-form-input" id="orgNameInput" placeholder="Acme Corp" readonly autocomplete="off" />
                            <span class="org-form-hint"><i class="bi bi-lock me-1"></i>Set during sign-up and cannot be changed</span>
                        </div>
                    </div>
                    <div class="org-form-divider"></div>
                    <div class="org-form-section">
                        <div class="org-form-section-label">
                            <i class="bi bi-image"></i>Branding
                        </div>
                        <div class="org-form-group">
                            <label class="org-form-label">Logo URL</label>
                            <input type="url" class="org-form-input" placeholder="https://your-logo-url.com/logo.png" autocomplete="off" />
                            <span class="org-form-hint">Recommended: 256×256px, PNG or SVG</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Users Tab -->
            <div class="org-settings-panel" data-panel="users">
                <div class="org-panel-header">
                    <h2>User Management</h2>
                    <p>Manage your organization's users, roles, and permissions</p>
                </div>
                <div class="org-form-card">
                    <!-- Token Usage Widget -->
                    <div class="token-budget-card" id="tokenUsageCard">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong><i class="bi bi-cpu me-2"></i>AI Token Usage (This Month)</strong>
                            <span class="small text-muted" id="tokenUsageText">Loading...</span>
                        </div>
                        <div class="token-budget-bar-wrap">
                            <div class="token-budget-bar-fill" id="tokenUsageBar" style="width:0%"></div>
                        </div>
                        <div class="token-budget-label" id="tokenUsageLabel">&nbsp;</div>
                    </div>
                </div>
                <div class="org-form-card" style="margin-top:16px">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h4 style="margin:0;font-size:1rem;font-weight:600">Users</h4>
                        </div>
                        <button class="btn cp-btn-gradient btn-sm" id="createUserBtn">
                            <i class="bi bi-person-plus me-1"></i>Create User
                        </button>
                    </div>
                    <div class="table-responsive">
                        <table class="table cp-table">
                            <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>License</th><th>Token Budget</th><th>Actions</th></tr></thead>
                            <tbody id="usersTableBody"><tr><td colspan="7" class="text-center text-muted py-3">No users yet</td></tr></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Workspace Members Tab -->
            <div class="org-settings-panel" data-panel="ws-members">
                <div class="org-panel-header">
                    <h2>Workspace Members</h2>
                    <p>Manage workspace membership and roles for your organisation's workspaces</p>
                </div>
                <div class="org-form-card">
                    <div id="wsMemberWorkspaceList"><div class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading...</div></div>
                </div>
            </div>

            <!-- Billing Tab -->
            <div class="org-settings-panel" data-panel="billing">
                <div class="org-panel-header">
                    <h2>Billing &amp; Subscription</h2>
                    <p>Manage your plan and view invoices</p>
                </div>
                <div class="org-form-card">
                    <div id="billingInfo">
                        <div class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading subscription info...</div>
                    </div>
                </div>
            </div>

            <!-- Compliance Tab -->
            <div class="org-settings-panel" data-panel="compliance">
                <div class="org-panel-header">
                    <h2>Compliance &amp; Privacy</h2>
                    <p>Your data protection and security overview</p>
                </div>
                <div class="org-form-card">
                    <div class="org-compliance-item">
                        <div class="org-compliance-icon success"><i class="bi bi-shield-check"></i></div>
                        <div>
                            <strong>GDPR Compliance</strong>
                            <p>All data is stored and processed in accordance with GDPR.</p>
                        </div>
                    </div>
                    <div class="org-form-divider"></div>
                    <div class="org-compliance-item">
                        <div class="org-compliance-icon primary"><i class="bi bi-lock-fill"></i></div>
                        <div>
                            <strong>Data Encryption</strong>
                            <p>Data at rest and in transit is encrypted with AES-256 and TLS 1.3.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Activity Tab -->
            <div class="org-settings-panel" data-panel="activity">
                <div class="org-panel-header">
                    <h2>Activity Log</h2>
                    <p>Recent actions performed in your organization</p>
                </div>
                <div class="org-form-card">
                    <div id="activityLog"><div class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading activity...</div></div>
                    <div id="activityPagination" class="mt-3 d-flex justify-content-between align-items-center d-none">
                        <span class="small text-muted" id="activityPagingInfo"></span>
                        <div>
                            <button class="btn btn-sm btn-outline-secondary me-1" id="activityPrevBtn" disabled>
                                <i class="bi bi-chevron-left"></i> Prev
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" id="activityNextBtn" disabled>
                                Next <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create User Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createUserModalLabel"><i class="bi bi-person-plus me-2"></i>Create User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="createUserAlert" class="alert d-none"></div>
                <div class="mb-3">
                    <label class="form-label-cp">Full Name</label>
                    <input type="text" class="form-control cp-input" id="createFullName" placeholder="Jane Doe" autocomplete="off" />
                </div>
                <div class="mb-3">
                    <label class="form-label-cp">Email Address <span class="text-danger">*</span></label>
                    <input type="email" class="form-control cp-input" id="createEmail" placeholder="user@example.com" required autocomplete="off" />
                </div>
                <div class="mb-3">
                    <label class="form-label-cp">Password</label>
                    <div class="password-toggle-wrap">
                        <input type="password" class="form-control cp-input" id="createPassword" placeholder="Min 6 characters" autocomplete="new-password" />
                        <button type="button" class="password-toggle-btn" id="toggleCreatePassword" tabindex="-1">
                            <i class="bi bi-eye" id="toggleCreatePasswordIcon"></i>
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label-cp">Role</label>
                    <select class="form-select cp-input" id="createRole">
                        <option value="User">User</option>
                        <option value="OrgAdmin">OrgAdmin</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn cp-btn-gradient" id="submitCreateUserBtn">
                    <i class="bi bi-person-check me-1"></i>Create User
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-labelledby="resetPasswordModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="resetPasswordModalLabel"><i class="bi bi-key me-2"></i>Reset Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="resetPasswordAlert" class="alert d-none"></div>
                <input type="hidden" id="resetUserId" />
                <p class="text-muted small">Leave the password field empty to auto-generate a secure password.</p>
                <div class="mb-3">
                    <label class="form-label-cp">New Password (optional)</label>
                    <div class="password-toggle-wrap">
                        <input type="password" class="form-control cp-input" id="resetNewPassword" placeholder="Leave blank to auto-generate" autocomplete="new-password" />
                        <button type="button" class="password-toggle-btn" id="toggleResetPassword" tabindex="-1">
                            <i class="bi bi-eye" id="toggleResetPasswordIcon"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn cp-btn-gradient" id="submitResetPasswordBtn">
                    <i class="bi bi-arrow-clockwise me-1"></i>Reset Password
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Workspace Members Modal -->
<div class="modal fade" id="wsMembersModal" tabindex="-1" aria-labelledby="wsMemberModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="wsMemberModalLabel"><i class="bi bi-people me-2"></i>Workspace Members</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="addMemberAlert" class="alert d-none mb-3"></div>
                <div class="d-flex gap-2 mb-3">
                    <input type="email" class="form-control cp-input" id="addMemberEmail" placeholder="user@example.com" autocomplete="off" />
                    <select class="form-select cp-input" id="addMemberRole" style="width:auto;min-width:110px">
                        <option value="Viewer">Viewer</option>
                        <option value="Editor">Editor</option>
                        <option value="Admin">Admin</option>
                    </select>
                    <button class="btn cp-btn-gradient text-nowrap" onclick="orgAdminWM.addMember()">
                        <i class="bi bi-person-plus me-1"></i>Add
                    </button>
                </div>
                <div class="table-responsive">
                    <table class="table cp-table">
                        <thead><tr><th>Name</th><th>Email</th><th>Role</th><th></th></tr></thead>
                        <tbody id="wsMembersTableBody"><tr><td colspan="4" class="text-center text-muted py-3">Loading...</td></tr></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Payment Placeholder Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-credit-card me-2"></i>Payment Processing</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <i class="bi bi-stripe fs-1 text-primary mb-3 d-block"></i>
                <h5>Payment Integration Coming Soon</h5>
                <p class="text-muted">Stripe and PayPal payment processing will be integrated here. Your plan upgrade request has been noted.</p>
                <p class="text-muted small">Contact us at <strong>billing@AIInsights.com</strong> for manual upgrades.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn cp-btn-gradient" data-bs-dismiss="modal">Got it</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    const user = JSON.parse(localStorage.getItem('cp_user') || 'null');
    const orgId = user?.organizationId;
    const userId = user?.id;

    // ---- Billing Tab ----
    function renderBilling(plan) {
        const isFreeTrial = plan?.plan === 'FreeTrial' || plan?.isTrialActive;
        const isPro = plan?.plan === 'Professional';
        const isEnterprise = plan?.plan === 'Enterprise';
        const trialDays = plan?.daysRemaining || 0;

        function planCard(title, price, features, isCurrent, planKey, badgeClass) {
            return `<div class="col-md-4">
                <div class="card h-100 ${isCurrent ? 'border-primary shadow' : 'border-0 glass-card'}">
                    <div class="card-body text-center p-4">
                        ${isCurrent ? '<span class="badge bg-primary mb-2">Current Plan</span><br>' : ''}
                        <h5 class="card-title">${title}</h5>
                        <div class="display-6 fw-bold my-3">${price}</div>
                        <ul class="list-unstyled text-start mb-4">${features.map(f => '<li class="mb-1"><i class="bi bi-check-circle-fill text-success me-2"></i>' + f + '</li>').join('')}</ul>
                        ${isCurrent
                            ? '<button class="btn btn-outline-primary w-100" disabled>Active</button>'
                            : `<button class="btn cp-btn-gradient w-100" onclick="upgradeplan('${planKey}')">${planKey === 'FreeTrial' ? 'Start Free Trial' : 'Upgrade'}</button>`}
                    </div>
                </div>
            </div>`;
        }

        const trialBadge = isFreeTrial ? `<div class="alert alert-info mb-3"><i class="bi bi-clock me-2"></i><strong>${trialDays} days remaining</strong> on your Free Trial.</div>` : '';

        document.getElementById('billingInfo').innerHTML = `
            ${trialBadge}
            <div class="row g-3 mb-4">
                ${planCard('Free Trial', '30 days', ['Up to 3 Workspaces', '1 AI Agent', '100 queries/mo', 'Basic charts'], isFreeTrial, 'FreeTrial', 'bg-info')}
                ${planCard('Professional', '$25<span class="fs-6 fw-normal">/mo</span>', ['Unlimited Workspaces', '10 AI Agents', '10,000 queries/mo', 'All chart types', 'Priority support'], isPro, 'Professional', 'bg-primary')}
                ${planCard('Enterprise', '$45<span class="fs-6 fw-normal">/mo</span>', ['Unlimited everything', 'Custom AI Agents', 'Unlimited queries', 'Custom branding', 'Dedicated support', 'SLA guarantee'], isEnterprise, 'Enterprise', 'bg-dark')}
            </div>
            <div class="glass-card p-4 mb-3">
                <h5>Token Add-ons</h5>
                <p class="text-muted small mb-2">Enterprise token packs add <strong>2,000,000</strong> tokens each at <strong>$15</strong> per pack.</p>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span>Current extra packs: <strong id="enterprisePackCount">${plan?.enterpriseExtraTokenPacks || 0}</strong></span>
                    <span>Total extra tokens: <strong id="enterprisePackTokens">${((plan?.enterpriseExtraTokenPacks || 0) * 2000000).toLocaleString()}</strong></span>
                </div>
                <button class="btn btn-sm cp-btn-gradient ${!isEnterprise ? 'disabled' : ''}" id="buyTokenPackBtn" ${!isEnterprise ? 'disabled' : ''}>Buy More</button>
            </div>
            <div class="glass-card p-4">
                <h5>Billing History</h5>
                <p class="text-muted small">No invoices yet. Invoices will appear here once you have an active paid plan.</p>
            </div>`;
        document.getElementById('buyTokenPackBtn')?.addEventListener('click', function() {
            fetch('/api/billing/token-packs', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ organizationId: orgId, packs: 1 })
            }).then(r => r.json()).then(function(d) {
                if (d.error) { alert(d.error); return; }
                document.getElementById('enterprisePackCount').textContent = d.packs;
                document.getElementById('enterprisePackTokens').textContent = (d.totalExtraTokens || 0).toLocaleString();
                loadTokenUsage();
            });
        });
    }

    window.upgradeplan = function(planKey) {
        if (!userId) return;
        if (planKey === 'FreeTrial') {
            fetch('/api/subscription/activate-trial', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ userId })
            }).then(r => r.json()).then(d => {
                if (d.error) alert(d.error);
                else { loadBilling(); }
            });
        } else {
            new bootstrap.Modal(document.getElementById('paymentModal')).show();
        }
    };

    function loadBilling() {
        if (!userId) {
            document.getElementById('billingInfo').innerHTML = '<p class="text-muted">Please sign in to view billing info.</p>';
            return;
        }
        fetch('/api/subscription/' + userId)
            .then(r => r.json())
            .then(plan => renderBilling(plan))
            .catch(() => { document.getElementById('billingInfo').innerHTML = '<p class="text-danger">Failed to load billing info.</p>'; });
    }

    // ---- Activity Tab ----
    let activityPage = 1;
    let activityTotal = 0;
    const pageSize = 20;

    function renderActivity(data) {
        const { items, total } = data;
        activityTotal = total;
        if (!items || items.length === 0) {
            document.getElementById('activityLog').innerHTML = '<p class="text-muted">No activity recorded yet.</p>';
            document.getElementById('activityPagination').classList.add('d-none');
            return;
        }
        const rows = items.map(a => {
            const dt = new Date(a.createdAt).toLocaleString();
            const icon = {
                login: 'bi-box-arrow-in-right text-success',
                logout: 'bi-box-arrow-right text-muted',
                agent_execution: 'bi-robot text-primary',
                datasource_query: 'bi-database text-info',
                workspace_created: 'bi-folder-plus text-warning',
                datasource_created: 'bi-plug text-success',
                agent_created: 'bi-robot text-primary',
                user_invited: 'bi-person-plus text-info'
            }[a.action] || 'bi-circle text-muted';
            return `<tr>
                <td><i class="bi ${icon} me-2"></i>${a.action}</td>
                <td>${a.description}</td>
                <td class="text-muted small">${dt}</td>
            </tr>`;
        }).join('');
        document.getElementById('activityLog').innerHTML = `
            <div class="table-responsive">
                <table class="table cp-table">
                    <thead><tr><th>Action</th><th>Description</th><th>Time</th></tr></thead>
                    <tbody>${rows}</tbody>
                </table>
            </div>`;
        const pagination = document.getElementById('activityPagination');
        pagination.classList.remove('d-none');
        document.getElementById('activityPagingInfo').textContent = `Page ${activityPage} of ${Math.ceil(total / pageSize)} (${total} total)`;
        document.getElementById('activityPrevBtn').disabled = activityPage <= 1;
        document.getElementById('activityNextBtn').disabled = activityPage >= Math.ceil(total / pageSize);
    }

    function loadActivity() {
        let url = `/api/activity?page=${activityPage}&pageSize=${pageSize}`;
        if (orgId) url += `&organizationId=${orgId}`;
        else if (userId) url += `&userId=${userId}`;
        fetch(url).then(r => r.json()).then(renderActivity).catch(() => {
            document.getElementById('activityLog').innerHTML = '<p class="text-danger">Failed to load activity.</p>';
        });
    }

    document.getElementById('activityPrevBtn')?.addEventListener('click', () => { activityPage--; loadActivity(); });
    document.getElementById('activityNextBtn')?.addEventListener('click', () => { activityPage++; loadActivity(); });

    // ---- Users Tab ----
    function loadUsers() {
        if (!orgId) return;
        fetch(`/api/org/users?organizationId=${orgId}`)
            .then(r => r.json())
            .then(users => {
                if (!users.length) { document.getElementById('usersTableBody').innerHTML = '<tr><td colspan="7" class="text-center text-muted py-3">No users yet</td></tr>'; return; }
                document.getElementById('usersTableBody').innerHTML = users.map(u => {
                    const plan = (u.assignedPlan || 'Free');
                    const planBudget = plan === 'Enterprise' ? '10,000,000 +' : plan === 'Professional' ? '2,000,000' : plan === 'FreeTrial' ? '10,000' : '0';
                    const statusBadge = u.status === 'Pending' ? '<span class="badge bg-warning text-dark">Pending</span>'
                        : u.status === 'Suspended' ? '<span class="badge bg-danger">Suspended</span>'
                        : '<span class="badge bg-success">Active</span>';
                    return `<tr>
                        <td>${u.fullName || '-'}</td>
                        <td>${u.email}</td>
                        <td><span class="badge bg-secondary">${u.role}</span></td>
                        <td>${statusBadge}</td>
                        <td>
                            <div class="d-flex gap-1">
                                <select class="form-select form-select-sm" id="license_${u.id}" autocomplete="off">
                                    <option value="Free" ${plan === 'Free' ? 'selected' : ''}>Free</option>
                                    <option value="Professional" ${plan === 'Professional' ? 'selected' : ''}>Pro</option>
                                    <option value="Enterprise" ${plan === 'Enterprise' ? 'selected' : ''}>Enterprise</option>
                                </select>
                                <button class="btn btn-sm btn-outline-primary" onclick="assignLicense('${u.id}')">Save</button>
                            </div>
                        </td>
                        <td><span class="small text-muted">${planBudget}</span></td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-secondary" onclick="changeRole('${u.id}','${u.role}')"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-outline-info" title="Reset Password" onclick="openResetPassword('${u.id}')"><i class="bi bi-key"></i></button>
                                <button class="btn btn-outline-warning" onclick="suspendUser('${u.id}')"><i class="bi bi-pause-circle"></i></button>
                                <button class="btn btn-outline-danger" onclick="removeUser('${u.id}')"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>`;
                }).join('');
            }).catch(() => {});
    }

    window.changeRole = function(uid, current) {
        const role = prompt('Enter new role (User, Contributor, OrgAdmin):', current);
        if (!role) return;
        fetch(`/api/org/users/${uid}/role`, { method: 'PUT', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ role }) })
            .then(() => loadUsers());
    };
    window.suspendUser = function(uid) {
        if (!confirm('Suspend this user?')) return;
        fetch(`/api/org/users/${uid}/suspend`, { method: 'PUT' }).then(() => loadUsers());
    };
    window.removeUser = function(uid) {
        if (!confirm('Remove this user from the organization?')) return;
        fetch(`/api/org/users/${uid}`, { method: 'DELETE' }).then(() => loadUsers());
    };
    window.assignLicense = function(uid) {
        const plan = document.getElementById('license_' + uid)?.value || 'Free';
        fetch('/api/billing/assign-license', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ organizationId: orgId, userId: uid, plan })
        }).then(r => r.json()).then(d => {
            if (d.error) { alert(d.error); return; }
            alert('License assigned successfully.');
            loadUsers();
        });
    };
    window.openResetPassword = function(uid) {
        document.getElementById('resetUserId').value = uid;
        document.getElementById('resetNewPassword').value = '';
        document.getElementById('resetPasswordAlert').classList.add('d-none');
        new bootstrap.Modal(document.getElementById('resetPasswordModal')).show();
    };

    // Create User
    document.getElementById('createUserBtn')?.addEventListener('click', function() {
        document.getElementById('createUserAlert').classList.add('d-none');
        new bootstrap.Modal(document.getElementById('createUserModal')).show();
    });
    document.getElementById('submitCreateUserBtn')?.addEventListener('click', function() {
        const fullName  = document.getElementById('createFullName').value.trim();
        const email     = document.getElementById('createEmail').value.trim();
        const password  = document.getElementById('createPassword').value;
        const role      = document.getElementById('createRole').value;
        const alertEl   = document.getElementById('createUserAlert');
        if (!email) { alertEl.className = 'alert alert-danger'; alertEl.textContent = 'Email is required.'; alertEl.classList.remove('d-none'); return; }
        if (!password) { alertEl.className = 'alert alert-danger'; alertEl.textContent = 'Password is required.'; alertEl.classList.remove('d-none'); return; }
        fetch('/api/org/users/create', {
            method: 'POST', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ fullName, email, username: email, password, role, organizationId: orgId, createdBy: userId })
        }).then(r => r.json()).then(d => {
            if (d.error) {
                alertEl.className = 'alert alert-danger'; alertEl.textContent = d.error; alertEl.classList.remove('d-none');
            } else {
                const msg = d.credentialsSent ? 'User created and credentials sent by email.' : 'User created. (Email not sent — SMTP not configured.)';
                bootstrap.Modal.getInstance(document.getElementById('createUserModal')).hide();
                loadUsers();
                setTimeout(() => alert(msg), 300);
            }
        }).catch(() => { alertEl.className = 'alert alert-danger'; alertEl.textContent = 'Request failed.'; alertEl.classList.remove('d-none'); });
    });

    // Password toggle for create user modal
    document.getElementById('toggleCreatePassword')?.addEventListener('click', function() {
        const input = document.getElementById('createPassword');
        const icon  = document.getElementById('toggleCreatePasswordIcon');
        if (input.type === 'password') { input.type = 'text'; icon.className = 'bi bi-eye-slash'; }
        else { input.type = 'password'; icon.className = 'bi bi-eye'; }
    });
    document.getElementById('toggleResetPassword')?.addEventListener('click', function() {
        const input = document.getElementById('resetNewPassword');
        const icon  = document.getElementById('toggleResetPasswordIcon');
        if (input.type === 'password') { input.type = 'text'; icon.className = 'bi bi-eye-slash'; }
        else { input.type = 'password'; icon.className = 'bi bi-eye'; }
    });

    // Reset Password
    document.getElementById('submitResetPasswordBtn')?.addEventListener('click', function() {
        const uid      = document.getElementById('resetUserId').value;
        const newPwd   = document.getElementById('resetNewPassword').value || null;
        const alertEl  = document.getElementById('resetPasswordAlert');
        fetch(`/api/org/users/${uid}/reset-password`, {
            method: 'POST', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ newPassword: newPwd, resetBy: userId })
        }).then(r => r.json()).then(d => {
            if (d.error) {
                alertEl.className = 'alert alert-danger'; alertEl.textContent = d.error; alertEl.classList.remove('d-none');
            } else {
                bootstrap.Modal.getInstance(document.getElementById('resetPasswordModal')).hide();
                const msg = d.emailSent ? 'Password reset and new password sent by email.' : 'Password reset. (Email not sent — SMTP not configured.)';
                setTimeout(() => alert(msg), 300);
            }
        }).catch(() => { alertEl.className = 'alert alert-danger'; alertEl.textContent = 'Request failed.'; alertEl.classList.remove('d-none'); });
    });

    // Token Usage
    function loadTokenUsage() {
        if (!orgId) return;
        fetch(`/api/org/token-usage?organizationId=${orgId}`)
            .then(r => r.json())
            .then(data => {
                const used      = data.used || 0;
                const budget    = data.budget || 2000000;
                const pct       = Math.min(100, Math.round((used / budget) * 100));
                const bar       = document.getElementById('tokenUsageBar');
                const text      = document.getElementById('tokenUsageText');
                const label     = document.getElementById('tokenUsageLabel');
                if (bar)   { bar.style.width = pct + '%'; bar.className = 'token-budget-bar-fill' + (pct >= 100 ? ' exceeded' : pct >= 80 ? ' warning' : ''); }
                if (text)  text.textContent = pct + '% used';
                if (label) label.textContent = `${used.toLocaleString()} / ${budget.toLocaleString()} tokens`;
            }).catch(() => {});
    }

    // ---- Left sidebar tab switching ----
    function switchSettingsTab(tab) {
        document.querySelectorAll('.org-settings-nav-item').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
        document.querySelectorAll('.org-settings-panel').forEach(p => p.classList.toggle('active', p.dataset.panel === tab));
        if (tab === 'billing') loadBilling();
        else if (tab === 'activity') loadActivity();
        else if (tab === 'users') { loadUsers(); loadTokenUsage(); }
        else if (tab === 'ws-members' && window.orgAdminWM) orgAdminWM.init(orgId);
    }
    document.querySelectorAll('.org-settings-nav-item').forEach(btn => {
        btn.addEventListener('click', () => switchSettingsTab(btn.dataset.tab));
    });

    // Auto-open tab from URL query param
    const params = new URLSearchParams(window.location.search);
    const tabParam = params.get('tab');
    if (tabParam) switchSettingsTab(tabParam);

    // Populate org name from stored user data
    const orgNameInput = document.getElementById('orgNameInput');
    if (orgNameInput && user) {
        orgNameInput.value = user.orgName || '';
    }

    // Initial loads
    loadUsers();
    loadTokenUsage();
    loadBilling();
})();
</script>
<script src="~/js/orgAdminWorkspaceMembers.js"></script>
}
