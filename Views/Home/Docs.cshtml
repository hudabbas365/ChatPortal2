@model List<AIInsights.Models.DocArticle>
@{
    ViewData["Title"] = "Documentation";
}

<section class="cp-section cp-page-hero">
    <div class="container">
        <h1 class="page-title">Documentation</h1>
        <p class="page-subtitle">Learn how to connect datasources, create agents, and build dashboards.</p>
    </div>
</section>

<section class="cp-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3">
                <div class="docs-nav glass-card">
                    <h6 class="docs-nav-title">Documentation</h6>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var article in Model)
                        {
                            <a href="@Url.Action("DocArticle", "Home", new { slug = article.Slug })" class="docs-nav-link">@article.Title</a>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">No documentation articles yet.</p>
                    }
                </div>
            </div>
            <div class="col-md-9">
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var article in Model)
                    {
                        <div class="docs-content glass-card mb-4">
                            <h2>@article.Title</h2>
                            @if (!string.IsNullOrWhiteSpace(article.Summary))
                            {
                                <p>@article.Summary</p>
                            }
                            <a href="@Url.Action("DocArticle", "Home", new { slug = article.Slug })" class="blog-read-more">Read More <i class="bi bi-arrow-right"></i></a>
                        </div>
                    }
                }
                else
                {
                    <div class="docs-content glass-card text-center py-5">
                        <p class="text-muted mb-0">No documentation articles yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
