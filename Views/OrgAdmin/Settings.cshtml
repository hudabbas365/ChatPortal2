    // ---- Embedded Reports Tab ----
    function escapeHtml(s) {
        return String(s ?? '').replace(/[&<>"']/g, function(c) {
            return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c];
        });
    }

    async function loadEmbeddedReports() {
        const host = document.getElementById('embeddedReportsList');
        if (!host || !orgId) return;
        host.innerHTML = '<div class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading...</div>';
        try {
            const res = await fetch(`/api/org/${orgId}/embedded-reports`, { credentials: 'same-origin' });
            if (!res.ok) {
                host.innerHTML = '<div class="alert alert-danger small mb-0">Failed to load embedded reports.</div>';
                return;
            }
            const items = await res.json();
            if (!Array.isArray(items) || items.length === 0) {
                host.innerHTML = '<div class="text-muted small py-3 text-center"><i class="bi bi-info-circle me-1"></i>No reports are currently published or embedded.</div>';
                return;
            }
            const origin = window.location.origin;
            const rows = items.map(function(r) {
                const fullPublic = origin + r.publicUrl;
                const fullEmbed = origin + r.embedUrl;
                const dt = r.publishedAt ? new Date(r.publishedAt).toLocaleString() : '';
                return (
                    '<tr>' +
                        '<td><div style="font-weight:500;">' + escapeHtml(r.name) + '</div>' +
                            '<div class="small text-muted"><i class="bi bi-folder me-1"></i>' + escapeHtml(r.workspaceName) + '</div></td>' +
                        '<td class="small"><a href="' + fullPublic + '" target="_blank" rel="noopener" style="word-break:break-all;">' + escapeHtml(fullPublic) + '</a></td>' +
                        '<td class="small text-muted">' + escapeHtml(dt) + '</td>' +
                        '<td class="text-end" style="white-space:nowrap;">' +
                            '<button class="btn btn-sm btn-outline-secondary me-1" data-copy-embed="' + encodeURIComponent(fullEmbed) + '" title="Copy embed code">' +
                                '<i class="bi bi-clipboard"></i></button>' +
                            '<button class="btn btn-sm btn-outline-danger" data-revoke="' + encodeURIComponent(r.guid) + '" data-name="' + encodeURIComponent(r.name) + '" title="Revoke public/embed URL">' +
                                '<i class="bi bi-slash-circle me-1"></i>Revoke</button>' +
                        '</td>' +
                    '</tr>'
                );
            }).join('');
            host.innerHTML =
                '<div class="table-responsive"><table class="table table-sm align-middle mb-0">' +
                    '<thead><tr><th>Report</th><th>Public URL</th><th>Published</th><th class="text-end">Actions</th></tr></thead>' +
                    '<tbody>' + rows + '</tbody>' +
                '</table></div>';

            host.querySelectorAll('[data-copy-embed]').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    const embedUrl = decodeURIComponent(btn.getAttribute('data-copy-embed'));
                    const snippet = '<iframe src="' + embedUrl + '" width="100%" height="900" frameborder="0" style="border:0;border-radius:12px;"></iframe>';
                    navigator.clipboard?.writeText(snippet);
                    if (window.cpToast) cpToast('Embed snippet copied to clipboard.', 'success');
                });
            });
            host.querySelectorAll('[data-revoke]').forEach(function(btn) {
                btn.addEventListener('click', async function() {
                    const guid = decodeURIComponent(btn.getAttribute('data-revoke'));
                    const name = decodeURIComponent(btn.getAttribute('data-name'));
                    const ok = (typeof cpConfirm === 'function')
                        ? await cpConfirm({ title: 'Revoke embed URL?', message: 'This will unpublish "' + name + '" and break any external iframes embedding it.', confirmText: 'Revoke', danger: true })
                        : confirm('Revoke embed URL for "' + name + '"? External iframes will stop working.');
                    if (!ok) return;
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Revoking...';
                    try {
                        const r = await fetch('/api/org/reports/' + encodeURIComponent(guid) + '/revoke-embed', {
                            method: 'POST', credentials: 'same-origin'
                        });
                        if (!r.ok) {
                            const err = await r.json().catch(function(){ return {}; });
                            if (window.cpToast) cpToast(err.error || 'Failed to revoke embed.', 'error');
                            else alert(err.error || 'Failed to revoke embed.');
                            btn.disabled = false;
                            btn.innerHTML = '<i class="bi bi-slash-circle me-1"></i>Revoke';
                            return;
                        }
                        if (window.cpToast) cpToast('Embed URL revoked.', 'success');
                        loadEmbeddedReports();
                    } catch (e) {
                        if (window.cpToast) cpToast('Network error while revoking.', 'error');
                        btn.disabled = false;
                        btn.innerHTML = '<i class="bi bi-slash-circle me-1"></i>Revoke';
                    }
                });
            });
        } catch (e) {
            host.innerHTML = '<div class="alert alert-danger small mb-0">Failed to load embedded reports.</div>';
        }
    }

    document.getElementById('reloadEmbedsBtn')?.addEventListener('click', loadEmbeddedReports);

    // Initial loads
    loadUsers();
    loadTokenUsage();
    loadLicenseInfo();
    loadBilling();
    loadVerifyStatus();
    loadEmbeddedReports();

    // Prefill Contact Support form with current user info
    try {
        const nameEl = document.getElementById('supportName');
        const emailEl = document.getElementById('supportEmail');
        if (nameEl && !nameEl.value) nameEl.value = user?.fullName || user?.userName || '';
        if (emailEl && !emailEl.value) emailEl.value = user?.email || '';
    } catch (e) { /* non-fatal */ }
})();
</script>
<script src="~/js/orgAdminWorkspaceMembers.js"></script>
<script src="~/js/cp-support-form.js"></script>
}
