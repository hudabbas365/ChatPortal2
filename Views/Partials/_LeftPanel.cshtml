<aside class="cp-left-panel" id="leftPanel">
    <div class="left-panel-header">
        <a href="/" class="panel-brand">
            <i class="bi bi-bar-chart-fill"></i>
            <span>ChatPortal2</span>
        </a>
        <button class="btn btn-icon panel-close-btn" id="panelCloseBtn">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <div class="panel-section">
        <div class="panel-section-label">Organization</div>
        <div class="panel-org-info" id="orgInfo">
            <i class="bi bi-building me-2"></i><span id="orgName">My Organization</span>
        </div>
    </div>

    <div class="panel-section">
        <div class="panel-section-label d-flex justify-content-between align-items-center">
            Workspaces
            <button class="btn btn-icon btn-xs" id="addWorkspaceBtn" title="Add Workspace">
                <i class="bi bi-plus"></i>
            </button>
        </div>
        <div class="panel-list" id="workspaceList">
            <div class="panel-list-item active" data-workspace-id="0">
                <i class="bi bi-folder me-2"></i>Default Workspace
            </div>
        </div>
    </div>

    <div class="panel-section">
        <div class="panel-section-label d-flex justify-content-between align-items-center">
            AI Agents
            <button class="btn btn-icon btn-xs" id="addAgentBtn" title="Add Agent">
                <i class="bi bi-plus"></i>
            </button>
        </div>
        <div class="panel-list" id="agentList">
            <div class="panel-list-item active" data-agent-id="0">
                <i class="bi bi-robot me-2"></i>Default Agent
            </div>
        </div>
    </div>

    <div class="panel-section">
        <div class="panel-section-label">Datasources</div>
        <div class="panel-list" id="datasourceList">
            <div class="panel-list-item" data-ds-id="0">
                <i class="bi bi-database me-2"></i>Sample Data
            </div>
        </div>
    </div>

    <div class="panel-footer">
        <a href="/org/settings?tab=activity" class="panel-footer-link">
            <i class="bi bi-activity me-2"></i>Activity
        </a>
        <a href="/org/settings" class="panel-footer-link">
            <i class="bi bi-gear me-2"></i>Settings
        </a>
        <a href="/admin" class="panel-footer-link">
            <i class="bi bi-shield-lock me-2"></i>Admin
        </a>
    </div>
</aside>

<!-- Add Workspace Modal -->
<div class="modal fade" id="addWorkspaceModal" tabindex="-1" aria-labelledby="addWorkspaceModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addWorkspaceModalLabel"><i class="bi bi-folder-plus me-2"></i>Create Workspace</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="wsModalAlert" class="alert d-none"></div>
                <div class="mb-3">
                    <label class="form-label">Workspace Name</label>
                    <input type="text" class="form-control cp-input" id="wsName" placeholder="e.g. Sales Analytics" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn cp-btn-gradient" id="createWorkspaceBtn">
                    <i class="bi bi-folder-plus me-1"></i>Create
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Add Agent Modal -->
<div class="modal fade" id="addAgentModal" tabindex="-1" aria-labelledby="addAgentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addAgentModalLabel"><i class="bi bi-robot me-2"></i>Create AI Agent</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="agentModalAlert" class="alert d-none"></div>
                <div class="mb-3">
                    <label class="form-label">Agent Name</label>
                    <input type="text" class="form-control cp-input" id="agentName" placeholder="e.g. Sales Agent" />
                </div>
                <div class="mb-3">
                    <label class="form-label">System Prompt</label>
                    <textarea class="form-control cp-input" id="agentSystemPrompt" rows="4" placeholder="You are a helpful data assistant..."></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Datasource</label>
                    <div class="d-flex gap-2">
                        <select class="form-select cp-input" id="agentDatasource">
                            <option value="">-- Select or create datasource --</option>
                        </select>
                        <button type="button" class="btn btn-outline-primary btn-sm" id="openDatasourceModalBtn" title="Connect new datasource">
                            <i class="bi bi-plug me-1"></i>Connect
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn cp-btn-gradient" id="createAgentBtn">
                    <i class="bi bi-robot me-1"></i>Create Agent
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Connect Datasource Modal -->
<div class="modal fade" id="addDatasourceModal" tabindex="-1" aria-labelledby="addDatasourceModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addDatasourceModalLabel"><i class="bi bi-plug me-2"></i>Connect Datasource</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="dsModalAlert" class="alert d-none"></div>
                <div id="dsTypeSelector">
                    <div class="mb-3">
                        <input type="text" class="form-control cp-input" id="dsTypeSearch" placeholder="Search datasource types..." />
                    </div>
                    <div id="dsTypeGrid" class="ds-type-grid"></div>
                </div>
                <div id="dsConfigForm" style="display:none">
                    <div class="mb-3">
                        <button class="btn btn-sm btn-outline-secondary" id="dsBackBtn"><i class="bi bi-arrow-left me-1"></i>Back</button>
                        <span class="ms-2 fw-bold" id="dsSelectedTypeName"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Datasource Name</label>
                        <input type="text" class="form-control cp-input" id="dsName" placeholder="e.g. Sales DB" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Connection String / URL</label>
                        <input type="text" class="form-control cp-input" id="dsConnectionString" placeholder="Server=...;Database=..." />
                    </div>
                    <div id="dsFieldsPreview" style="display:none">
                        <label class="form-label">Available Fields</label>
                        <div id="dsFieldsList" class="d-flex flex-wrap gap-2 mt-1"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-outline-primary" id="dsTestBtn" style="display:none">
                    <i class="bi bi-wifi me-1"></i>Test &amp; Load Fields
                </button>
                <button type="button" class="btn cp-btn-gradient" id="saveDatasourceBtn" style="display:none">
                    <i class="bi bi-plug me-1"></i>Connect &amp; Save
                </button>
            </div>
        </div>
    </div>
</div>
