<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – SuperAdmin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root { --sa-bg: #0f172a; --sa-sidebar: #1e293b; --sa-primary: #60a5fa; --sa-text: #e2e8f0; --sa-muted: #94a3b8; }
        body { background: var(--sa-bg); color: var(--sa-text); margin: 0; font-family: 'Inter', sans-serif; }
        .sa-layout { display: flex; min-height: 100vh; }
        .sa-sidebar { width: 240px; min-width: 240px; background: var(--sa-sidebar); padding: 1.5rem 0; display: flex; flex-direction: column; border-right: 1px solid rgba(255,255,255,0.08); }
        .sa-brand { font-size: 1rem; font-weight: 700; color: var(--sa-primary); padding: 0 1.5rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 1rem; }
        .sa-nav { display: flex; flex-direction: column; gap: 0.2rem; padding: 0 0.75rem; }
        .sa-nav-item { display: flex; align-items: center; gap: 0.6rem; padding: 0.55rem 0.85rem; border-radius: 8px; color: var(--sa-muted); text-decoration: none; font-size: 0.875rem; transition: background 0.2s, color 0.2s; }
        .sa-nav-item:hover, .sa-nav-item.active { background: rgba(96,165,250,0.15); color: var(--sa-primary); }
        .sa-main { flex: 1; padding: 2rem; overflow: auto; }
        .sa-stat { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 1.25rem; }
        .sa-stat-val { font-size: 2rem; font-weight: 700; color: var(--sa-primary); }
        .sa-stat-label { color: var(--sa-muted); font-size: 0.85rem; }
        .sa-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; }
        .sa-table { width: 100%; border-collapse: collapse; }
        .sa-table th { color: var(--sa-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.5rem 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sa-table td { padding: 0.6rem 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 0.875rem; }
        .sa-badge { display: inline-block; padding: 0.2em 0.6em; border-radius: 6px; font-size: 0.75rem; font-weight: 600; }
        .sa-badge-blue { background: rgba(96,165,250,0.2); color: #60a5fa; }
        .sa-badge-green { background: rgba(52,211,153,0.2); color: #34d399; }
        .sa-badge-red { background: rgba(248,113,113,0.2); color: #f87171; }
        .btn-sa { background: linear-gradient(135deg, #3b82f6, #8b5cf6); border: none; color: #fff; font-weight: 600; font-size: 0.875rem; padding: 0.4rem 1rem; border-radius: 8px; }
        .btn-sa:hover { opacity: 0.9; color: #fff; }
    </style>
</head>
<body>
    <div class="sa-layout">
        <aside class="sa-sidebar">
            <div class="sa-brand"><i class="bi bi-shield-lock-fill me-2"></i>SuperAdmin</div>
            <nav class="sa-nav">
                <a href="/superadmin" class="sa-nav-item @(ViewData["ActivePage"]?.ToString() == "dashboard" ? "active" : "")"><i class="bi bi-speedometer2"></i> Dashboard</a>
                <a href="/superadmin/organizations" class="sa-nav-item @(ViewData["ActivePage"]?.ToString() == "orgs" ? "active" : "")"><i class="bi bi-building"></i> Organizations</a>
                <a href="/superadmin/activity" class="sa-nav-item @(ViewData["ActivePage"]?.ToString() == "activity" ? "active" : "")"><i class="bi bi-activity"></i> Activity Logs</a>
                <a href="/superadmin/aiconfig" class="sa-nav-item @(ViewData["ActivePage"]?.ToString() == "aiconfig" ? "active" : "")"><i class="bi bi-cpu"></i> AI Config</a>
                <a href="/superadmin/revenue" class="sa-nav-item @(ViewData["ActivePage"]?.ToString() == "revenue" ? "active" : "")"><i class="bi bi-cash-stack"></i> Revenue</a>
                <a href="/superadmin/seo" class="sa-nav-item @(ViewData["ActivePage"]?.ToString() == "seo" ? "active" : "")"><i class="bi bi-search"></i> SEO</a>
            </nav>
            <div class="mt-auto px-3 pb-2">
                <button class="btn btn-sm btn-outline-secondary w-100" onclick="logout()"><i class="bi bi-box-arrow-right me-1"></i>Logout</button>
            </div>
        </aside>
        <main class="sa-main">
            @RenderBody()
        </main>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    @RenderSection("Scripts", required: false)
    <script>
    function logout() {
        fetch('/api/superadmin/logout', { method: 'POST' })
            .then(() => window.location.href = '/superadmin/login');
    }
    </script>
</body>
</html>
