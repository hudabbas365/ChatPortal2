        })();
            </text>
        }

        document.getElementById('toggle-library-panel')?.addEventListener('click', function() {
            const panel = document.querySelector('.library-panel');
            panel.classList.toggle('collapsed');
            const icon = this.querySelector('i');
            icon.className = panel.classList.contains('collapsed') ? 'bi bi-chevron-right' : 'bi bi-chevron-left';
        });
        document.getElementById('toggle-data-fields-panel')?.addEventListener('click', function() {
            const panel = document.getElementById('data-fields-aside');
            if (!panel) return;
            panel.classList.toggle('collapsed');
            const icon = this.querySelector('i');
            icon.className = panel.classList.contains('collapsed') ? 'bi bi-chevron-left' : 'bi bi-chevron-right';
        });
        document.getElementById('toggle-properties-panel')?.addEventListener('click', function() {
