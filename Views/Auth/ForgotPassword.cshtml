@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="container">
        <div class="row justify-content-center min-vh-100 align-items-center">
            <div class="col-md-5">
                <div class="auth-card glass-card">
                    <div class="auth-header text-center mb-4">
                        <div class="auth-logo">
                            <i class="bi bi-bar-chart-fill"></i>
                        </div>
                        <h2 class="auth-title">Reset your password</h2>
                        <p class="auth-subtitle">Enter your email and we'll send you a reset link</p>
                    </div>
                    <div id="fpAlert" class="alert d-none"></div>
                    <form id="forgotForm">
                        <div class="mb-3">
                            <label class="form-label-cp">Email Address</label>
                            <div class="input-group-cp">
                                <i class="bi bi-envelope input-icon"></i>
                                <input type="email" class="form-control cp-input" id="fpEmail" placeholder="you@example.com" required autocomplete="off" />
                            </div>
                        </div>
                        <button type="submit" class="btn cp-btn-gradient w-100 btn-lg" id="fpBtn">
                            <i class="bi bi-envelope me-2"></i>Send Reset Link
                        </button>
                    </form>
                    <div class="auth-footer mt-4 text-center">
                        <p>Remember your password? <a href="/auth/login" class="auth-link">Sign in</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
$('#forgotForm').on('submit', function(e) {
    e.preventDefault();
    var btn = $('#fpBtn').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Sending...');
    $.ajax({
        url: '/api/auth/forgot-password',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ email: $('#fpEmail').val() }),
        success: function(r) {
            $('#fpAlert').removeClass('d-none alert-danger').addClass('alert alert-success').text(r.message);
            btn.prop('disabled', false).html('<i class="bi bi-envelope me-2"></i>Send Reset Link');
        },
        error: function(e) {
            $('#fpAlert').removeClass('d-none alert-success').addClass('alert alert-danger').text(e.responseJSON?.error || 'Request failed.');
            btn.prop('disabled', false).html('<i class="bi bi-envelope me-2"></i>Send Reset Link');
        }
    });
});
</script>
}
