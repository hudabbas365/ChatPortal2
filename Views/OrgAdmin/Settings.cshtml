    window.assignLicense = function(uid) {
        const selected = document.getElementById('license_' + uid)?.value || 'FreeTrial';
        const plan = selected === 'FreeTrial' ? 'FreeTrial' : selected;
        // Capture user email from the row for a nicer confirmation dialog.
        const row = document.querySelector(`tr[data-user-id="${uid}"]`);
        const userEmail = row?.querySelector('[data-user-email]')?.dataset?.userEmail
            || row?.children?.[1]?.textContent?.trim() || uid;
        fetch('/api/billing/assign-license', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ organizationId: orgId, userId: uid, plan })
        }).then(r => r.json()).then(d => {
            if (d.error) {
                if (typeof window.cpToast === 'function') {
                    cpToast({ title: 'Could not assign license', message: d.error, variant: 'error', duration: 6000 });
                } else { alert(d.error); }
                return;
            }
            const details = [
                ['User', userEmail],
                ['Plan', plan]
            ];
            if (typeof window.cpSuccessModal === 'function') {
                cpSuccessModal({
                    title: 'License assigned',
                    message: 'The selected plan has been granted to this user.',
                    details,
                    primaryText: 'Done',
                    variant: 'success'
                });
            } else if (typeof window.cpToast === 'function') {
                cpToast({ title: 'License assigned', message: `${plan} granted to ${userEmail}.`, variant: 'success' });
            } else {
                alert('License assigned successfully.');
            }
            loadUsers();
            loadLicenseInfo();

            // If the admin just upgraded themselves, refresh the cached plan and
            // redraw the trial banner so the "X days remaining" message clears.
            try {
                const me = JSON.parse(localStorage.getItem('cp_user') || 'null');
                if (me && me.id === uid && typeof window.refreshTrialBanner === 'function') {
                    window.refreshTrialBanner();
                }
            } catch {}
        });
    };
