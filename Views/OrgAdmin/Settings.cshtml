@{
    ViewData["Title"] = "Organization Settings";
    Layout = "_Layout";
}

<div class="org-settings-page">
    <div class="org-settings-shell">
        <!-- Left sidebar navigation -->
        <aside class="org-settings-nav">
            <div class="org-settings-nav-header">
                <i class="bi bi-gear"></i>
                <span>Settings</span>
            </div>
            <button class="org-settings-nav-item active" data-tab="org">
                <i class="bi bi-building"></i><span>Organization</span>
            </button>
            <button class="org-settings-nav-item" data-tab="users">
                <i class="bi bi-people"></i><span>Users &amp; Licensing</span>
            </button>
            <button class="org-settings-nav-item" data-tab="ws-members">
                <i class="bi bi-person-badge"></i><span>Workspace Members</span>
            </button>
            <button class="org-settings-nav-item" data-tab="compliance">
                <i class="bi bi-shield-check"></i><span>Compliance</span>
            </button>
            <button class="org-settings-nav-item" data-tab="embeds">
                <i class="bi bi-code-square"></i><span>Embedded Reports</span>
            </button>
            <button class="org-settings-nav-item" data-tab="activity">
                <i class="bi bi-activity"></i><span>Activity</span>
            </button>
            <button class="org-settings-nav-item" data-tab="support">
                <i class="bi bi-life-preserver"></i><span>Contact Support</span>
            </button>
            <a class="org-settings-nav-item" href="/org/notifications">
                <i class="bi bi-bell"></i><span>Manage Notifications</span>
            </a>
        </aside>

        <!-- Right content area -->
        <div class="org-settings-content">
            <!-- Organization Tab -->
            <div class="org-settings-panel active" data-panel="org">
                <div class="org-panel-header">
                    <h2>Organization Profile</h2>
                    <p>Manage your organization identity and branding</p>
                </div>
                <div class="org-form-card">
                    <div class="org-form-section">
                        <div class="org-form-section-label">
                            <i class="bi bi-building"></i>Details
                        </div>
                        <div class="org-form-group">
                            <label class="org-form-label" for="orgNameInput">Organization Name</label>
                            <input type="text" class="org-form-input" id="orgNameInput" placeholder="Acme Corp" readonly autocomplete="off" />
                            <span class="org-form-hint"><i class="bi bi-lock me-1"></i>Set during sign-up and cannot be changed</span>
                        </div>
                    </div>
                    <div class="org-form-divider"></div>
                    <div class="org-form-section">
                        <div class="org-form-section-label">
                            <i class="bi bi-envelope-check"></i>Email Verification
                        </div>
                        <div id="orgEmailVerifyStatus" class="org-form-group">
                            <div class="text-muted small"><span class="spinner-border spinner-border-sm me-2"></span>Checking verification status&hellip;</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Users Tab -->
            <div class="org-settings-panel" data-panel="users">
                <div class="org-panel-header">
                    <h2>Users &amp; Licensing</h2>
                    <p>Manage users, licenses, token usage, and your subscription</p>
                </div>
                <div class="org-form-card">
                    <!-- Token Usage Widget -->
                    <div class="token-budget-card" id="tokenUsageCard">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong><i class="bi bi-cpu me-2"></i>AI Token Usage (This Month)</strong>
                            <span class="small text-muted" id="tokenUsageText">Loading...</span>
                        </div>
                        <div class="token-budget-bar-wrap">
                            <div class="token-budget-bar-fill" id="tokenUsageBar" style="width:0%"></div>
                        </div>
                        <div class="token-budget-label" id="tokenUsageLabel">&nbsp;</div>
                    </div>
                </div>
                <div class="org-form-card" style="margin-top:16px">
                    <!-- License Info Widget -->
                    <div class="license-info-card mb-3" id="licenseInfoCard">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong><i class="bi bi-key me-2"></i>License Management</strong>
                            <button class="btn btn-sm cp-btn-gradient" id="buyLicensesBtn">
                                <i class="bi bi-cart-plus me-1"></i>Buy Licenses
                            </button>
                        </div>
                        <div class="d-flex gap-3 flex-wrap mb-2">
                            <div class="license-stat">
                                <span class="license-stat-label">Professional</span>
                                <span class="badge bg-primary" id="licenseProStats" title="Assigned / Purchased">0 / 0</span>
                            </div>
                            <div class="license-stat">
                                <span class="license-stat-label">Enterprise</span>
                                <span class="badge bg-dark" id="licenseEntStats" title="Assigned / Purchased">0 / 0</span>
                            </div>
                            <div class="license-stat">
                                <span class="license-stat-label">Available</span>
                                <span class="badge bg-success" id="licenseAvailable">0</span>
                            </div>
                            <div class="license-stat">
                                <span class="license-stat-label">Plan</span>
                                <span class="badge bg-info" id="licensePlanType">—</span>
                            </div>
                        </div>
                        <div class="small text-muted" id="licenseHint">Each license allows you to assign a paid plan to one user.</div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h4 style="margin:0;font-size:1rem;font-weight:600">Users</h4>
                        </div>
                        <button class="btn cp-btn-gradient btn-sm" id="createUserBtn">
                            <i class="bi bi-person-plus me-1"></i>Create User
                        </button>
                    </div>
                    <div class="table-responsive">
                        <table class="table cp-table">
                            <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>License</th><th>Actions</th></tr></thead>
                            <tbody id="usersTableBody"><tr><td colspan="6" class="text-center text-muted py-3">No users yet</td></tr></tbody>
                        </table>
                    </div>
                </div>
                <div class="org-form-card" style="margin-top:16px">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 style="margin:0;font-size:1rem;font-weight:600"><i class="bi bi-credit-card-2-front me-2"></i>Subscription &amp; Billing</h4>
                    </div>
                    <div id="billingInfo">
                        <div class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading subscription info...</div>
                    </div>
                </div>
            </div>

            <!-- Workspace Members Tab -->
            <div class="org-settings-panel" data-panel="ws-members">
                <div class="org-panel-header">
                    <h2>Workspace Members</h2>
                    <p>Manage workspace membership and roles for your organisation's workspaces</p>
                </div>
                <div class="org-form-card">
                    <div id="wsMemberWorkspaceList"><div class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading...</div></div>
                </div>
            </div>

            <!-- Compliance Tab -->
            <div class="org-settings-panel" data-panel="compliance">
                <div class="org-panel-header">
                    <h2>Compliance &amp; Privacy</h2>
                    <p>Your data protection and security overview</p>
                </div>
                <div class="org-form-card">
                    <div class="org-compliance-item">
                        <div class="org-compliance-icon success"><i class="bi bi-shield-check"></i></div>
                        <div>
                            <strong>GDPR Compliance</strong>
                            <p>All data is stored and processed in accordance with GDPR.</p>
                        </div>
                    </div>
                    <div class="org-form-divider"></div>
                    <div class="org-compliance-item">
                        <div class="org-compliance-icon primary"><i class="bi bi-lock-fill"></i></div>
                        <div>
                            <strong>Data Encryption</strong>
                            <p>Data at rest and in transit is encrypted with AES-256 and TLS 1.3.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Embedded Reports Tab -->
            <div class="org-settings-panel" data-panel="embeds">
                <div class="org-panel-header">
                    <h2>Embedded Reports</h2>
                    <p>Reports currently exposed via a public URL or iframe embed. Revoking removes anonymous access immediately.</p>
                </div>
                <div class="org-form-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <strong><i class="bi bi-code-square me-2"></i>Published / Embeddable Reports</strong>
                        <button class="btn btn-sm btn-outline-secondary" id="reloadEmbedsBtn">
                            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                        </button>
                    </div>
                    <div id="embeddedReportsList">
                        <div class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading...</div>
                    </div>
                    <div style="background:#fef3c7;border:1px solid #fde68a;border-radius:6px;padding:10px 14px;font-size:0.78rem;color:#92400e;margin-top:14px;">
                        <i class="bi bi-info-circle-fill me-1"></i>
                        Revoking sets the report back to <strong>Draft</strong> and clears its share token. Existing iframes embedded on external sites will stop rendering.
                    </div>
                </div>
            </div>

            <!-- Activity Tab -->
            <div class="org-settings-panel" data-panel="activity">
                <div class="org-panel-header">
                    <h2>Activity Log</h2>
                    <p>Recent actions performed in your organization</p>
                </div>
                <div class="org-form-card">
                    <div id="activityLog"><div class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading activity...</div></div>
                    <div id="activityPagination" class="mt-3 d-flex justify-content-between align-items-center d-none">
                        <span class="small text-muted" id="activityPagingInfo"></span>
                        <div>
                            <button class="btn btn-sm btn-outline-secondary me-1" id="activityPrevBtn" disabled>
                                <i class="bi bi-chevron-left"></i> Prev
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" id="activityNextBtn" disabled>
                                Next <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Support Tab -->
            <div class="org-settings-panel" data-panel="support">
                <div class="org-panel-header">
                    <h2>Contact Support</h2>
                    <p>Open a ticket and our team will respond by email according to your plan's SLA.</p>
                </div>
                <div class="org-form-card" style="max-width:820px;">
                    <div id="supportAlert" class="alert d-none"></div>
                    <form id="settingsSupportForm" autocomplete="off">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-cp">Your Name</label>
                                <input type="text" class="form-control cp-input" id="supportName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-cp">Email <span class="text-danger">*</span></label>
                                <input type="email" class="form-control cp-input" id="supportEmail" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-cp">Category</label>
                                <select class="form-select cp-input" id="supportCategory">
                                    <option>Question</option>
                                    <option>Billing</option>
                                    <option>Technical Issue</option>
                                    <option>Feature Request</option>
                                    <option>Account</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-cp">Priority</label>
                                <select class="form-select cp-input" id="supportPriority">
                                    <option>Low</option>
                                    <option selected>Normal</option>
                                    <option>High</option>
                                    <option>Urgent</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label-cp">Subject <span class="text-danger">*</span></label>
                                <input type="text" class="form-control cp-input" id="supportSubject" maxlength="250" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label-cp">Message <span class="text-danger">*</span></label>
                                <textarea class="form-control cp-input" id="supportMessage" rows="6" required></textarea>
                            </div>
                            <div class="col-12 d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-send me-1"></i>Submit Ticket
                                </button>
                            </div>
                        </div>
                    </form>
                    <p class="small text-muted mt-3 mb-0">
                        Tickets are sent to <a href="mailto:support@AIInsights365.net">support@AIInsights365.net</a>.
                        You'll receive a confirmation email with your ticket number.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create User Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createUserModalLabel"><i class="bi bi-person-plus me-2"></i>Create User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="createUserAlert" class="alert d-none"></div>
                <div class="mb-3">
                    <label class="form-label-cp">Full Name</label>
                    <input type="text" class="form-control cp-input" id="createFullName" placeholder="Jane Doe" autocomplete="off" />
                </div>
                <div class="mb-3">
                    <label class="form-label-cp">Email Address <span class="text-danger">*</span></label>
                    <input type="email" class="form-control cp-input" id="createEmail" placeholder="user@example.com" required autocomplete="off" />
                </div>
                <div class="mb-3">
                    <label class="form-label-cp">Password</label>
                    <div class="password-toggle-wrap">
                        <input type="password" class="form-control cp-input" id="createPassword" placeholder="Min 6 characters" autocomplete="new-password" />
                        <button type="button" class="password-toggle-btn" id="toggleCreatePassword" tabindex="-1">
                            <i class="bi bi-eye" id="toggleCreatePasswordIcon"></i>
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label-cp">Role</label>
                    <select class="form-select cp-input" id="createRole">
                        <option value="User">User</option>
                        <option value="OrgAdmin">OrgAdmin</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn cp-btn-gradient" id="submitCreateUserBtn">
                    <i class="bi bi-person-check me-1"></i>Create User
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-labelledby="resetPasswordModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="resetPasswordModalLabel"><i class="bi bi-key me-2"></i>Reset Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="resetPasswordAlert" class="alert d-none"></div>
                <input type="hidden" id="resetUserId" />
                <p class="text-muted small">Leave the password field empty to auto-generate a secure password.</p>
                <div class="mb-3">
                    <label class="form-label-cp">New Password (optional)</label>
                    <div class="password-toggle-wrap">
                        <input type="password" class="form-control cp-input" id="resetNewPassword" placeholder="Leave blank to auto-generate" autocomplete="new-password" />
                        <button type="button" class="password-toggle-btn" id="toggleResetPassword" tabindex="-1">
                            <i class="bi bi-eye" id="toggleResetPasswordIcon"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn cp-btn-gradient" id="submitResetPasswordBtn">
                    <i class="bi bi-arrow-clockwise me-1"></i>Reset Password
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Generic Confirm Action Modal (Suspend / Remove / etc.) -->
<div class="modal fade" id="confirmActionModal" tabindex="-1" aria-labelledby="confirmActionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmActionModalLabel">
                    <i class="bi bi-question-circle me-2" id="confirmActionIcon"></i>
                    <span id="confirmActionTitle">Confirm Action</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2" id="confirmActionMessage">Are you sure?</p>
                <p class="text-muted small mb-0" id="confirmActionSubtext"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmActionBtn">
                    <i class="bi bi-check2 me-1"></i><span id="confirmActionBtnLabel">Confirm</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Change Role Modal -->
<div class="modal fade" id="changeRoleModal" tabindex="-1" aria-labelledby="changeRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="changeRoleModalLabel"><i class="bi bi-person-gear me-2"></i>Change User Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="changeRoleAlert" class="alert d-none"></div>
                <input type="hidden" id="changeRoleUserId" />
                <p class="text-muted small">Select a new role for this user.</p>
                <div class="mb-3">
                    <label class="form-label-cp">Role</label>
                    <select class="form-select cp-input" id="changeRoleSelect">
                        <option value="User">User</option>
                        <option value="Contributor">Contributor</option>
                        <option value="OrgAdmin">Organization Admin</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn cp-btn-gradient" id="submitChangeRoleBtn">
                    <i class="bi bi-check2 me-1"></i>Save Role
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Workspace Members Modal -->
<div class="modal fade" id="wsMembersModal" tabindex="-1" aria-labelledby="wsMemberModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="wsMemberModalLabel"><i class="bi bi-people me-2"></i>Workspace Members</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="addMemberAlert" class="alert d-none mb-3"></div>
                <div class="d-flex gap-2 mb-3">
                    <input type="email" class="form-control cp-input" id="addMemberEmail" placeholder="user@example.com" autocomplete="off" />
                    <select class="form-select cp-input" id="addMemberRole" style="width:auto;min-width:110px">
                        <option value="Viewer">Viewer</option>
                        <option value="Editor">Editor</option>
                        <option value="Admin">Admin</option>
                    </select>
                    <button class="btn cp-btn-gradient text-nowrap" onclick="orgAdminWM.addMember()">
                        <i class="bi bi-person-plus me-1"></i>Add
                    </button>
                </div>
                <div class="table-responsive">
                    <table class="table cp-table">
                        <thead><tr><th>Name</th><th>Email</th><th>Role</th><th></th></tr></thead>
                        <tbody id="wsMembersTableBody"><tr><td colspan="4" class="text-center text-muted py-3">Loading...</td></tr></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- PayPal Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-paypal me-2"></i>Complete Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="paymentSummary" class="mb-3">
                    <div class="d-flex justify-content-between align-items-center p-3 rounded" style="background:var(--cp-glass-bg, #f8f9fa)">
                        <div>
                            <div class="fw-bold" id="paymentItemName">—</div>
                            <div class="text-muted small" id="paymentItemDesc">—</div>
                        </div>
                        <div class="fw-bold fs-5 text-primary" id="paymentItemPrice">$0</div>
                    </div>
                </div>
                <div id="paymentAlert" class="alert d-none mb-3"></div>
                <div id="paymentProcessing" class="text-center py-4 d-none">
                    <span class="spinner-border text-primary mb-2"></span>
                    <p class="text-muted">Processing your payment with PayPal…</p>
                </div>
                <div id="paymentActions">
                    <button class="btn cp-btn-gradient w-100" id="payWithPayPalBtn">
                        <i class="bi bi-paypal me-1"></i>Pay with PayPal
                    </button>
                    <p class="text-muted small text-center mt-2 mb-0">You will be redirected to PayPal to complete the payment securely.</p>
                </div>
                <div id="paymentSuccess" class="text-center py-4 d-none">
                    <i class="bi bi-check-circle-fill text-success fs-1 d-block mb-2"></i>
                    <h5>Payment Successful!</h5>
                    <p class="text-muted" id="paymentSuccessMsg">Your purchase has been applied.</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Buy Licenses Modal -->
<div class="modal fade" id="buyLicensesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-key me-2"></i>Buy Licenses</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="buyLicAlert" class="alert d-none mb-3"></div>
                <p class="text-muted small">Each license costs <strong>$25/user</strong> (Professional) or <strong>$45/user</strong> (Enterprise). Purchase licenses so you can assign paid plans to your users.</p>
                <div class="mb-3">
                    <label class="form-label-cp">Number of Licenses</label>
                    <input type="number" class="form-control cp-input" id="buyLicCount" min="1" value="1" />
                </div>
                <div class="mb-3">
                    <label class="form-label-cp">License Type</label>
                    <select class="form-select cp-input" id="buyLicType">
                        <option value="Professional">Professional — $25/license</option>
                        <option value="Enterprise">Enterprise — $45/license</option>
                    </select>
                </div>
                <div class="p-3 rounded mb-3" style="background:var(--cp-glass-bg, #f8f9fa)">
                    <div class="d-flex justify-content-between">
                        <span>Total</span>
                        <strong id="buyLicTotal">$25.00</strong>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn cp-btn-gradient" id="submitBuyLicBtn">
                    <i class="bi bi-paypal me-1"></i>Pay with PayPal
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Buy Token Pack Modal -->
<div class="modal fade" id="buyTokenModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-cpu me-2"></i>Buy Token Packs</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="buyTokenAlert" class="alert d-none mb-3"></div>
                <p class="text-muted small">Add more AI tokens to your organization. Choose a package below:</p>
                <div class="row g-3" id="tokenPackageList">
                    <label class="token-pack-option">
                        <input type="radio" name="tokenPack" value="0" data-tokens="100000" data-price="9" checked />
                        <div class="token-pack-card glass-card">
                            <div class="small text-uppercase text-muted">Starter</div>
                            <div class="fw-bold">100K Tokens</div>
                            <div class="text-muted small">Great for small teams getting started.</div>
                            <div class="fw-bold text-primary mt-1">$9.00</div>
                        </div>
                    </label>
                    <label class="token-pack-option">
                        <input type="radio" name="tokenPack" value="1" data-tokens="500000" data-price="20" />
                        <div class="token-pack-card glass-card">
                            <div class="small text-uppercase text-muted">Growth</div>
                            <div class="fw-bold">500K Tokens</div>
                            <div class="text-muted small">Perfect for regular weekly reporting.</div>
                            <div class="fw-bold text-primary mt-1">$20.00</div>
                        </div>
                    </label>
                    <label class="token-pack-option">
                        <input type="radio" name="tokenPack" value="2" data-tokens="2000000" data-price="25" />
                        <div class="token-pack-card glass-card pricing-featured">
                            <div class="small text-uppercase text-muted">Pro</div>
                            <div class="fw-bold">2M Tokens</div>
                            <div class="text-muted small">Best for active teams and heavy AI usage.</div>
                            <div class="fw-bold text-primary mt-1">$25.00</div>
                        </div>
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn cp-btn-gradient" id="submitBuyTokenBtn">
                    <i class="bi bi-paypal me-1"></i>Pay with PayPal
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    const user = JSON.parse(localStorage.getItem('cp_user') || 'null');
    const orgId = user?.organizationId;
    const userId = user?.id;
    let _licenseAvailability = { pro: 0, enterprise: 0 };

    // ---- Billing Tab ----
    function renderBilling(plan) {
        const isFreeTrial = plan?.plan === 'FreeTrial' || plan?.isTrialActive;
        const trialDays = plan?.daysRemaining || 0;

        const trialBadge = isFreeTrial ? `<div class="alert alert-info mb-3"><i class="bi bi-clock me-2"></i><strong>${trialDays} days remaining</strong> on your Free Trial.</div>` : '';

        // Build subscription status card
        let subscriptionCard = '';
        fetch(`/api/paypal/subscription-status?organizationId=${orgId}`)
            .then(r => r.json())
            .then(sub => {
                const el = document.getElementById('subscriptionStatusCard');
                if (!el) return;
                const nextDate = sub.nextBillingDate ? new Date(sub.nextBillingDate).toLocaleDateString() : 'N/A';
                switch (sub.status) {
                    case 'ACTIVE':
                        el.innerHTML = `
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="badge bg-success mb-1">Active Subscription</span>
                                    <div class="small text-muted">Next billing: <strong>${nextDate}</strong></div>
                                </div>
                                <button class="btn btn-outline-danger btn-sm" onclick="cancelSubscription()">
                                    <i class="bi bi-x-circle me-1"></i>Cancel Subscription
                                </button>
                            </div>`;
                        break;
                    case 'CANCELLED':
                        el.innerHTML = `
                            <div class="alert alert-warning mb-0 py-2">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                Subscription cancelled. Plan active until <strong>${nextDate}</strong>.
                            </div>`;
                        break;
                    case 'APPROVAL_PENDING':
                        el.innerHTML = `
                            <div class="alert alert-info mb-0 py-2 d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-hourglass-split me-1"></i>
                                    <span id="pendingSubMsg">Awaiting PayPal approval — checking activation status…</span>
                                </div>
                                <button class="btn btn-sm btn-outline-secondary ms-2" onclick="clearPendingSubscription()">
                                    <i class="bi bi-x-circle me-1"></i>Cancel pending
                                </button>
                            </div>`;
                        // Self-heal: keep polling /api/paypal/activate-subscription
                        // until PayPal flips the sub to ACTIVE or we hit the
                        // timeout. PayPal sandbox commonly takes 10-30s to
                        // propagate APPROVAL_PENDING -> ACTIVE after the user
                        // approves in the popup, so a single check on page
                        // load isn't enough.
                        if (sub.subscriptionId && !window._pendingSubPollActive) {
                            window._pendingSubPollActive = true;
                            const planKeyForActivate = (plan?.plan === 'Enterprise' ? 'Enterprise' : 'Professional');
                            const startedAt = Date.now();
                            const maxWaitMs = 60_000;   // total poll window
                            const intervalMs = 4_000;   // every 4s
                            let attempt = 0;
                            const poll = async () => {
                                attempt++;
                                try {
                                    const r = await fetch('/api/paypal/activate-subscription', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({
                                            organizationId: orgId,
                                            subscriptionId: sub.subscriptionId,
                                            planKey: planKeyForActivate
                                        })
                                    });
                                    const j = await r.json().catch(() => ({}));
                                    if (j && j.success && j.status === 'ACTIVE') {
                                        window._pendingSubPollActive = false;
                                        // Refresh whole billing card so the
                                        // ACTIVE banner replaces the pending one
                                        // without any user action.
                                        if (typeof window.cpToast === 'function') {
                                            cpToast({ title: 'Subscription activated', message: `${planKeyForActivate} plan is now active.`, variant: 'success' });
                                        }
                                        loadBilling();
                                        if (typeof window.refreshTrialBanner === 'function') window.refreshTrialBanner();
                                        return;
                                    }
                                } catch { /* ignore, will retry */ }

                                if (Date.now() - startedAt < maxWaitMs) {
                                    setTimeout(poll, intervalMs);
                                } else {
                                    window._pendingSubPollActive = false;
                                    const msg = document.getElementById('pendingSubMsg');
                                    if (msg) msg.textContent =
                                        'Awaiting PayPal approval. Complete the checkout window to activate your plan.';
                                }
                            };
                            // Kick off immediately
                            poll();
                        }
                        break;
                    case 'SUSPENDED':
                        el.innerHTML = `
                            <div class="alert alert-warning mb-0 py-2">
                                <i class="bi bi-pause-circle me-1"></i>
                                Subscription suspended by PayPal. Contact support or update your payment method to resume billing.
                            </div>`;
                        break;
                    case 'PAST_DUE':
                        el.innerHTML = `
                            <div class="alert alert-danger mb-0 py-2 d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-exclamation-octagon me-1"></i>
                                    <strong>Payment failed.</strong> Please update your payment method — access will be revoked if not resolved within 5 days.
                                </div>
                                <button class="btn btn-sm btn-light" onclick="window.upgradeplan && window.upgradeplan(plan?.plan)">
                                    <i class="bi bi-credit-card me-1"></i>Update Payment
                                </button>
                            </div>`;
                        break;
                    case 'EXPIRED':
                        el.innerHTML = `
                            <div class="alert alert-secondary mb-0 py-2">
                                <i class="bi bi-clock-history me-1"></i>
                                Subscription expired. Choose a plan below to reactivate.
                            </div>`;
                        break;
                    case 'NONE':
                    default:
                        // No banner when there's nothing meaningful to show.
                        el.innerHTML = '';
                        el.classList.add('d-none');
                        break;
                }
            }).catch(() => {});

        document.getElementById('billingInfo').innerHTML = `
            ${trialBadge}
            <div id="subscriptionStatusCard" class="glass-card p-3 mb-3"></div>
            <div class="glass-card p-4 mb-3">
                <h5>Token Add-ons</h5>
                <p class="text-muted small mb-2">Purchase additional AI tokens for your organization.</p>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span>Current extra packs: <strong id="enterprisePackCount">${plan?.enterpriseExtraTokenPacks || 0}</strong></span>
                    <span>Total extra tokens: <strong id="enterprisePackTokens">${((plan?.enterpriseExtraTokenPacks || 0) * 2000000).toLocaleString()}</strong></span>
                </div>
                <button class="btn btn-sm cp-btn-gradient" id="buyTokenPackBtn">
                    <i class="bi bi-cart-plus me-1"></i>Buy More Tokens
                </button>
            </div>
            <div class="glass-card p-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Billing History</h5>
                    <button class="btn btn-sm btn-outline-secondary" id="refreshInvoicesBtn" title="Refresh">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
                <p class="text-muted small mb-2">Click an invoice to view a printable copy or save it as PDF.</p>
                <div id="billingHistoryList">
                    <div class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading invoices...</div>
                </div>
            </div>`;
        document.getElementById('buyTokenPackBtn')?.addEventListener('click', function() {
            new bootstrap.Modal(document.getElementById('buyTokenModal')).show();
        });
        document.getElementById('refreshInvoicesBtn')?.addEventListener('click', loadBillingHistory);
        loadBillingHistory();
    }

    function escapeHtml(s) {
        if (s == null) return '';
        return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    function loadBillingHistory() {
        const el = document.getElementById('billingHistoryList');
        if (!el || !orgId) return;
        el.innerHTML = '<div class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading invoices...</div>';
        fetch(`/api/billing/invoices?organizationId=${orgId}`)
            .then(r => r.ok ? r.json() : [])
            .then(items => {
                if (!Array.isArray(items) || items.length === 0) {
                    el.innerHTML = '<p class="text-muted small mb-0">No invoices yet. Invoices will appear here once you complete a purchase.</p>';
                    return;
                }
                const rows = items.map(it => {
                    const dt = it.paidAt || it.createdAt;
                    const dtStr = dt ? new Date(dt).toLocaleDateString() : '-';
                    const amt = `$${Number(it.amount || 0).toFixed(2)} ${it.currency || 'USD'}`;
                    const statusBadge = it.status === 'succeeded'
                        ? '<span class="badge bg-success">Paid</span>'
                        : it.status === 'failed'
                            ? '<span class="badge bg-danger">Failed</span>'
                            : it.status === 'refunded'
                                ? '<span class="badge bg-info">Refunded</span>'
                                : `<span class="badge bg-secondary">${escapeHtml(it.status || '-')}</span>`;
                    const typeLabel = ({ license: 'License', token_pack: 'Token Pack', subscription: 'Subscription', plan_upgrade: 'Plan Upgrade' })[it.paymentType] || (it.paymentType || '-');
                    return `<tr>
                        <td class="small">${dtStr}</td>
                        <td class="small"><code>${escapeHtml(it.invoiceNumber || ('#' + it.id))}</code></td>
                        <td class="small">${escapeHtml(typeLabel)}</td>
                        <td class="small">${escapeHtml(it.description || '-')}</td>
                        <td class="small text-end">${amt}</td>
                        <td>${statusBadge}</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" href="/billing/invoice/${it.id}" target="_blank" rel="noopener" title="View invoice">
                                <i class="bi bi-file-earmark-text"></i> View
                            </a>
                        </td>
                    </tr>`;
                }).join('');
                el.innerHTML = `
                    <div class="table-responsive">
                        <table class="table cp-table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Invoice #</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>${rows}</tbody>
                        </table>
                    </div>`;
            })
            .catch(() => {
                el.innerHTML = '<p class="text-danger small mb-0">Failed to load invoices.</p>';
            });
    }

    // ── Pending PayPal payment context ──
    let _pendingPayment = { type: '', amount: 0, description: '', quantity: 0, tokenAmount: 0, planKey: '' };

    function openPayPalPayment(type, amount, description, extra) {
        _pendingPayment = { type, amount, description, quantity: extra?.quantity || 0, tokenAmount: extra?.tokenAmount || 0, planKey: extra?.planKey || '' };
        document.getElementById('paymentItemName').textContent = description;
        document.getElementById('paymentItemDesc').textContent = type === 'license' ? 'License purchase' : type === 'token_pack' ? 'Token pack' : 'Plan upgrade';
        document.getElementById('paymentItemPrice').textContent = '$' + amount.toFixed(2);
        document.getElementById('paymentAlert').classList.add('d-none');
        document.getElementById('paymentProcessing').classList.add('d-none');
        document.getElementById('paymentActions').classList.remove('d-none');
        document.getElementById('paymentSuccess').classList.add('d-none');
        new bootstrap.Modal(document.getElementById('paymentModal')).show();
    }

    document.getElementById('payWithPayPalBtn')?.addEventListener('click', async function() {
        const btn = this;
        const alertEl = document.getElementById('paymentAlert');
        const processing = document.getElementById('paymentProcessing');
        const actions = document.getElementById('paymentActions');

        btn.disabled = true;
        actions.classList.add('d-none');
        processing.classList.remove('d-none');

        try {
            if (_pendingPayment.type === 'subscription') {
                // ── Recurring subscription flow ──
                const createResp = await fetch('/api/paypal/create-subscription', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ organizationId: orgId, planKey: _pendingPayment.planKey })
                });
                const createData = await createResp.json();
                if (!createResp.ok || !createData.approveUrl) {
                    throw new Error(createData.error || 'Failed to create subscription.');
                }

                // Open PayPal approval in popup
                const popup = window.open(createData.approveUrl, 'PayPal', 'width=500,height=650,scrollbars=yes');

                // Poll for popup close
                await new Promise((resolve, reject) => {
                    const interval = setInterval(() => {
                        if (!popup || popup.closed) { clearInterval(interval); resolve(); }
                    }, 500);
                    setTimeout(() => { clearInterval(interval); reject(new Error('Payment timeout.')); }, 600000);
                });

                // Activate the subscription. The server already polls PayPal a few
                // times, but we also retry on this side because the user might close
                // the popup the instant they click Subscribe — before PayPal has
                // finished promoting APPROVAL_PENDING → ACTIVE.
                let activateData = null;
                let activateResp = null;
                for (let attempt = 0; attempt < 4; attempt++) {
                    activateResp = await fetch('/api/paypal/activate-subscription', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ organizationId: orgId, planKey: _pendingPayment.planKey })
                    });
                    activateData = await activateResp.json();
                    if (activateResp.ok && activateData.success) break;
                    // Only retry while PayPal is still propagating the approval.
                    const stillPending = activateData && (activateData.status === 'APPROVAL_PENDING' || activateData.status === 'APPROVED');
                    if (!stillPending) break;
                    await new Promise(r => setTimeout(r, 2500));
                }

                if (activateResp.ok && activateData.success) {
                    processing.classList.add('d-none');
                    // Close the payment modal and show an animated success dialog
                    bootstrap.Modal.getInstance(document.getElementById('paymentModal'))?.hide();
                    const nextDate = activateData.nextBilling
                        ? new Date(activateData.nextBilling).toLocaleDateString()
                        : '—';
                    if (typeof window.cpSuccessModal === 'function') {
                        cpSuccessModal({
                            title: 'Subscription activated',
                            message: `Your ${_pendingPayment.planKey} plan is now active.`,
                            details: [
                                ['Plan',          _pendingPayment.planKey],
                                ['Amount',        `$${_pendingPayment.amount.toFixed(2)} / month`],
                                ['Auto-renews',   'Yes'],
                                ['Next billing',  nextDate]
                            ],
                            primaryText: 'Great'
                        });
                    } else if (typeof window.cpToast === 'function') {
                        cpToast({ title: 'Subscription activated', message: `${_pendingPayment.planKey} plan is active.`, variant: 'success' });
                    }
                    loadBilling();
                    loadLicenseInfo();
                    loadTokenUsage();
                    if (typeof window.refreshTrialBanner === 'function') window.refreshTrialBanner();
                } else {
                    throw new Error(activateData.error || 'Subscription activation pending. Please check back shortly.');
                }
            } else {
                // ── One-time payment flow (licenses, token packs) ──
                const createResp = await fetch('/api/paypal/create-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ amount: _pendingPayment.amount, description: _pendingPayment.description })
                });
                const createData = await createResp.json();
                if (!createResp.ok || !createData.orderId) {
                    throw new Error(createData.error || 'Failed to create PayPal order.');
                }

                const popup = window.open(createData.approveUrl, 'PayPal', 'width=500,height=650,scrollbars=yes');

                await new Promise((resolve, reject) => {
                    const interval = setInterval(() => {
                        if (!popup || popup.closed) { clearInterval(interval); resolve(); }
                    }, 500);
                    setTimeout(() => { clearInterval(interval); reject(new Error('Payment timeout.')); }, 600000);
                });

                const captureResp = await fetch('/api/paypal/capture-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        orderId: createData.orderId,
                        organizationId: orgId,
                        purchaseType: _pendingPayment.type,
                        quantity: _pendingPayment.quantity,
                        tokenAmount: _pendingPayment.tokenAmount,
                        planKey: _pendingPayment.planKey
                    })
                });
                const captureData = await captureResp.json();

                if (captureResp.ok && captureData.success) {
                    processing.classList.add('d-none');
                    bootstrap.Modal.getInstance(document.getElementById('paymentModal'))?.hide();
                    // Build a nice details table depending on purchase type
                    const details = [];
                    if (_pendingPayment.type === 'license') {
                        details.push(['Quantity',  `${_pendingPayment.quantity} license(s)`]);
                        if (_pendingPayment.planKey) details.push(['Tier', _pendingPayment.planKey]);
                    } else if (_pendingPayment.type === 'token_pack') {
                        details.push(['Tokens added', Number(_pendingPayment.tokenAmount || 0).toLocaleString()]);
                    } else if (_pendingPayment.planKey) {
                        details.push(['Plan', _pendingPayment.planKey]);
                    }
                    details.push(['Amount charged', `$${Number(_pendingPayment.amount || 0).toFixed(2)}`]);
                    const titleMap = {
                        'license':      'Licenses added',
                        'token_pack':   'Tokens added',
                        'plan_upgrade': 'Plan upgraded'
                    };
                    if (typeof window.cpSuccessModal === 'function') {
                        cpSuccessModal({
                            title: titleMap[_pendingPayment.type] || 'Payment successful',
                            message: captureData.message || 'Your purchase has been applied to your organization.',
                            details,
                            primaryText: 'Done'
                        });
                    } else if (typeof window.cpToast === 'function') {
                        cpToast({ title: titleMap[_pendingPayment.type] || 'Payment successful', message: captureData.message || 'Purchase applied.', variant: 'success' });
                    }
                    loadBilling();
                    loadLicenseInfo();
                    loadTokenUsage();
                    if (typeof window.refreshTrialBanner === 'function') window.refreshTrialBanner();
                } else {
                    throw new Error(captureData.error || 'Payment capture failed.');
                }
            }
        } catch (err) {
            processing.classList.add('d-none');
            actions.classList.remove('d-none');
            alertEl.className = 'alert alert-danger';
            alertEl.textContent = err.message || 'Payment failed. Please try again.';
            alertEl.classList.remove('d-none');
        } finally {
            btn.disabled = false;
        }
    });

    window.upgradeplan = async function(planKey) {
        if (!userId) return;
        if (planKey === 'FreeTrial') {
            fetch('/api/subscription/activate-trial', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ userId })
            }).then(r => r.json()).then(d => {
                if (d.error) alert(d.error);
                else { loadBilling(); }
            });
        } else {
            // Use PayPal recurring subscription for paid plans
            const alertEl = document.getElementById('paymentAlert');
            const processing = document.getElementById('paymentProcessing');
            const actions = document.getElementById('paymentActions');
            const price = planKey === 'Enterprise' ? 45.00 : 25.00;

            document.getElementById('paymentItemName').textContent = planKey + ' Plan — Monthly Subscription';
            document.getElementById('paymentItemDesc').textContent = `$${price.toFixed(2)}/month • Auto-renews monthly`;
            document.getElementById('paymentItemPrice').textContent = '$' + price.toFixed(2) + '/mo';
            alertEl.classList.add('d-none');
            processing.classList.add('d-none');
            actions.classList.remove('d-none');
            document.getElementById('paymentSuccess').classList.add('d-none');
            _pendingPayment = { type: 'subscription', planKey, amount: price };
            new bootstrap.Modal(document.getElementById('paymentModal')).show();
        }
    };

    window.cancelSubscription = async function() {
        if (!orgId) return;
        const ok = typeof window.cpConfirm === 'function'
            ? await cpConfirm({
                title: 'Cancel Subscription',
                message: 'Cancel your monthly subscription? Your plan will remain active until the end of the current billing period.',
                icon: 'bi-x-circle',
                variant: 'danger',
                confirmText: 'Cancel Subscription',
                cancelText: 'Keep Subscription'
              })
            : confirm('Are you sure you want to cancel your monthly subscription? Your plan will remain active until the end of the current billing period.');
        if (!ok) return;
        try {
            const resp = await fetch('/api/paypal/cancel-subscription', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ organizationId: orgId, reason: 'Customer requested cancellation' })
            });
            const data = await resp.json();
            if (resp.ok && data.success) {
                if (typeof window.cpToast === 'function') cpToast({ title: 'Subscription cancelled', message: data.message, variant: 'success' });
                else alert(data.message);
                loadBilling();
            } else {
                if (typeof window.cpToast === 'function') cpToast({ title: 'Cancel failed', message: data.error || 'Failed to cancel subscription.', variant: 'danger' });
                else alert(data.error || 'Failed to cancel subscription.');
            }
        } catch (err) {
            if (typeof window.cpToast === 'function') cpToast({ title: 'Cancel failed', message: err.message, variant: 'danger' });
            else alert('Error cancelling subscription: ' + err.message);
        }
    };

    // Clears a stuck APPROVAL_PENDING subscription (popup closed before approval).
    window.clearPendingSubscription = async function() {
        if (!orgId) return;
        const ok = typeof window.cpConfirm === 'function'
            ? await cpConfirm({
                title: 'Cancel Pending Subscription',
                message: 'Discard the pending PayPal subscription? You can start a new checkout afterwards.',
                icon: 'bi-x-circle',
                variant: 'warning',
                confirmText: 'Discard',
                cancelText: 'Keep waiting'
              })
            : confirm('Discard the pending PayPal subscription?');
        if (!ok) return;
        try {
            const resp = await fetch('/api/paypal/clear-pending-subscription', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ organizationId: orgId, reason: 'Abandoned before approval' })
            });
            const data = await resp.json();
            if (resp.ok && data.success) {
                if (typeof window.cpToast === 'function') cpToast({ title: 'Pending subscription cleared', message: 'You can start a new subscription now.', variant: 'success' });
                loadBilling();
            } else {
                if (typeof window.cpToast === 'function') cpToast({ title: 'Could not clear', message: data.error || 'Failed.', variant: 'danger' });
                else alert(data.error || 'Failed.');
            }
        } catch (err) {
            if (typeof window.cpToast === 'function') cpToast({ title: 'Error', message: err.message, variant: 'danger' });
        }
    };

    function loadBilling() {
        if (!userId) {
            document.getElementById('billingInfo').innerHTML = '<p class="text-muted">Please sign in to view billing info.</p>';
            return;
        }
        fetch('/api/subscription/' + userId)
            .then(r => r.json())
            .then(plan => renderBilling(plan))
            .catch(() => { document.getElementById('billingInfo').innerHTML = '<p class="text-danger">Failed to load billing info.</p>'; });
    }

    // ---- Activity Tab ----
    let activityPage = 1;
    let activityTotal = 0;
    const pageSize = 20;

    function renderActivity(data) {
        const { items, total } = data;
        activityTotal = total;
        if (!items || items.length === 0) {
            document.getElementById('activityLog').innerHTML = '<p class="text-muted">No activity recorded yet.</p>';
            document.getElementById('activityPagination').classList.add('d-none');
            return;
        }
        const rows = items.map(a => {
            const dt = new Date(a.createdAt).toLocaleString();
            const icon = {
                login: 'bi-box-arrow-in-right text-success',
                logout: 'bi-box-arrow-right text-muted',
                agent_execution: 'bi-robot text-primary',
                datasource_query: 'bi-database text-info',
                workspace_created: 'bi-folder-plus text-warning',
                datasource_created: 'bi-plug text-success',
                agent_created: 'bi-robot text-primary',
                user_invited: 'bi-person-plus text-info'
            }[a.action] || 'bi-circle text-muted';
            return `<tr>
                <td><i class="bi ${icon} me-2"></i>${a.action}</td>
                <td>${a.description}</td>
                <td class="text-muted small">${dt}</td>
            </tr>`;
        }).join('');
        document.getElementById('activityLog').innerHTML = `
            <div class="table-responsive">
                <table class="table cp-table">
                    <thead><tr><th>Action</th><th>Description</th><th>Time</th></tr></thead>
                    <tbody>${rows}</tbody>
                </table>
            </div>`;
        const pagination = document.getElementById('activityPagination');
        pagination.classList.remove('d-none');
        document.getElementById('activityPagingInfo').textContent = `Page ${activityPage} of ${Math.ceil(total / pageSize)} (${total} total)`;
        document.getElementById('activityPrevBtn').disabled = activityPage <= 1;
        document.getElementById('activityNextBtn').disabled = activityPage >= Math.ceil(total / pageSize);
    }

    function loadActivity() {
        let url = `/api/activity?page=${activityPage}&pageSize=${pageSize}`;
        if (orgId) url += `&organizationId=${orgId}`;
        else if (userId) url += `&userId=${userId}`;
        fetch(url).then(r => r.json()).then(renderActivity).catch(() => {
            document.getElementById('activityLog').innerHTML = '<p class="text-danger">Failed to load activity.</p>';
