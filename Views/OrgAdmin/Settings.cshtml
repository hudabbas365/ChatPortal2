    // Token Usage
    function loadTokenUsage() {
        if (!orgId) return;
        fetch(`/api/org/token-usage?organizationId=${orgId}`)
            .then(r => r.json())
            .then(data => {
                const used      = data.used || 0;
                const budget    = data.budget || 2000000;
                const pct       = Math.min(100, Math.round((used / budget) * 100));
                const bar       = document.getElementById('tokenUsageBar');
                const text      = document.getElementById('tokenUsageText');
                const label     = document.getElementById('tokenUsageLabel');
                if (bar)   { bar.style.width = pct + '%'; bar.className = 'token-budget-bar-fill' + (pct >= 100 ? ' exceeded' : pct >= 80 ? ' warning' : ''); }
                if (text)  text.textContent = pct + '% used';
                if (label) label.textContent = `${used.toLocaleString()} / ${budget.toLocaleString()} tokens`;
            }).catch(() => {});
    }

    // ---- Left sidebar tab switching ----
    const SETTINGS_TAB_STORAGE_KEY = 'cp_orgSettings_activeTab';

    function switchSettingsTab(tab, opts) {
        // Billing tab was merged into the Users & Licensing tab.
        if (tab === 'billing') tab = 'users';
        // Fall back to the first nav item if an unknown tab is supplied.
        const known = Array.from(document.querySelectorAll('.org-settings-nav-item[data-tab]')).map(b => b.dataset.tab);
        if (!known.includes(tab)) tab = known[0] || 'org';

        document.querySelectorAll('.org-settings-nav-item').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
        document.querySelectorAll('.org-settings-panel').forEach(p => p.classList.toggle('active', p.dataset.panel === tab));
        if (tab === 'activity') loadActivity();
        else if (tab === 'users') { loadUsers(); loadTokenUsage(); loadLicenseInfo(); loadBilling(); }
        else if (tab === 'ws-members' && window.orgAdminWM) orgAdminWM.init(orgId);

        // Persist the active tab so it survives a page refresh.
        if (!opts || opts.persist !== false) {
            try { localStorage.setItem(SETTINGS_TAB_STORAGE_KEY, tab); } catch { }
            try {
                const url = new URL(window.location.href);
                if (url.searchParams.get('tab') !== tab) {
                    url.searchParams.set('tab', tab);
                    window.history.replaceState({}, '', url.toString());
                }
            } catch { }
        }
    }
    document.querySelectorAll('.org-settings-nav-item').forEach(btn => {
        btn.addEventListener('click', () => switchSettingsTab(btn.dataset.tab));
    });

    // Auto-open tab from URL query param, or fall back to the last active tab.
    const params = new URLSearchParams(window.location.search);
    const tabParam = params.get('tab');
    let savedTab = null;
    try { savedTab = localStorage.getItem(SETTINGS_TAB_STORAGE_KEY); } catch { }
    if (tabParam) switchSettingsTab(tabParam);
    else if (savedTab) switchSettingsTab(savedTab);

    // Populate org name + email from stored user data, then refresh from /api/auth/me
    const orgNameInput = document.getElementById('orgNameInput');
    const orgEmailInput = document.getElementById('orgEmailInput');
    if (orgNameInput && user) orgNameInput.value = user.orgName || '';
    if (orgEmailInput && user) orgEmailInput.value = user.orgEmail || user.email || '';

    (async function refreshOrgIdentity() {
        try {
            const r = await fetch('/api/auth/me', { credentials: 'same-origin' });
            if (!r.ok) return;
            const me = await r.json();
            if (orgNameInput) orgNameInput.value = me.orgName || orgNameInput.value || '';
            if (orgEmailInput) orgEmailInput.value = me.orgEmail || me.email || orgEmailInput.value || '';
            // Keep cp_user in sync so other pages benefit
            try {
                const cached = JSON.parse(localStorage.getItem('cp_user') || 'null') || {};
                cached.orgName = me.orgName ?? cached.orgName;
                cached.orgEmail = me.orgEmail ?? me.email ?? cached.orgEmail;
                cached.email = me.email ?? cached.email;
                localStorage.setItem('cp_user', JSON.stringify(cached));
            } catch { }
        } catch { }
    })();

    // ---- Email verification status (Organization tab) ----
    function renderVerifyStatus(isVerified) {
        const el = document.getElementById('orgEmailVerifyStatus');
        if (!el) return;
        if (isVerified) {
            el.innerHTML = '<div class="alert alert-success mb-0 py-2"><i class="bi bi-check-circle-fill me-2"></i>Your organization email is verified.</div>';
        } else {
            el.innerHTML = `
                <div class="alert alert-warning mb-2 py-2">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Your organization email has not been verified yet.
                </div>
                <button type="button" class="btn btn-sm cp-btn-gradient" id="resendConfirmEmailBtn">
                    <i class="bi bi-envelope-arrow-up me-1"></i>Resend Confirmation Email
                </button>
                <span id="resendConfirmEmailMsg" class="ms-2 small"></span>`;
            document.getElementById('resendConfirmEmailBtn').addEventListener('click', async function () {
                const btn = this;
                const msg = document.getElementById('resendConfirmEmailMsg');
                btn.disabled = true;
                msg.textContent = '';
                msg.className = 'ms-2 small text-muted';
                try {
                    const r = await fetch('/api/auth/resend-confirmation', { method: 'POST', credentials: 'same-origin' });
                    const d = await r.json().catch(() => ({}));
                    if (r.ok && d.success) {
                        msg.className = 'ms-2 small text-success';
                        msg.innerHTML = '<i class="bi bi-check-circle me-1"></i>' + (d.message || 'Confirmation email sent.');
                    } else {
                        msg.className = 'ms-2 small text-danger';
                        msg.textContent = d.error || d.message || 'Failed to send confirmation email.';
                    }
                } catch {
                    msg.className = 'ms-2 small text-danger';
                    msg.textContent = 'Network error. Please try again.';
                } finally {
                    btn.disabled = false;
                }
            });
        }
    }

    function loadVerifyStatus() {
        if (!orgId) return;
        fetch(`/api/auth/org-verified?orgId=${orgId}`, { credentials: 'same-origin' })
            .then(r => r.ok ? r.json() : { isVerified: false })
            .then(d => renderVerifyStatus(!!d.isVerified))
            .catch(() => renderVerifyStatus(false));
