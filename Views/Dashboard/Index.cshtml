<script>
(function() {
    const initialCharts = @Html.Raw(ViewBag.InitialCharts ?? "[]");
    const chartLibraryData = @Html.Raw(ViewBag.ChartLibrary ?? "[]");
    const datasets = @Html.Raw(ViewBag.Datasets ?? "[]");
    const pages = @Html.Raw(ViewBag.Pages ?? "[]");
    const activePageIndex = @(ViewBag.ActivePageIndex ?? 0);

    // ── Reset all dashboard globals to prevent cross-dashboard state leakage ──
    window.currentDatasourceId = null;
    window.currentDatasourceType = null;
    window.currentAgentGuid = null;
    window.currentWorkspaceGuid = null;
    window.currentOrganizationGuid = null;
    window._realTableNames = null;
    window._dashboardWsData = null;
    window._currentReportGuid = null;

    // Track existing report guid for save-upsert
    window._currentReportGuid = @Html.Raw(ViewBag.ReportGuid != null ? Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.ReportGuid) : "null");

    // Set datasource context from server so charts can query real data immediately
    @if (ViewBag.DatasourceId != null)
