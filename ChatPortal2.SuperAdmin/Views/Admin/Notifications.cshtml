@model List<AIInsights.Models.Notification>
@{
    ViewData["Title"] = "Broadcast Notifications";
    var orgs = ViewBag.Orgs as IEnumerable<dynamic> ?? new List<dynamic>();
}

<div class="admin-page container">
    <div class="admin-header">
        <h1 class="admin-title">Broadcast Notifications</h1>
        <p class="admin-subtitle">Push a notification to every organization, or target specific organizations. Delivered to all users via the bell icon.</p>
    </div>

    <div class="content-card mb-4">
        <h5 class="mb-3"><i class="bi bi-broadcast me-2"></i>New Broadcast</h5>
        <form id="saBroadcastForm" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Audience</label>
                <select class="form-select" id="bc-scope">
                    <option value="All" selected>All organizations</option>
                    <option value="SpecificOrgs">Specific organizations…</option>
                </select>
            </div>
            <div class="col-md-8" id="bc-orgs-wrap" style="display:none;">
                <label class="form-label">Organizations</label>
                <select class="form-select" id="bc-orgs" multiple size="4">
                    @foreach (var o in orgs)
                    {
                        <option value="@o.Id">@o.Name</option>
                    }
                </select>
                <small class="text-muted">Hold Ctrl/Cmd to select multiple.</small>
            </div>
            <div class="col-md-8">
                <label class="form-label">Title *</label>
                <input class="form-control" id="bc-title" maxlength="120" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Severity</label>
                <select class="form-select" id="bc-severity">
                    <option value="low">Low</option>
                    <option value="normal" selected>Normal</option>
                    <option value="high">High</option>
                </select>
            </div>
            <div class="col-12">
                <label class="form-label">Body *</label>
                <textarea class="form-control" id="bc-body" rows="3" maxlength="800" required></textarea>
            </div>
            <div class="col-md-4">
                <label class="form-label">Type</label>
                <select class="form-select" id="bc-type">
                    <option value="Announcement" selected>Announcement</option>
                    <option value="Info">Info</option>
                    <option value="Warning">Warning</option>
                    <option value="Success">Success</option>
                    <option value="System">System</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Link (optional)</label>
                <input class="form-control" id="bc-link" placeholder="/pricing" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Expires At (optional)</label>
                <input type="datetime-local" class="form-control" id="bc-expires" />
            </div>
            <div class="col-12 d-flex justify-content-end gap-2">
                <button type="reset" class="btn btn-outline-secondary">Clear</button>
                <button type="submit" class="cp-btn-gradient"><i class="bi bi-send me-1"></i>Broadcast</button>
            </div>
        </form>
        <div id="bc-result" class="mt-3 small"></div>
    </div>

    <div class="content-card">
        <h5 class="mb-3"><i class="bi bi-clock-history me-2"></i>Recent Broadcasts</h5>
        <div class="dr-table-scroll">
            <table class="cp-table">
                <thead class="cp-table-head">
                    <tr>
                        <th>Title</th>
                        <th>Scope</th>
                        <th>Org</th>
                        <th>Type</th>
                        <th>Severity</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="bc-tbody">
                    @if (Model == null || Model.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No broadcasts yet.</td></tr>
                    }
                    else
                    {
                        foreach (var n in Model)
                        {
                            <tr data-id="@n.Id">
                                <td><strong>@n.Title</strong><div class="text-muted small">@n.Body</div></td>
                                <td>@n.Scope</td>
                                <td>@(n.OrganizationId?.ToString() ?? "—")</td>
                                <td>@n.Type</td>
                                <td>@n.Severity</td>
                                <td>@n.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td><button class="btn btn-sm btn-outline-danger bc-del" data-id="@n.Id"><i class="bi bi-trash"></i></button></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
(function() {
    const scopeEl = document.getElementById('bc-scope');
    const orgsWrap = document.getElementById('bc-orgs-wrap');
    scopeEl.addEventListener('change', () => {
        orgsWrap.style.display = scopeEl.value === 'SpecificOrgs' ? '' : 'none';
    });

    document.getElementById('saBroadcastForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const result = document.getElementById('bc-result');
        result.textContent = 'Sending…';
        const selected = Array.from(document.getElementById('bc-orgs').selectedOptions).map(o => parseInt(o.value, 10));
        const body = {
            scope: scopeEl.value,
            organizationIds: selected,
            title: document.getElementById('bc-title').value.trim(),
            body: document.getElementById('bc-body').value.trim(),
            type: document.getElementById('bc-type').value,
            severity: document.getElementById('bc-severity').value,
            link: document.getElementById('bc-link').value.trim() || null,
            expiresAt: document.getElementById('bc-expires').value || null
        };
        try {
            const r = await fetch('/api/superadmin/notifications/broadcast', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            if (!r.ok) { const err = await r.json().catch(() => ({})); throw new Error(err.error || 'Failed'); }
            const data = await r.json();
            result.innerHTML = '<span class="text-success">✓ Broadcast sent (' + data.count + ' row(s)). Reloading…</span>';
            setTimeout(() => location.reload(), 900);
        } catch (err) {
            result.innerHTML = '<span class="text-danger">' + err.message + '</span>';
        }
    });

    document.getElementById('bc-tbody').addEventListener('click', async function(e) {
        const btn = e.target.closest('.bc-del');
        if (!btn) return;
        if (!confirm('Delete this notification?')) return;
        const id = btn.dataset.id;
        const r = await fetch('/api/superadmin/notifications/' + id, { method: 'DELETE', credentials: 'same-origin' });
        if (r.ok) btn.closest('tr').remove();
    });
})();
</script>
