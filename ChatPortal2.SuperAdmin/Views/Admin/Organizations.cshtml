@model List<AIInsights.Models.Organization>
@{
    ViewData["Title"] = "Organizations";
    ViewData["ActivePage"] = "orgs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Organizations</h1>
        <p class="page-desc">@Model.Count registered organizations</p>
    </div>
</div>

<div class="card-panel" style="overflow-x:auto">
    <table class="tbl">
        <thead>
            <tr>
                <th>Name</th>
                <th>Users</th>
                <th>Pro</th>
                <th>Enterprise</th>
                <th>Trial</th>
                <th>Workspaces</th>
                <th>Revenue</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var org in Model)
            {
                var proCount = org.Users?.Count(u => u.Subscription?.Plan == AIInsights.Models.PlanType.Professional) ?? 0;
                var entCount = org.Users?.Count(u => u.Subscription?.Plan == AIInsights.Models.PlanType.Enterprise) ?? 0;
                var trialCount = org.Users?.Count(u => u.Subscription?.IsTrialActive == true) ?? 0;
                var revenue = proCount * AIInsights.Models.PlanPricing.ProPricePerUser
                            + entCount * AIInsights.Models.PlanPricing.EnterprisePricePerUser;
                <tr>
                    <td style="color:#1e3a5f;font-weight:600">@org.Name</td>
                    <td>@(org.Users?.Count ?? 0)</td>
                    <td>
                        @if (proCount > 0)
                        {
                            <span class="badge-sm badge-indigo">@proCount</span>
                        }
                        else { <span style="color:var(--text-muted)">—</span> }
                    </td>
                    <td>
                        @if (entCount > 0)
                        {
                            <span class="badge-sm badge-emerald">@entCount</span>
                        }
                        else { <span style="color:var(--text-muted)">—</span> }
                    </td>
                    <td>
                        @if (trialCount > 0)
                        {
                            <span class="badge-sm badge-amber">@trialCount</span>
                        }
                        else { <span style="color:var(--text-muted)">—</span> }
                    </td>
                    <td>@(org.Workspaces?.Count ?? 0)</td>
                    <td>
                        @if (revenue > 0)
                        {
                            <span class="badge-sm badge-emerald">$@revenue.ToString("N0")/mo</span>
                        }
                        else { <span style="color:var(--text-muted)">$0</span> }
                    </td>
                    <td style="color:var(--text-muted)">@org.CreatedAt.ToString("MMM d, yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
