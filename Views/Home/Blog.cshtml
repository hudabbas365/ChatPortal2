@model List<AIInsights.Models.BlogPost>
@{
    ViewData["Title"] = "Blog";
}

<section class="cp-section cp-page-hero">
    <div class="container">
        <h1 class="page-title">Blog</h1>
        <p class="page-subtitle">Latest updates, tips, and insights from the AIInsights team.</p>
    </div>
</section>

<section class="cp-section">
    <div class="container">
        <div class="row g-4">
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var post in Model)
                {
                    <div class="col-md-4">
                        <div class="blog-card glass-card">
                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <img src="@post.ImageUrl" alt="@post.Title" class="img-fluid rounded mb-3" />
                            }
                            <div class="blog-date">@post.PublishedAt.ToString("MMMM yyyy")</div>
                            <h3 class="blog-title">@post.Title</h3>
                            <p class="blog-excerpt">@post.Summary</p>
                            @if (!string.IsNullOrEmpty(post.Author))
                            {
                                <small class="text-muted">By @post.Author</small>
                            }
                            <a href="/blog/@post.Slug" class="blog-read-more d-block mt-2">Read More <i class="bi bi-arrow-right"></i></a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-md-4">
                    <div class="blog-card glass-card">
                        <div class="blog-date">April 2026</div>
                        <h3 class="blog-title">Introducing 72 Chart Types in AIInsights</h3>
                        <p class="blog-excerpt">We've migrated the full ManageCharts library into AIInsights, giving you access to 72 chart types including treemaps, Sankey diagrams, candlesticks, and more.</p>
                        <a href="#" class="blog-read-more">Read More <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="blog-card glass-card">
                        <div class="blog-date">March 2026</div>
                        <h3 class="blog-title">Cohere AI Integration: Real-time Streaming</h3>
                        <p class="blog-excerpt">AIInsights now uses Cohere's command-a-03-2025 model with real-time SSE streaming for instant AI responses to your data questions.</p>
                        <a href="#" class="blog-read-more">Read More <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="blog-card glass-card">
                        <div class="blog-date">February 2026</div>
                        <h3 class="blog-title">SEO Management &amp; Dynamic Sitemaps</h3>
                        <p class="blog-excerpt">Super Admins can now manage all SEO metadata, canonical URLs, Open Graph tags, and generate dynamic sitemaps from the Admin panel.</p>
                        <a href="#" class="blog-read-more">Read More <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
