<Application x:Class="GatewayApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:GatewayApp.Views"
             xmlns:viewModels="clr-namespace:GatewayApp.ViewModels">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:DatasourcesViewModel}">
                <views:DatasourcesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:DiagnosticsViewModel}">
                <views:DiagnosticsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:RecoveryViewModel}">
                <views:RecoveryView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
