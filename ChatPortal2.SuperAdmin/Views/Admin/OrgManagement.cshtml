@model List<AIInsights.Models.Organization>
@{
    ViewData["Title"] = "Block / Unblock Organizations";
    ViewData["ActivePage"] = "orgmgmt";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h1 class="page-title">Block / Unblock Organizations</h1>
    <p class="page-desc">Manage organization access. Blocked organizations cannot use the platform.</p>
</div>

<div class="card-panel" style="overflow-x:auto">
    <table class="tbl">
        <thead>
            <tr>
                <th>Organization</th>
                <th>Plan</th>
                <th>Status</th>
                <th>Blocked Reason</th>
                <th>Blocked At</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var org in Model)
            {
                <tr id="org-row-@org.Id">
                    <td style="font-weight:600;color:#1e3a5f">@org.Name</td>
                    <td><span class="badge-sm badge-indigo">@org.Plan</span></td>
                    <td>
                        @if (org.IsBlocked)
                        {
                            <span class="badge-sm badge-rose" id="status-@org.Id"><i class="bi bi-lock-fill"></i> Blocked</span>
                        }
                        else
                        {
                            <span class="badge-sm badge-emerald" id="status-@org.Id"><i class="bi bi-unlock-fill"></i> Active</span>
                        }
                    </td>
                    <td id="reason-@org.Id" style="color:var(--text-muted);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@org.BlockedReason">@(org.BlockedReason ?? "—")</td>
                    <td id="blockedat-@org.Id" style="color:var(--text-muted)">@(org.BlockedAt?.ToString("MMM d, yyyy HH:mm") ?? "—")</td>
                    <td>
                        @if (org.IsBlocked)
                        {
                            <button class="btn-primary-sm" onclick="unblockOrg(@org.Id)" id="action-@org.Id">
                                <i class="bi bi-unlock"></i> Unblock
                            </button>
                        }
                        else
                        {
                            <button class="btn-ghost-sm" style="border-color:#ef4444;color:#ef4444" onclick="blockOrg(@org.Id)" id="action-@org.Id">
                                <i class="bi bi-lock"></i> Block
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Block reason modal -->
<div class="modal fade" id="blockModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:12px">
            <div class="modal-header">
                <h5 class="modal-title">Block Organization</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Reason for blocking (optional)</label>
                <textarea id="blockReason" class="form-control" rows="3" placeholder="e.g. Violation of terms of service…"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-ghost-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn-primary-sm" style="background:#ef4444" onclick="confirmBlock()">
                    <i class="bi bi-lock"></i> Confirm Block
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
let pendingBlockId = null;
let blockModalInstance = null;

function blockOrg(id) {
    pendingBlockId = id;
    document.getElementById('blockReason').value = '';
    if (!blockModalInstance) blockModalInstance = new bootstrap.Modal(document.getElementById('blockModal'));
    blockModalInstance.show();
}

async function confirmBlock() {
    if (!pendingBlockId) return;
    const reason = document.getElementById('blockReason').value.trim();
    const r = await fetch('/api/superadmin/orgs/' + pendingBlockId + '/block', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason: reason || null })
    });
    if (!r.ok) { alert('Failed to block organization.'); return; }
    blockModalInstance.hide();
    location.reload();
}

async function unblockOrg(id) {
    if (!confirm('Unblock this organization?')) return;
    const r = await fetch('/api/superadmin/orgs/' + id + '/unblock', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
    });
    if (!r.ok) { alert('Failed to unblock organization.'); return; }
    location.reload();
}
</script>
