@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<!-- Hero Section -->
<section class="cp-hero">
    <div class="container px-4 px-lg-5">
        <div class="row align-items-center g-5">

            <!-- Left column -->
            <div class="col-lg-6">
                <div class="hero-badge mb-3">
                    <i class="bi bi-stars me-2"></i>✦ Trusted by 1,200+ data teams
                </div>
                <h1 class="hero-title">
                    Turn Any Data Into<br/>
                    <span class="hero-highlight">Decisions — Instantly</span>
                </h1>
                <p class="hero-subtitle">
                    AI Insights connects to your SQL databases and Power BI Semantic Models, deploys custom AI agents, and generates beautiful charts in seconds. No SQL. No dashboards. Just answers.
                </p>
                <div class="hero-actions">
                    <a href="/auth/register" class="btn cp-btn-gradient btn-lg">
                        <i class="bi bi-rocket-takeoff me-2"></i>Start Free Trial
                    </a>
                    <a href="/chat" class="btn btn-outline-cp btn-lg">
                        <i class="bi bi-play-circle me-2"></i>Watch 2-min Demo
                    </a>
                </div>
                <!-- Stat row -->
                <div class="hero-stats mb-3">
                    <div class="hero-stat-item">
                        <span class="stat-number">2</span>
                        <span class="stat-label">Datasources (Growing)</span>
                    </div>
                    <div class="hero-stat-divider"></div>
                    <div class="hero-stat-item">
                        <span class="stat-number">72+</span>
                        <span class="stat-label">Chart Types</span>
                    </div>
                    <div class="hero-stat-divider"></div>
                    <div class="hero-stat-item">
                        <span class="stat-number">10×</span>
                        <span class="stat-label">Faster insights</span>
                    </div>
                </div>
                <!-- Trust badges -->
                <div class="hero-trust">
                    <span class="trust-item"><i class="bi bi-shield-check me-1"></i>GDPR Compliant</span>
                    <span class="trust-item"><i class="bi bi-clock me-1"></i>30-day Free Trial</span>
                    <span class="trust-item"><i class="bi bi-credit-card me-1"></i>No Credit Card</span>
                    <span class="trust-item"><i class="bi bi-patch-check me-1"></i>SOC 2 Ready</span>
                </div>
            </div>

            <!-- Right column — AI Insights Panel -->
            <div class="col-lg-6">
                <div class="hero-insights-panel">

                    <!-- Ask Anything bar -->
                    <div class="hero-ask-bar">
                        <i class="bi bi-search text-muted me-2"></i>
                        <span class="hero-ask-placeholder">Ask your data anything…</span>
                        <button class="btn cp-btn-gradient hero-ask-send">Send</button>
                    </div>
                    <div class="hero-quick-chips">
                        <button class="hero-chip"><i class="bi bi-graph-up me-1"></i>Top revenue this month</button>
                        <button class="hero-chip"><i class="bi bi-person-x me-1"></i>Churn risk users</button>
                    </div>

                    <!-- Metrics grid (2×2) -->
                    <div class="hero-metrics-grid">
                        <div class="hero-metric-card glass-card">
                            <i class="bi bi-graph-up-arrow metric-icon" style="color:var(--cp-primary)"></i>
                            <div class="metric-value">$2.4M</div>
                            <div class="metric-label">Total Revenue</div>
                            <span class="metric-trend up"><i class="bi bi-arrow-up-short"></i>13.3% vs last qtr</span>
                        </div>
                        <div class="hero-metric-card glass-card">
                            <i class="bi bi-people-fill metric-icon" style="color:var(--cp-accent)"></i>
                            <div class="metric-value">18,420</div>
                            <div class="metric-label">Active Users</div>
                            <span class="metric-trend up"><i class="bi bi-arrow-up-short"></i>9.7% this month</span>
                        </div>
                        <div class="hero-metric-card glass-card">
                            <i class="bi bi-lightning-charge-fill metric-icon" style="color:var(--cp-orange)"></i>
                            <div class="metric-value">0.8s</div>
                            <div class="metric-label">Avg Query Time</div>
                            <span class="metric-trend down"><i class="bi bi-arrow-down-short"></i>62% faster</span>
                        </div>
                        <div class="hero-metric-card glass-card">
                            <i class="bi bi-bar-chart-fill metric-icon" style="color:var(--cp-purple)"></i>
                            <div class="metric-value">72</div>
                            <div class="metric-label">Chart Types</div>
                            <span class="metric-trend up"><i class="bi bi-plus"></i>Sankey · Treemap · +70</span>
                        </div>
                    </div>

                    <!-- Live AI response strip -->
                    <div class="hero-ai-strip">
                        <div class="hero-ai-msg">
                            🤖 <strong>AI Insight</strong>: <em>"North region leads $145K (+13%), East $101K (+9.7%). Recommend reallocating 15% budget from South → North for Q3 max ROI."</em>
                        </div>
                        <div class="hero-ai-footer">Generated in 0.4s · Powered by GPT-4</div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>

<!-- Features Section -->
<section class="cp-section cp-features">
    <div class="container">
        <div class="section-header text-center mb-5">
            <h2 class="section-title">Everything You Need</h2>
            <p class="section-subtitle">A complete analytics platform powered by AI</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="bi bi-database-fill-gear"></i>
                    </div>
                    <h3 class="feature-title">Growing Datasource Library</h3>
                    <p class="feature-desc">Currently supporting SQL Server Online and Power BI Semantic Models, with 15+ additional connectors launching next month.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="bi bi-robot"></i>
                    </div>
                    <h3 class="feature-title">AI Agents</h3>
                    <p class="feature-desc">Create custom AI agents with specific knowledge, system prompts, and datasource connections. Chat naturally.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="bi bi-bar-chart-line-fill"></i>
                    </div>
                    <h3 class="feature-title">72+ Chart Types</h3>
                    <p class="feature-desc">From basic bar charts to Sankey diagrams, candlesticks, treemaps, and more. Drag-and-drop report designer.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How to Use AI Insights — User Guide -->
<section class="cp-section cp-how-to" id="how-to">
    <div class="container">
        <div class="section-header text-center mb-5">
            <h2 class="section-title">How to Use AI Insights</h2>
            <p class="section-subtitle">Get started in 4 simple steps — no technical knowledge required</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="howto-card glass-card">
                    <div class="howto-step-num">1</div>
                    <div class="howto-icon"><i class="bi bi-folder-plus"></i></div>
                    <h4 class="howto-title">Create a Workspace</h4>
                    <p class="howto-desc">Click <strong>+ New Workspace</strong> in the left panel and give it a name. A workspace is your project space where everything lives.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="howto-card glass-card">
                    <div class="howto-step-num">2</div>
                    <div class="howto-icon"><i class="bi bi-database-add"></i></div>
                    <h4 class="howto-title">Connect Your Data</h4>
                    <p class="howto-desc">Follow the guided wizard to connect a data source. Just paste your connection details — we'll handle the rest.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="howto-card glass-card">
                    <div class="howto-step-num">3</div>
                    <div class="howto-icon"><i class="bi bi-chat-dots"></i></div>
                    <h4 class="howto-title">Ask Questions</h4>
                    <p class="howto-desc">Click on your AI Agent and start chatting. Ask things like <em>"What were our top sales last month?"</em> — the AI understands plain English.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="howto-card glass-card">
                    <div class="howto-step-num">4</div>
                    <div class="howto-icon"><i class="bi bi-bar-chart-line"></i></div>
                    <h4 class="howto-title">View & Share Reports</h4>
                    <p class="howto-desc">Charts and insights are created automatically. Open the Dashboard to drag, resize, and save reports — then share them with your team.</p>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-lg-8 mx-auto">
                <div class="howto-tips glass-card">
                    <h5><i class="bi bi-lightbulb me-2"></i>Tips for Best Results</h5>
                    <ul class="howto-tips-list">
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>Ask clear, specific questions — e.g. <em>"Show me revenue by region this quarter"</em></li>
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>Use the <strong>suggestion chips</strong> that appear below the chat for quick ideas</li>
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>Click <strong>"Add to Dashboard"</strong> on any chart to save it to your report</li>
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>Invite team members from <strong>Settings → Users</strong> so everyone can explore the data</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works / Integration Showcase -->
<section class="cp-section cp-pricing-preview" id="integrations">
    <div class="container">
        <div class="section-header text-center mb-5">
            <h2 class="section-title">How It Works with Your Current Stack</h2>
            <p class="section-subtitle">Connect today with SQL Online Service and Power BI Semantic Model</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-md-6">
                <div class="pricing-card glass-card h-100">
                    <div class="pricing-tier"><i class="bi bi-database-fill-check me-2"></i>SQL Online Service</div>
                    <p class="feature-desc mb-2">Connect your SQL Server and online SQL databases in minutes. Ask plain-English questions and get instant charts from live operational data.</p>
                    <ul class="pricing-features mb-0">
                        <li><i class="bi bi-check-circle-fill me-2"></i>Use existing schemas and tables</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Secure read-only query execution</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Fast chart generation from SQL data</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-6">
                <div class="pricing-card glass-card h-100">
                    <div class="pricing-tier"><i class="bi bi-pie-chart-fill me-2"></i>Power BI Semantic Model</div>
                    <p class="feature-desc mb-2">Connect to your Power BI datasets and semantic models so teams can explore trusted metrics through conversational analytics.</p>
                    <ul class="pricing-features mb-0">
                        <li><i class="bi bi-check-circle-fill me-2"></i>Use existing business logic and measures</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Query curated datasets with AI</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Share report-ready visuals quickly</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <div class="glass-card d-inline-block px-4 py-3">
                <i class="bi bi-clock-history me-2 text-primary"></i>
                <strong>Coming Soon:</strong> 15+ additional data sources next month (MySQL, PostgreSQL, Snowflake, BigQuery, MongoDB, REST APIs, and more).
            </div>
        </div>
    </div>
</section>
