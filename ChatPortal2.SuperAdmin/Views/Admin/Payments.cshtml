@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Payments";
    ViewData["ActivePage"] = "payments";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="fw-bold mb-4"><i class="bi bi-credit-card me-2 text-primary"></i>Payments</h2>

<div class="sa-card">
    <h6 class="text-muted mb-3">Users with Payment Methods on File</h6>
    <table class="sa-table">
        <thead>
            <tr>
                <th>User</th>
                <th>Email</th>
                <th>Card Brand</th>
                <th>Last 4</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td><span class="sa-badge sa-badge-blue">@user.CardBrand</span></td>
                    <td>****@user.CardLast4</td>
                </tr>
            }
        </tbody>
    </table>
</div>
