@{
    ViewData["Title"] = "Token Usage";
    ViewData["ActivePage"] = "token-usage";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var range  = ViewBag.Range  as string ?? "30d";
    var orgId  = ViewBag.OrgId  as int?;
    var userId = ViewBag.UserId as string;
}

<style>
    .kpi-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:1rem; margin-bottom:1.5rem; }
    .filter-row { display:flex;gap:.75rem;flex-wrap:wrap;align-items:flex-end; }
    .filter-label { font-size:.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.25rem }
    .cp-select { border:1px solid var(--border);border-radius:8px;padding:.4rem .7rem;font-size:.84rem;
                 font-family:inherit;outline:none;background:var(--surface);color:var(--text) }
    .cp-input  { border:1px solid var(--border);border-radius:8px;padding:.4rem .7rem;font-size:.84rem;
                 font-family:inherit;outline:none;background:var(--surface);color:var(--text) }
    .chart-wrap { position:relative; height:260px; }
    .two-col { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
    @@media (max-width:768px) { .two-col { grid-template-columns:1fr; } }
</style>

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title">Token Usage Dashboard</h1>
        <p class="page-desc">AI token consumption across orgs, users, and models.</p>
    </div>
    <a href="@Url.Action("TokenUsageExport", "Insights", new { range = range, orgId = orgId, userId = userId })"
       class="btn-ghost-sm"><i class="bi bi-download"></i>Export CSV</a>
</div>

<!-- Filters -->
<div class="card-panel" style="margin-bottom:1rem">
    <form method="get" action="/superadmin/insights/token-usage" class="filter-row">
        <div>
            <div class="filter-label">Range</div>
            <select name="range" class="cp-select" onchange="this.form.submit()">
                @{ var r7d = range == "7d"; var r30d = range == "30d"; var r90d = range == "90d"; var rYtd = range == "ytd"; }
                @if (r7d) { <option value="7d" selected>Last 7 Days</option> } else { <option value="7d">Last 7 Days</option> }
                @if (r30d) { <option value="30d" selected>Last 30 Days</option> } else { <option value="30d">Last 30 Days</option> }
                @if (r90d) { <option value="90d" selected>Last 90 Days</option> } else { <option value="90d">Last 90 Days</option> }
                @if (rYtd) { <option value="ytd" selected>Year to Date</option> } else { <option value="ytd">Year to Date</option> }
            </select>
        </div>
        <div>
            <div class="filter-label">Organization</div>
            <select name="orgId" class="cp-select" onchange="this.form.submit()">
                @if (!orgId.HasValue) { <option value="" selected>All Orgs</option> } else { <option value="">All Orgs</option> }
                @if (ViewBag.Orgs != null)
                {
                    foreach (var o in ViewBag.Orgs)
                    {
                        int oId = o.Id;
                        string oName = o.Name;
                        if (orgId.HasValue && orgId.Value == oId)
                        { <option value="@oId" selected>@oName</option> }
                        else { <option value="@oId">@oName</option> }
                    }
                }
            </select>
        </div>
        <div>
            <div class="filter-label">User ID</div>
            <input type="text" name="userId" value="@userId" placeholder="Filter by user ID…" class="cp-input" style="width:200px" />
        </div>
        <button type="submit" class="btn-primary-sm" style="margin-top:auto"><i class="bi bi-filter"></i>Apply</button>
        <a href="/superadmin/insights/token-usage" class="btn-ghost-sm" style="margin-top:auto">Clear</a>
    </form>
</div>

<!-- KPI cards (populated by JS) -->
<div class="kpi-grid" id="kpiGrid">
    @foreach (var label in new[] { "Total Tokens", "Prompt Tokens (est.)", "Completion Tokens (est.)", "Est. Cost (USD)" })
    {
        var kpiId = "kpi" + label.Replace(" ", "").Replace(".", "").Replace("(", "").Replace(")", "");
        <div class="stat">
            <div class="stat-icon" style="background:rgba(74,142,201,.1);color:#4a8ec9"><i class="bi bi-cpu"></i></div>
            <div class="stat-val" id="@kpiId">—</div>
            <div class="stat-label">@label</div>
        </div>
    }
</div>

<!-- Daily chart -->
<div class="card-panel" style="margin-bottom:1rem">
    <div class="card-panel-title">Daily Token Consumption</div>
    <div class="chart-wrap"><canvas id="dailyChart"></canvas></div>
</div>

<!-- Top tables + donut -->
<div class="two-col" style="margin-bottom:1rem">
    <div class="card-panel">
        <div class="card-panel-title">Top 10 Organizations</div>
        <table class="tbl" id="topOrgsTable">
            <thead><tr><th>Organization</th><th>Tokens</th><th>Cost</th></tr></thead>
            <tbody><tr><td colspan="3" style="text-align:center;color:var(--text-muted)">Loading…</td></tr></tbody>
        </table>
    </div>
    <div class="card-panel">
        <div class="card-panel-title">Top 10 Users</div>
        <table class="tbl" id="topUsersTable">
            <thead><tr><th>User</th><th>Tokens</th><th>Cost</th></tr></thead>
            <tbody><tr><td colspan="3" style="text-align:center;color:var(--text-muted)">Loading…</td></tr></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function() {
    const range  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(range));
    const orgId  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(orgId.HasValue ? orgId.Value.ToString() : ""));
    const userId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(userId ?? ""));
    let qs = '?range=' + range;
    if (orgId)  qs += '&orgId='  + orgId;
    if (userId) qs += '&userId=' + userId;

    fetch('/api/superadmin/insights/token-usage' + qs, { credentials: 'same-origin' })
        .then(async r => {
            if (!r.ok) {
                const text = await r.text().catch(() => '');
                throw new Error('HTTP ' + r.status + (text ? ' — ' + text.substring(0, 300) : ''));
            }
            return r.json();
        })
        .then(data => {
            // KPIs
            const fmtNum = n => n >= 1e6 ? (n/1e6).toFixed(1) + 'M' : n >= 1e3 ? (n/1e3).toFixed(0) + 'K' : n;
            document.getElementById('kpiTotalTokens').textContent          = fmtNum(data.totals.totalTokens);
            document.getElementById('kpiPromptTokensest').textContent      = fmtNum(data.totals.promptTokens);
            document.getElementById('kpiCompletionTokensest').textContent  = fmtNum(data.totals.completionTokens);
            document.getElementById('kpiEstCostUSD').textContent           = '$' + data.totals.estimatedCost.toFixed(2);

            // Daily chart
            const ctx = document.getElementById('dailyChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.daily.map(d => d.date),
                    datasets: [{
                        label: 'Tokens',
                        data: data.daily.map(d => d.tokens),
                        backgroundColor: 'rgba(74,142,201,.65)',
                        yAxisID: 'y'
                    }, {
                        label: 'Cost ($)',
                        data: data.daily.map(d => d.cost),
                        type: 'line',
                        borderColor: '#f59e0b',
                        backgroundColor: 'rgba(245,158,11,.1)',
                        tension: 0.3,
                        yAxisID: 'y1',
                        fill: true
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    scales: {
                        y:  { type:'linear', position:'left',  title:{ display:true, text:'Tokens' }, beginAtZero:true },
                        y1: { type:'linear', position:'right', title:{ display:true, text:'Cost ($)' }, beginAtZero:true, grid:{ drawOnChartArea:false } }
                    },
                    plugins: { legend:{ position:'bottom' } }
                }
            });

            // Top orgs table
            const orgTbody = document.querySelector('#topOrgsTable tbody');
            while (orgTbody.firstChild) orgTbody.removeChild(orgTbody.firstChild);
            if (!data.topOrgs.length) {
                const tr = orgTbody.insertRow(); const td = tr.insertCell();
                td.colSpan = 3; td.style.cssText = 'text-align:center;color:var(--text-muted)';
                td.textContent = 'No data.';
            } else {
                data.topOrgs.forEach(o => {
                    const tr = orgTbody.insertRow();
                    const c0 = tr.insertCell(); c0.style.cssText = 'font-weight:500;color:#1e3a5f'; c0.textContent = o.orgName;
                    const c1 = tr.insertCell(); c1.textContent = fmtNum(o.tokens);
                    const c2 = tr.insertCell(); c2.textContent = '$' + o.cost.toFixed(2);
                });
            }

            // Top users table
            const userTbody = document.querySelector('#topUsersTable tbody');
            while (userTbody.firstChild) userTbody.removeChild(userTbody.firstChild);
            if (!data.topUsers.length) {
                const tr = userTbody.insertRow(); const td = tr.insertCell();
                td.colSpan = 3; td.style.cssText = 'text-align:center;color:var(--text-muted)';
                td.textContent = 'No data.';
            } else {
                data.topUsers.forEach(u => {
                    const tr = userTbody.insertRow();
                    const c0 = tr.insertCell(); c0.style.cssText = 'font-size:.82rem;color:#1e3a5f';
                    const a = document.createElement('a');
                    a.href = '/superadmin/users/' + encodeURIComponent(u.userId) + '/timeline';
                    a.style.cssText = 'color:var(--primary);text-decoration:none';
                    a.textContent = u.userEmail;
                    c0.appendChild(a);
                    const c1 = tr.insertCell(); c1.textContent = fmtNum(u.tokens);
                    const c2 = tr.insertCell(); c2.textContent = '$' + u.cost.toFixed(2);
                });
            }
        })
        .catch(err => {
            console.error('Failed to load token usage data:', err);
            const setMsg = (id, msg) => { const el = document.getElementById(id); if (el) el.textContent = msg; };
            setMsg('kpiTotalTokens', '—');
            setMsg('kpiPromptTokensest', '—');
            setMsg('kpiCompletionTokensest', '—');
            setMsg('kpiEstCostUSD', '—');
            const errBanner = document.createElement('div');
            errBanner.className = 'card-panel';
            errBanner.style.cssText = 'background:#fff5f5;border:1px solid #fca5a5;color:#b91c1c;margin-bottom:1rem';
            errBanner.textContent = 'Failed to load token usage data: ' + (err && err.message ? err.message : 'Unknown error');
            const grid = document.getElementById('kpiGrid');
            if (grid && grid.parentNode) grid.parentNode.insertBefore(errBanner, grid);
            ['#topOrgsTable tbody', '#topUsersTable tbody'].forEach(sel => {
                const tbody = document.querySelector(sel);
                if (!tbody) return;
                while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
                const tr = tbody.insertRow(); const td = tr.insertCell();
                td.colSpan = 3; td.style.cssText = 'text-align:center;color:#b91c1c';
                td.textContent = 'Error loading data.';
            });
        });
})();
</script>
}
