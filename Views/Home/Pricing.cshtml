@{
    ViewData["Title"] = "Pricing";
}

<section class="cp-section cp-page-hero">
    <div class="container text-center">
        <h1 class="page-title">Pricing Plans</h1>
        <p class="page-subtitle">Choose the plan that fits your needs. Start with a 30-day free trial — no credit card required.</p>
    </div>
</section>

<section class="cp-section">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-md-3">
                <div class="pricing-card glass-card text-center">
                    <div class="pricing-tier">Free</div>
                    <div class="pricing-price">$0 <span class="pricing-period">forever</span></div>
                    <ul class="pricing-features">
                        <li><i class="bi bi-check-circle-fill me-2"></i>1 Workspace</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>1 AI Agent</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>50 messages/mo</li>
                        <li><i class="bi bi-x-circle me-2 text-muted"></i>Export</li>
                    </ul>
                    <a href="/auth/register" class="btn btn-outline-cp w-100">Get Started Free</a>
                </div>
            </div>
            <div class="col-md-3">
                <div class="pricing-card glass-card text-center">
                    <div class="pricing-tier">Free Trial</div>
                    <div class="pricing-price">$0 <span class="pricing-period">/ 30 days</span></div>
                    <ul class="pricing-features">
                        <li><i class="bi bi-check-circle-fill me-2"></i>10 Workspaces</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>5 AI Agents</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>1,000 messages</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Export</li>
                    </ul>
                    <button class="btn cp-btn-gradient w-100" id="startTrialBtn">Start 30-Day Free Trial</button>
                </div>
            </div>
            <div class="col-md-3">
                <div class="pricing-card glass-card pricing-featured text-center">
                    <div class="pricing-badge">Popular</div>
                    <div class="pricing-tier">Professional</div>
                    <div class="pricing-price">$49 <span class="pricing-period">/ month</span></div>
                    <ul class="pricing-features">
                        <li><i class="bi bi-check-circle-fill me-2"></i>50 Workspaces</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>20 AI Agents</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>10,000 messages</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Export + API</li>
                    </ul>
                    <a href="/auth/register" class="btn cp-btn-gradient w-100">Get Professional</a>
                </div>
            </div>
            <div class="col-md-3">
                <div class="pricing-card glass-card text-center">
                    <div class="pricing-tier">Enterprise</div>
                    <div class="pricing-price">Custom</div>
                    <ul class="pricing-features">
                        <li><i class="bi bi-check-circle-fill me-2"></i>Unlimited</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>SSO / SAML</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>Dedicated support</li>
                        <li><i class="bi bi-check-circle-fill me-2"></i>On-premise</li>
                    </ul>
                    <a href="mailto:sales@chatportal2.com" class="btn btn-outline-cp w-100">Contact Sales</a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
document.getElementById('startTrialBtn')?.addEventListener('click', function() {
    const user = JSON.parse(localStorage.getItem('cp_user') || 'null');
    if (!user) { window.location.href = '/auth/register'; return; }
    $.post('/api/subscription/activate-trial', JSON.stringify({ userId: user.id }), function(r) {
        alert('Trial activated! You have ' + r.daysRemaining + ' days remaining.');
    }, 'json').fail(function(e) {
        alert(e.responseJSON?.error || 'Could not activate trial.');
    });
});
</script>
}
