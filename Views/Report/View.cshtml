@{
    ViewData["Title"] = ViewBag.ReportName ?? "Report";
    Layout = null;
    var reportName = ViewBag.ReportName as string ?? "Report";
    var canvasJson = ViewBag.CanvasJson as string ?? "{}";
    var workspaceName = ViewBag.WorkspaceName as string;
    var workspaceGuid = ViewBag.WorkspaceGuid as string;
    var datasourceName = ViewBag.DatasourceName as string;
    var agentName = ViewBag.AgentName as string;
    var datasourceId = ViewBag.DatasourceId as int?;
    var status = ViewBag.Status as string ?? "Draft";
    var reportGuid = ViewBag.ReportGuid as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@reportName — ChatPortal2 Report</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dashboard-shapes.css" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <style>
        body { background: var(--cp-bg, #f0f2f5); font-family: 'Inter', sans-serif; margin: 0; }

        /* ── Navbar ────────────────────────────────────── */
        .rv-navbar {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 20px; background: var(--cp-surface, #fff);
            border-bottom: 1px solid var(--cp-border, #e2e8f0);
            box-shadow: var(--cp-shadow-sm, 0 1px 3px rgba(0,0,0,0.04));
        }
        .rv-brand { display: flex; align-items: center; gap: 8px; text-decoration: none; color: inherit; }
        .rv-brand:hover { color: var(--cp-primary, #4A90D9); }
        .rv-brand-text { font-weight: 700; font-size: 0.95rem; }

        /* ── Breadcrumbs ──────────────────────────────── */
        .rv-breadcrumb {
            display: flex; align-items: center; gap: 6px;
            margin-left: 12px; font-size: 0.88rem;
        }
        .rv-breadcrumb a { color: var(--cp-primary, #4A90D9); text-decoration: none; font-weight: 500; }
        .rv-breadcrumb a:hover { text-decoration: underline; }
        .rv-breadcrumb .rv-sep { color: var(--cp-border, #cbd5e1); font-size: 0.7rem; }
        .rv-breadcrumb .rv-current { font-weight: 600; color: var(--cp-text, #1e293b); }
        .rv-badge { font-size: 0.68rem; padding: 2px 8px; border-radius: 10px; font-weight: 600; }
        .rv-badge-published { background: var(--cp-success-light, #d1fae5); color: var(--cp-success, #065f46); }
        .rv-badge-draft { background: var(--cp-orange-light, #fef3c7); color: var(--cp-orange, #92400e); }
        .rv-meta { display: flex; align-items: center; gap: 14px; font-size: 0.78rem; color: var(--cp-text-muted, #64748b); }
        .rv-meta i { font-size: 0.72rem; }

        /* ── Toolbar ──────────────────────────────────── */
        .rv-toolbar {
            margin-left: auto; display: flex; align-items: center; gap: 8px;
        }
        .rv-toolbar .btn {
            display: inline-flex; align-items: center; gap: 5px;
            font-size: 0.78rem; padding: 5px 12px; border-radius: var(--cp-radius, 6px);
            font-weight: 500; border: 1px solid var(--cp-border, #e2e8f0);
            background: var(--cp-surface, #fff); color: var(--cp-text, #475569);
            cursor: pointer; transition: var(--cp-transition, all 0.15s);
            text-decoration: none;
        }
        .rv-toolbar .btn:hover { background: var(--cp-bg, #f1f5f9); border-color: var(--cp-border, #cbd5e1); }
        .rv-toolbar .btn i { font-size: 0.82rem; }
        .rv-toolbar .btn-primary-rv {
            background: var(--cp-gradient, #4A90D9); color: #fff; border-color: var(--cp-primary, #4A90D9);
        }
        .rv-toolbar .btn-primary-rv:hover { opacity: 0.9; }

        /* ── Share modal ──────────────────────────────── */
        .rv-share-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.4); z-index: 9999;
            align-items: center; justify-content: center;
        }
        .rv-share-overlay.active { display: flex; }
        .rv-share-box {
            background: var(--cp-surface, #fff); border-radius: var(--cp-radius, 10px);
            padding: 24px 28px; box-shadow: var(--cp-shadow, 0 8px 30px rgba(0,0,0,0.15));
            width: 420px; max-width: 90vw;
        }
        .rv-share-box h5 { font-size: 0.95rem; font-weight: 600; margin-bottom: 12px; }
        .rv-share-url { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
        .rv-share-url input {
            flex: 1; font-size: 0.8rem; padding: 7px 10px;
            border: 1px solid var(--cp-border, #e2e8f0); border-radius: 6px;
            background: var(--cp-bg, #f8fafc); color: var(--cp-text, #334155);
        }
        .rv-share-url button {
            font-size: 0.78rem; padding: 7px 14px; border-radius: 6px;
            border: 1px solid var(--cp-primary, #4A90D9); background: var(--cp-primary, #4A90D9);
            color: #fff; cursor: pointer; white-space: nowrap; font-weight: 500;
        }
        .rv-share-url button:hover { opacity: 0.9; }
        .rv-share-note { font-size: 0.72rem; color: var(--cp-text-muted, #94a3b8); margin-bottom: 8px; }
        .rv-share-close {
            font-size: 0.78rem; padding: 5px 14px; border-radius: 6px;
            border: 1px solid var(--cp-border, #e2e8f0); background: var(--cp-surface, #fff);
            color: var(--cp-text, #475569); cursor: pointer; float: right;
        }

        /* ── Canvas layout ────────────────────────────── */
        .rv-canvas-wrap { max-width: 1200px; margin: 24px auto; padding: 0 16px; }
        .rv-page {
            background: var(--cp-surface, #fff); border-radius: var(--cp-radius, 8px);
            box-shadow: var(--cp-shadow-sm, 0 1px 4px rgba(0,0,0,0.06));
            margin-bottom: 24px; padding: 16px;
            position: relative; min-height: 400px; overflow: hidden;
        }
        .rv-page-title {
            font-size: 0.78rem; font-weight: 600; color: var(--cp-text-muted, #94a3b8);
            margin-bottom: 12px; padding-bottom: 6px;
            border-bottom: 1px solid var(--cp-border, #f1f5f9);
        }

        /* ── Chart cards: reuse dashboard .chart-card from site.css, read-only overrides ── */
        .rv-page .chart-card {
            cursor: default;
            overflow: hidden;
        }
        .rv-page .chart-card:hover {
            border-color: var(--cp-primary-light);
            transform: none;
        }
        .rv-page .chart-card .chart-card-actions,
        .rv-page .chart-card .chart-drag-handle,
        .rv-page .chart-card .chart-resize-handle,
        .rv-page .chart-card .shape-hover-actions {
            display: none !important;
        }
        .rv-page .chart-card.shape-card { cursor: default; }
        .rv-page .chart-card.shape-card:hover { border-color: transparent; }
        .rv-page .chart-canvas-wrap canvas { width: 100% !important; height: 100% !important; }

        /* ── Empty & export states ─────────────────────── */
        .rv-empty { text-align: center; padding: 60px 20px; color: var(--cp-text-muted, #94a3b8); }
        .rv-empty i { font-size: 2.5rem; margin-bottom: 12px; display: block; }
        .rv-export-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.4); z-index: 9999;
            align-items: center; justify-content: center;
        }
        .rv-export-overlay.active { display: flex; }
        .rv-export-box {
            background: var(--cp-surface, #fff); border-radius: var(--cp-radius, 10px);
            padding: 30px 40px; text-align: center;
            box-shadow: var(--cp-shadow, 0 8px 30px rgba(0,0,0,0.15));
        }
        .rv-export-box .spinner-border { width: 2rem; height: 2rem; margin-bottom: 12px; }
        .rv-export-box p { margin: 0; font-size: 0.9rem; color: var(--cp-text, #475569); }

        @@media print {
            body { background: #fff !important; }
            .rv-navbar, .rv-toolbar, .rv-export-overlay, .rv-share-overlay { display: none !important; }
            .rv-canvas-wrap { margin: 0; padding: 0; max-width: 100%; }
            .rv-page {
                box-shadow: none; border: none;
                page-break-inside: avoid; break-inside: avoid;
                margin-bottom: 0;
            }
        }
    </style>
</head>
<body>
    <nav class="rv-navbar">
        <a href="/" class="rv-brand">
            <i class="bi bi-bar-chart-fill text-primary"></i>
            <span class="rv-brand-text">ChatPortal2</span>
        </a>
        <div class="rv-breadcrumb">
            <span class="rv-sep"><i class="bi bi-chevron-right"></i></span>
            @if (!string.IsNullOrEmpty(workspaceGuid) && !string.IsNullOrEmpty(workspaceName))
            {
                <a href="/chat?workspace=@workspaceGuid">@workspaceName</a>
                <span class="rv-sep"><i class="bi bi-chevron-right"></i></span>
            }
            <span class="rv-current">@reportName</span>
            <span class="rv-badge @(status == "Published" ? "rv-badge-published" : "rv-badge-draft")">@status</span>
        </div>
        <div class="rv-meta" style="margin-left: 16px;">
            @if (!string.IsNullOrEmpty(datasourceName))
            {
                <span><i class="bi bi-database-fill me-1"></i>@datasourceName</span>
            }
            @if (!string.IsNullOrEmpty(agentName))
            {
                <span><i class="bi bi-robot me-1"></i>@agentName</span>
            }
        </div>
        <div class="rv-toolbar">
            @if (!string.IsNullOrEmpty(workspaceGuid))
            {
                <a class="btn" href="/chat?workspace=@workspaceGuid" title="Back to Workspace">
                    <i class="bi bi-arrow-left"></i> Workspace
                </a>
                <a class="btn" href="/dashboard?workspace=@workspaceGuid&report=@reportGuid" title="Edit in Dashboard">
                    <i class="bi bi-pencil-square"></i> Edit
                </a>
            }
            <button class="btn" onclick="openShareModal()" title="Share Report">
                <i class="bi bi-share"></i> Share
            </button>
            <button class="btn" onclick="window.print()" title="Print Report">
                <i class="bi bi-printer"></i> Print
            </button>
            <button class="btn btn-primary-rv" onclick="exportPDF()" title="Export as PDF">
                <i class="bi bi-file-earmark-pdf"></i> Export PDF
            </button>
        </div>
    </nav>

    <div class="rv-share-overlay" id="rvShareOverlay" onclick="if(event.target===this)closeShareModal()">
        <div class="rv-share-box">
            <h5><i class="bi bi-people me-2"></i>Share Internally</h5>
            <p style="font-size:0.82rem;color:#475569;margin-bottom:14px;">
                This report is shared with all members of <strong id="rvShareWsName">this workspace</strong>.
                Public sharing via URL is not permitted.
            </p>
            <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:6px;padding:10px 14px;font-size:0.78rem;color:#0369a1;margin-bottom:14px;">
                <i class="bi bi-shield-lock-fill me-1"></i>
                Only workspace members can access this report. No public link is available.
            </div>
            <button class="rv-share-close" onclick="closeShareModal()">Close</button>
        </div>
    </div>

    <div class="rv-export-overlay" id="rvExportOverlay">
        <div class="rv-export-box">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Generating PDF…</p>
        </div>
    </div>

    <div class="rv-canvas-wrap" id="rvCanvasWrap">
        <div class="rv-empty" id="rvEmpty" style="display:none">
            <i class="bi bi-bar-chart"></i>
            <p>This report has no charts.</p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="~/js/chartRenderer.js"></script>
    <script src="~/js/shapeManager.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
    <script>
    (function() {
        'use strict';

        const canvasJson = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(canvasJson));
        const datasourceId = @Html.Raw(datasourceId.HasValue ? datasourceId.Value.ToString() : "null");
        const wrap = document.getElementById('rvCanvasWrap');

        // Set global datasource context so chartRenderer can fetch real data
        if (datasourceId) window.currentDatasourceId = datasourceId;
        @if (ViewBag.DatasourceType != null)
        {
            <text>window.currentDatasourceType = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.DatasourceType));</text>
        }

        let parsed;
        try { parsed = JSON.parse(canvasJson); } catch { parsed = {}; }

        const pages = parsed.pages || [];
        if (!pages.length) {
            document.getElementById('rvEmpty').style.display = '';
            return;
        }

        // Match dashboard colsToPixels calculation
        function colsToPixels(width) {
            const baseWidth = Math.min(1200 - 32, 900);
            const pct = (parseInt(width) || 6) / 12;
            return Math.round(Math.max(200, baseWidth * pct));
        }

        pages.forEach((page, pi) => {
            const charts = page.charts || [];
            if (!charts.length) return;

            const pageEl = document.createElement('div');
            pageEl.className = 'rv-page';
            pageEl.style.position = 'relative';
            if (page.background) pageEl.style.background = page.background;

            if (pages.length > 1) {
                const title = document.createElement('div');
                title.className = 'rv-page-title';
                title.textContent = page.name || ('Page ' + (pi + 1));
                pageEl.appendChild(title);
            }

            // Calculate page height from chart positions
            let maxBottom = 400;
            charts.forEach(c => {
                const cardHeight = c.height || 300;
                const bottom = (c.posY || 0) + cardHeight + 20;
                if (bottom > maxBottom) maxBottom = bottom;
            });
            pageEl.style.minHeight = maxBottom + 'px';

            charts.forEach(c => {
                const isShape = window.ShapeManager && ShapeManager.isShape(c.chartType);
                const cardWidth = colsToPixels(c.width || 6);
                const cardHeight = c.height || 300;
                const posX = c.posX || 0;
                const posY = c.posY || 0;
                const zIdx = c.zIndex || 1;

                // Build card using the same .chart-card classes as the Dashboard
                const card = document.createElement('div');
                card.className = 'chart-card' + (isShape ? ' shape-card' : '');
                card.style.cssText = 'left:' + posX + 'px;top:' + posY + 'px;width:' + cardWidth + 'px;z-index:' + zIdx + ';';

                if (isShape) {
                    // Shape: render SVG via ShapeManager (same as dashboard)
                    const canvasWrap = document.createElement('div');
                    canvasWrap.className = 'chart-canvas-wrap';
                    canvasWrap.style.height = cardHeight + 'px';
                    card.appendChild(canvasWrap);
                    pageEl.appendChild(card);
                    requestAnimationFrame(() => ShapeManager.render(canvasWrap, c));
                } else {
                    // Chart: add header + canvas, render with chartRenderer (same engine as dashboard)
                    const header = document.createElement('div');
                    header.className = 'chart-card-header';
                    const titleSpan = document.createElement('span');
                    titleSpan.className = 'chart-title';
                    titleSpan.textContent = c.title || c.chartType || 'Chart';
                    header.appendChild(titleSpan);
                    card.appendChild(header);

                    const canvasWrap = document.createElement('div');
                    canvasWrap.className = 'chart-canvas-wrap';
                    canvasWrap.style.height = (cardHeight - 36) + 'px';
                    const canvas = document.createElement('canvas');
                    canvasWrap.appendChild(canvas);
                    card.appendChild(canvasWrap);
                    pageEl.appendChild(card);

                    // Ensure datasource context on chart definition
                    if (!c.datasourceId && datasourceId) c.datasourceId = datasourceId;

                    // Render using the same engine as the Dashboard
                    if (window.chartRenderer) {
                        requestAnimationFrame(() => chartRenderer.render(c, canvas));
                    }
                }
            });

            wrap.appendChild(pageEl);
        });
    })();

    // PDF Export using html2canvas + jsPDF
    async function exportPDF() {
        const overlay = document.getElementById('rvExportOverlay');
        overlay.classList.add('active');
        try {
            const wrap = document.getElementById('rvCanvasWrap');
            // Wait a tick for charts to finish rendering
            await new Promise(r => setTimeout(r, 300));

            const canvas = await html2canvas(wrap, {
                scale: 2,
                useCORS: true,
                backgroundColor: '#f0f2f5',
                logging: false
            });

            const imgData = canvas.toDataURL('image/png');
            const { jsPDF } = window.jspdf;

            // Determine orientation from content aspect ratio
            const imgW = canvas.width;
            const imgH = canvas.height;
            const orientation = imgW > imgH ? 'landscape' : 'portrait';
            const pdf = new jsPDF({ orientation, unit: 'mm', format: 'a4' });

            const pageW = pdf.internal.pageSize.getWidth();
            const pageH = pdf.internal.pageSize.getHeight();
            const margin = 10;
            const contentW = pageW - margin * 2;
            const contentH = (imgH / imgW) * contentW;

            // If content fits on one page
            if (contentH <= pageH - margin * 2) {
                pdf.addImage(imgData, 'PNG', margin, margin, contentW, contentH);
            } else {
                // Multi-page: slice the image
                let yOffset = 0;
                const sliceH = pageH - margin * 2;
                const srcSliceH = (sliceH / contentH) * imgH;
                let pageIndex = 0;
                while (yOffset < imgH) {
                    if (pageIndex > 0) pdf.addPage();
                    const remaining = imgH - yOffset;
                    const thisSlice = Math.min(srcSliceH, remaining);
                    const thisContentH = (thisSlice / imgH) * contentH;

                    // Create a cropped canvas for this slice
                    const sliceCanvas = document.createElement('canvas');
                    sliceCanvas.width = imgW;
                    sliceCanvas.height = thisSlice;
                    const ctx = sliceCanvas.getContext('2d');
                    ctx.drawImage(canvas, 0, yOffset, imgW, thisSlice, 0, 0, imgW, thisSlice);
                    const sliceData = sliceCanvas.toDataURL('image/png');
                    pdf.addImage(sliceData, 'PNG', margin, margin, contentW, thisContentH);

                    yOffset += srcSliceH;
                    pageIndex++;
                }
            }

            const title = document.title.replace(/[^a-zA-Z0-9_\- ]/g, '').trim() || 'Report';
            pdf.save(title + '.pdf');
        } catch (e) {
            console.error('PDF export failed:', e);
            alert('Failed to export PDF. Please try printing instead.');
        } finally {
            overlay.classList.remove('active');
        }
    }
    // Share modal
    function openShareModal() {
        const wsNameEl = document.getElementById('rvShareWsName');
        if (wsNameEl && '@workspaceName' !== '') wsNameEl.textContent = '@workspaceName';
        document.getElementById('rvShareOverlay').classList.add('active');
    }
    function closeShareModal() {
        document.getElementById('rvShareOverlay').classList.remove('active');
    }
    </script>
</body>
</html>
