@{
    ViewData["Title"] = "Reset Password";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="container">
        <div class="row justify-content-center min-vh-100 align-items-center">
            <div class="col-md-5">
                <div class="auth-card glass-card">
                    <div class="auth-header text-center mb-4">
                        <div class="auth-logo">
                            <i class="bi bi-bar-chart-fill"></i>
                        </div>
                        <h2 class="auth-title">Set new password</h2>
                        <p class="auth-subtitle">Enter your new password below</p>
                    </div>
                    <div id="rpAlert" class="alert d-none"></div>
                    <form id="resetForm">
                        <input type="hidden" id="rpToken" value="@ViewBag.Token" />
                        <input type="hidden" id="rpEmail" value="@ViewBag.Email" />
                        <div class="mb-3">
                            <label class="form-label-cp">New Password</label>
                            <div class="input-group-cp">
                                <i class="bi bi-lock input-icon"></i>
                                <input type="password" class="form-control cp-input" id="rpPassword" placeholder="At least 10 characters" required minlength="10" autocomplete="new-password" />
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label-cp">Confirm Password</label>
                            <div class="input-group-cp">
                                <i class="bi bi-lock input-icon"></i>
                                <input type="password" class="form-control cp-input" id="rpConfirm" placeholder="Re-enter password" required minlength="10" autocomplete="new-password" />
                            </div>
                        </div>
                        <button type="submit" class="btn cp-btn-gradient w-100 btn-lg" id="rpBtn">
                            <i class="bi bi-check-circle me-2"></i>Reset Password
                        </button>
                    </form>
                    <div class="auth-footer mt-4 text-center">
                        <p><a href="/auth/login" class="auth-link">Back to Sign In</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
$('#resetForm').on('submit', function(e) {
    e.preventDefault();
    if ($('#rpPassword').val() !== $('#rpConfirm').val()) {
        $('#rpAlert').removeClass('d-none alert-success').addClass('alert alert-danger').text('Passwords do not match.');
        return;
    }
    var btn = $('#rpBtn').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Resetting...');
    $.ajax({
        url: '/api/auth/reset-password',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ email: $('#rpEmail').val(), token: $('#rpToken').val(), newPassword: $('#rpPassword').val() }),
        success: function(r) {
            $('#rpAlert').removeClass('d-none alert-danger').addClass('alert alert-success').text(r.message);
            btn.prop('disabled', false).html('<i class="bi bi-check-circle me-2"></i>Reset Password');
            setTimeout(function() { window.location.href = '/auth/login'; }, 2000);
        },
        error: function(e) {
            $('#rpAlert').removeClass('d-none alert-success').addClass('alert alert-danger').text(e.responseJSON?.error || 'Reset failed.');
            btn.prop('disabled', false).html('<i class="bi bi-check-circle me-2"></i>Reset Password');
        }
    });
});
</script>
}
