        // ── Right-panels divider resize (horizontal) ────────────
        (function wireRightPanelsDivider() {
            const divider = document.getElementById('right-panels-divider');
            const dfPanel = document.getElementById('data-fields-aside');
            if (!divider || !dfPanel) return;
            let isResizing = false;
            let startX = 0;
            let startW = 0;
            divider.addEventListener('mousedown', function(e) {
                isResizing = true;
                startX = e.clientX;
                startW = dfPanel.offsetWidth;
                divider.classList.add('active');
                document.body.style.cursor = 'ew-resize';
                document.body.style.userSelect = 'none';
                e.preventDefault();
            });
            document.addEventListener('mousemove', function(e) {
                if (!isResizing) return;
                const delta = e.clientX - startX;
                const newW = Math.max(80, Math.min(500, startW - delta));
                dfPanel.style.width = newW + 'px';
                dfPanel.style.flex = '0 0 ' + newW + 'px';
            });
            document.addEventListener('mouseup', function() {
                if (isResizing) {
                    isResizing = false;
                    divider.classList.remove('active');
                    document.body.style.cursor = '';
                    document.body.style.userSelect = '';
                }
            });
        })();

        // ── Pre-load real table names BEFORE chart init so charts use correct tables ──
        if (window.currentDatasourceId) {
            const realTables = await loadDatasourceTables(window.currentDatasourceId);
            if (realTables && realTables.length > 0) {
                const lowerTables = realTables.map(n => n.toLowerCase());
                // Fix chart dataset names in all pages before init
                const allPageCharts = (pages && pages.length > 0)
                    ? pages.flatMap(p => p.charts || [])
                    : (initialCharts || []);
                allPageCharts.forEach(chart => {
                    if (chart.datasetName && !lowerTables.includes(chart.datasetName.toLowerCase())) {
                        chart.datasetName = realTables[0];
                    }
                    if (!chart.datasourceId) {
                        chart.datasourceId = window.currentDatasourceId;
                    }
                });
            }
        }

        // Inject shapes group into chart library
        if (window.ShapeManager) {
            chartLibraryData.unshift(ShapeManager.getLibraryGroup());
        }
        chartLibrary.init(chartLibraryData);
        canvasManager.init(initialCharts, pages, activePageIndex);
        // Initialize group and layout managers
        if (window.groupManager) groupManager.init();
        if (window.layoutManager) layoutManager.init();
        // Initialize filter panel
        if (window.filterPanel) filterPanel.init();
        // Receive any chart pushed from the Chat page — must run after canvasManager.init()
        if (window.dashboardChartTransfer) dashboardChartTransfer.receiveFromChat();

        // Populate dataset options safely (use DOM API to avoid XSS)
        const ds = document.getElementById('prop-dataset');
        if (window._realTableNames && window._realTableNames.length > 0) {
            if (ds) {
                ds.innerHTML = '';
                window._realTableNames.forEach(name => {
                    const opt = document.createElement('option');
                    opt.value = name;
                    opt.textContent = name;
                    ds.appendChild(opt);
                });
            }
        } else if (ds && datasets.length) {
            ds.innerHTML = '';
            datasets.forEach(d => {
                const opt = document.createElement('option');
                opt.value = d;
                opt.textContent = d.charAt(0).toUpperCase() + d.slice(1);
                ds.appendChild(opt);
            });
        }

        function updateCount() {
            const el = document.getElementById('chart-count-label');
            if (el) el.textContent = `${canvasManager.charts.length} chart${canvasManager.charts.length !== 1 ? 's' : ''}`;
        }
        setInterval(updateCount, 500);

        // ── Canvas Properties wiring ──────────────────────────
        (function wireCanvasProps() {
            const widthInput = document.getElementById('canvas-prop-width');
            const heightInput = document.getElementById('canvas-prop-height');
            const bgColor = document.getElementById('canvas-prop-bg');
            const bgText = document.getElementById('canvas-prop-bg-text');
            const bgMode = document.getElementById('canvas-prop-bg-mode');
            const bgPreset = document.getElementById('canvas-prop-bg-preset');
            const bgPresetWrap = document.getElementById('canvas-prop-bg-preset-wrap');
            const canvas = document.getElementById('chart-canvas-drop');

            function applyCanvasSize() {
                if (!canvas) return;
                const w = parseInt(widthInput?.value) || 1200;
                const h = parseInt(heightInput?.value) || 900;
                canvas.style.minWidth = w + 'px';
                canvas.style.minHeight = h + 'px';
                // Store on current page
                const page = canvasManager.pages[canvasManager.activePageIndex];
                if (page) { page.pageWidth = w; page.pageHeight = h; }
            }
            function applyCanvasBg() {
                if (!canvas) return;
                const mode = bgMode?.value || 'solid';
                let backgroundValue = bgColor?.value || '#ffffff';
                if (mode === 'gradient' || mode === 'pattern') {
                    backgroundValue = bgPreset?.value || backgroundValue;
                }
                // Solid mode: only override backgroundColor so the CSS-defined
                // design grid (radial-gradient dots on .chart-grid) stays visible.
                // Gradient/pattern mode: replace the whole background intentionally.
                if (mode === 'solid') {
                    canvas.style.background = '';
                    canvas.style.backgroundColor = backgroundValue;
                } else {
                    canvas.style.background = backgroundValue;
                }
                if (mode === 'solid' && bgText) bgText.value = backgroundValue;
                if (bgPresetWrap) bgPresetWrap.classList.toggle('d-none', mode === 'solid');
                const page = canvasManager.pages[canvasManager.activePageIndex];
                if (page) {
                    page.background = backgroundValue;
                    page.backgroundMode = mode;
                }
            }
            function syncFromPage() {
                const page = canvasManager.pages[canvasManager.activePageIndex];
                if (!page) return;
                if (widthInput) widthInput.value = page.pageWidth || 1200;
                if (heightInput) heightInput.value = page.pageHeight || 900;
                if (bgColor) bgColor.value = page.background || '#ffffff';
                if (bgText) bgText.value = page.background || '#ffffff';
                if (bgMode) bgMode.value = page.backgroundMode || 'solid';
                applyCanvasSize();
                applyCanvasBg();
            }
            if (widthInput) widthInput.addEventListener('change', applyCanvasSize);
            if (heightInput) heightInput.addEventListener('change', applyCanvasSize);
            if (bgColor) bgColor.addEventListener('input', applyCanvasBg);
            if (bgMode) bgMode.addEventListener('change', applyCanvasBg);
            if (bgPreset) bgPreset.addEventListener('change', applyCanvasBg);
            if (bgText) bgText.addEventListener('change', function() {
                if (bgColor) bgColor.value = this.value;
                applyCanvasBg();
            });
            syncFromPage();
        })();

        document.getElementById('add-navigation-widget-btn')?.addEventListener('click', async function() {
            if (!window.canvasManager) return;
            await canvasManager.addChart({
                chartType: 'navigation',
                title: 'Navigation Link',
                width: 3,
                height: 80,
                datasetName: '',
