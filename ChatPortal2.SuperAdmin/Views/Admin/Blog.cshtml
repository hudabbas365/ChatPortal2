@model List<AIInsights.Models.BlogPost>
@{
    ViewData["Title"] = "Blog";
    ViewData["ActivePage"] = "blog";
    var jsonOpts = new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase };
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Blog Posts</h1>
        <p class="page-desc">Manage news, updates, and articles for the public blog.</p>
    </div>
    <button class="btn-primary-sm" onclick="openForm()"><i class="bi bi-plus-lg"></i>New Post</button>
</div>

<!-- posts list -->
<div class="card-panel">
    <div class="card-panel-title">All Posts</div>
    @if (Model.Count == 0)
    {
        <p style="color:var(--text-muted);font-size:.85rem;">No blog posts yet. Click <strong>New Post</strong> to create one.</p>
    }
    else
    {
        <table class="tbl">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Slug</th>
                    <th>Author</th>
                    <th>Status</th>
                    <th>Published</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var post in Model)
                {
                    <tr>
                        <td style="font-weight:600;color:#1e3a5f;">@post.Title</td>
                        <td><code style="color:#4a8ec9;">@post.Slug</code></td>
                        <td>@(post.Author ?? "—")</td>
                        <td>
                            @if (post.IsPublished)
                            {
                                <span class="badge-sm badge-emerald"><i class="bi bi-check-circle-fill"></i>Published</span>
                            }
                            else
                            {
                                <span class="badge-sm badge-amber"><i class="bi bi-pencil-fill"></i>Draft</span>
                            }
                        </td>
                        <td>@post.PublishedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            <button class="btn-ghost-sm" style="padding:.3rem .6rem;font-size:.78rem;" onclick='editPost(@System.Text.Json.JsonSerializer.Serialize(post, jsonOpts))'><i class="bi bi-pencil"></i></button>
                            <button class="btn-ghost-sm" style="padding:.3rem .6rem;font-size:.78rem;border-color:#ef4444;color:#ef4444;" onclick="deletePost(@post.Id)"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- modal overlay -->
<div id="blogModal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,.45);align-items:center;justify-content:center;">
    <div style="background:#fff;border:1px solid var(--border);border-radius:14px;width:680px;max-width:95vw;max-height:90vh;overflow-y:auto;padding:1.75rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem;">
            <h3 id="formTitle" style="font-size:1.05rem;font-weight:700;color:#1e3a5f;">New Post</h3>
            <button onclick="closeForm()" style="background:none;border:none;font-size:1.2rem;color:var(--text-muted);cursor:pointer;"><i class="bi bi-x-lg"></i></button>
        </div>
        <input type="hidden" id="postId" value="0" />
        <div style="margin-bottom:.85rem;">
            <label style="font-size:.78rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.3rem;">Title</label>
            <input id="postTitle" type="text" style="width:100%;padding:.5rem .75rem;border:1px solid var(--border);border-radius:8px;font-size:.85rem;font-family:inherit;color:var(--text);" placeholder="My Awesome Post" />
        </div>
        <div style="margin-bottom:.85rem;">
            <label style="font-size:.78rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.3rem;">Slug</label>
            <input id="postSlug" type="text" style="width:100%;padding:.5rem .75rem;border:1px solid var(--border);border-radius:8px;font-size:.85rem;font-family:inherit;color:var(--text);" placeholder="my-awesome-post" />
        </div>
        <div style="display:flex;gap:.75rem;margin-bottom:.85rem;">
            <div style="flex:1;">
                <label style="font-size:.78rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.3rem;">Author</label>
                <input id="postAuthor" type="text" style="width:100%;padding:.5rem .75rem;border:1px solid var(--border);border-radius:8px;font-size:.85rem;font-family:inherit;color:var(--text);" placeholder="Admin" />
            </div>
            <div style="flex:1;">
                <label style="font-size:.78rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.3rem;">Image URL (optional)</label>
                <input id="postImage" type="text" style="width:100%;padding:.5rem .75rem;border:1px solid var(--border);border-radius:8px;font-size:.85rem;font-family:inherit;color:var(--text);" placeholder="https://..." />
            </div>
        </div>
        <div style="margin-bottom:.85rem;">
            <label style="font-size:.78rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.3rem;">Summary</label>
            <textarea id="postSummary" rows="2" style="width:100%;padding:.5rem .75rem;border:1px solid var(--border);border-radius:8px;font-size:.85rem;font-family:inherit;color:var(--text);resize:vertical;" placeholder="Brief summary for listing pages..."></textarea>
        </div>
        <div style="margin-bottom:.85rem;">
            <label style="font-size:.78rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.3rem;">Content (HTML or Markdown)</label>
            <textarea id="postContent" rows="10" style="width:100%;padding:.5rem .75rem;border:1px solid var(--border);border-radius:8px;font-size:.85rem;font-family:inherit;color:var(--text);resize:vertical;" placeholder="Full post content..."></textarea>
        </div>
        <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:1.25rem;">
            <input id="postPublished" type="checkbox" checked />
            <label for="postPublished" style="font-size:.85rem;font-weight:500;color:var(--text-dim);">Published</label>
        </div>
        <div style="display:flex;gap:.5rem;justify-content:flex-end;">
            <button class="btn-ghost-sm" onclick="closeForm()">Cancel</button>
            <button class="btn-primary-sm" onclick="savePost()"><i class="bi bi-check-lg"></i>Save Post</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openForm() {
        document.getElementById('postId').value = '0';
        document.getElementById('postTitle').value = '';
        document.getElementById('postSlug').value = '';
        document.getElementById('postAuthor').value = '';
        document.getElementById('postImage').value = '';
        document.getElementById('postSummary').value = '';
        document.getElementById('postContent').value = '';
        document.getElementById('postPublished').checked = true;
        document.getElementById('formTitle').textContent = 'New Post';
        document.getElementById('blogModal').style.display = 'flex';
    }

    function editPost(post) {
        document.getElementById('postId').value = post.id;
        document.getElementById('postTitle').value = post.title;
        document.getElementById('postSlug').value = post.slug;
        document.getElementById('postAuthor').value = post.author || '';
        document.getElementById('postImage').value = post.imageUrl || '';
        document.getElementById('postSummary').value = post.summary;
        document.getElementById('postContent').value = post.content;
        document.getElementById('postPublished').checked = post.isPublished;
        document.getElementById('formTitle').textContent = 'Edit Post';
        document.getElementById('blogModal').style.display = 'flex';
    }

    function closeForm() { document.getElementById('blogModal').style.display = 'none'; }

    function savePost() {
        var payload = {
            id: parseInt(document.getElementById('postId').value),
            title: document.getElementById('postTitle').value,
            slug: document.getElementById('postSlug').value,
            summary: document.getElementById('postSummary').value,
            content: document.getElementById('postContent').value,
            author: document.getElementById('postAuthor').value,
            imageUrl: document.getElementById('postImage').value || null,
            isPublished: document.getElementById('postPublished').checked
        };
        fetch('/api/superadmin/blog/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        }).then(r => r.json()).then(d => {
            if (d.success) location.reload();
            else alert(d.error || 'Save failed');
        }).catch(() => alert('Save failed'));
    }

    function deletePost(id) {
        if (!confirm('Delete this blog post?')) return;
        fetch('/api/superadmin/blog/' + id, { method: 'DELETE' })
            .then(r => r.json()).then(d => { if (d.success) location.reload(); })
            .catch(() => alert('Delete failed'));
    }
</script>
}
