<UserControl x:Class="GatewayApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold" Margin="0,0,0,12" />
        <Border Style="{StaticResource CardStyle}">
            <TextBlock Text="{Binding StatusSummary}" FontSize="16" />
        </Border>
    </StackPanel>
</UserControl>
