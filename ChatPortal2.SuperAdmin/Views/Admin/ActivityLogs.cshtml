@model List<ChatPortal2.Models.ActivityLog>
@{
    ViewData["Title"] = "Activity Logs";
    ViewData["ActivePage"] = "activity";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-activity me-2 text-primary"></i>Activity Logs</h2>
    <a href="?page=@(ViewBag.Page + 1)" class="btn btn-sa btn-sm">Next Page →</a>
</div>

<div class="sa-card">
    <table class="sa-table">
        <thead>
            <tr>
                <th>Time</th>
                <th>Action</th>
                <th>Description</th>
                <th>User ID</th>
                <th>Org ID</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td class="text-muted" style="white-space:nowrap">@log.CreatedAt.ToString("MMM d HH:mm")</td>
                    <td><span class="sa-badge sa-badge-blue">@log.Action</span></td>
                    <td>@log.Description</td>
                    <td class="text-muted" style="font-size:0.75rem">@(log.UserId?.Length > 12 ? log.UserId[..12] + "…" : log.UserId)</td>
                    <td>@log.OrganizationId</td>
                </tr>
            }
        </tbody>
    </table>
</div>
