@{
    ViewData["Title"] = "AI Configuration";
    ViewData["ActivePage"] = "aiconfig";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h1 class="page-title">AI Configuration</h1>
    <p class="page-desc">Current AI provider settings and model configuration</p>
</div>

<div class="card-panel">
    <div class="card-panel-title">Provider Settings</div>
    <table class="tbl">
        <tbody>
            <tr>
                <td>Provider</td>
                <td class="text-end"><span class="badge-sm badge-indigo">Cohere AI</span></td>
            </tr>
            <tr>
                <td>API Endpoint</td>
                <td class="text-end"><code style="color:#4a8ec9;font-size:.82rem">https://api.cohere.ai/v2/chat</code></td>
            </tr>
            <tr>
                <td>Model</td>
                <td class="text-end"><code style="color:#4a8ec9;font-size:.82rem">command-a-03-2025</code></td>
            </tr>
            <tr>
                <td>Streaming</td>
                <td class="text-end"><span class="badge-sm badge-emerald">Enabled (SSE)</span></td>
            </tr>
        </tbody>
    </table>
    <p style="color:var(--text-muted);font-size:.82rem;margin-top:1rem">Configuration is managed via <code style="color:#4a8ec9">appsettings.json</code> — keys: <code style="color:#4a8ec9">Cohere:ApiKey</code>, <code style="color:#4a8ec9">Cohere:Model</code></p>
</div>
