@{
    ViewData["Title"] = "AI Configuration";
    ViewData["ActivePage"] = "aiconfig";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="fw-bold mb-4"><i class="bi bi-cpu me-2 text-primary"></i>AI Configuration</h2>

<div class="sa-card">
    <h6 class="text-muted mb-3">Current AI Provider Settings</h6>
    <table class="sa-table">
        <tbody>
            <tr>
                <td>Provider</td>
                <td><span class="sa-badge sa-badge-blue">Cohere AI</span></td>
            </tr>
            <tr>
                <td>API Endpoint</td>
                <td><code>https://api.cohere.ai/v2/chat</code></td>
            </tr>
            <tr>
                <td>Model</td>
                <td><code>command-a-03-2025</code></td>
            </tr>
            <tr>
                <td>Streaming</td>
                <td><span class="sa-badge sa-badge-green">Enabled (SSE)</span></td>
            </tr>
        </tbody>
    </table>
    <p class="text-muted small mt-3">AI configuration is managed via <code>appsettings.json</code> (Cohere:ApiKey, Cohere:Model).</p>
</div>
