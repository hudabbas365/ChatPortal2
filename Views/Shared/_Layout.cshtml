@using AIInsights.Models
@{
    var seoEntry = ViewBag.SeoEntry as SeoEntry;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — AI Insights 365" : "AI Insights 365")</title>
    <meta name="description" content="@(seoEntry?.MetaDescription ?? "AI-Powered Data Conversations Portal")" />
    <meta name="keywords" content="@(seoEntry?.MetaKeywords ?? "chat, AI, data, analytics, dashboards")" />
    <meta name="robots" content="@(seoEntry?.RobotsDirective ?? "index, follow")" />
    @{
        var canonicalUrl = !string.IsNullOrEmpty(seoEntry?.CanonicalUrl)
            ? seoEntry.CanonicalUrl
            : $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
        var ogType = (ViewData["OgType"] as string) ?? "website";
    }
    <link rel="canonical" href="@canonicalUrl" />
    <meta property="og:title" content="@(seoEntry?.OgTitle ?? seoEntry?.Title ?? "AI Insights 365")" />
    <meta property="og:description" content="@(seoEntry?.OgDescription ?? seoEntry?.MetaDescription ?? "")" />
    <meta property="og:image" content="@(seoEntry?.OgImage ?? "")" />
    <meta property="og:type" content="@ogType" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@(seoEntry?.OgTitle ?? seoEntry?.Title ?? "AI Insights 365")" />
    <meta name="twitter:description" content="@(seoEntry?.OgDescription ?? seoEntry?.MetaDescription ?? "")" />
    @if (!string.IsNullOrEmpty(seoEntry?.StructuredData)) {
        <script type="application/ld+json">@Html.Raw(seoEntry.StructuredData)</script>
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/permissions.css" />
    <link rel="stylesheet" href="~/css/orgadmin.css" />
    <link rel="stylesheet" href="~/css/cp-toast.css" />
    <link rel="stylesheet" href="~/css/cp-pricing-home.css" />
    <link rel="stylesheet" href="~/css/cp-about.css" />
    @RenderSection("Head", required: false)
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-M7E9RXEQL5"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-M7E9RXEQL5');
    </script>
</head>
<body style="display:flex;flex-direction:column;min-height:100vh;">
    @await Html.PartialAsync("~/Views/Partials/_Navbar.cshtml")

    @await Html.PartialAsync("~/Views/Partials/_TrialBanner.cshtml")
    <div id="subscriptionExpiredBanner" style="display:none;background:#dc3545;color:#fff;padding:.6rem 1.25rem;font-size:.82rem;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem">
        <span id="subscriptionExpiredMsg"><i class="bi bi-exclamation-triangle-fill me-1"></i></span>
        <button onclick="document.getElementById('subscriptionExpiredBanner').style.display='none'" style="background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);color:#fff;border-radius:6px;padding:.2rem .75rem;font-size:.78rem;cursor:pointer;font-family:inherit">Dismiss</button>
    </div>
    <script>
    (function() {
        try {
            var u = JSON.parse(localStorage.getItem('cp_user') || 'null');
            if (!u || !u.id || !u.organizationId) return;
            fetch('/api/paypal/subscription-status?organizationId=' + u.organizationId, { credentials: 'same-origin' })
                .then(function(r) { return r.ok ? r.json() : null; })
                .then(function(d) {
                    if (!d) return;
                    // Show banner only when subscription is definitively expired (not for new/free orgs that never subscribed)
                    var isExpired = d.status === 'EXPIRED'
                        || (d.plan === 'Free' && d.status !== 'APPROVAL_PENDING' && d.status !== 'NONE' && d.status !== 'ACTIVE');
                    if (!isExpired) return;
                    var banner = document.getElementById('subscriptionExpiredBanner');
                    var msg = document.getElementById('subscriptionExpiredMsg');
                    if (!banner || !msg) return;
                    var isAdmin = u.role === 'OrgAdmin';
                    msg.innerHTML = isAdmin
                        ? '<i class="bi bi-exclamation-triangle-fill me-1"></i>Your subscription has ended. Choose a plan in <a href="/orgadmin/settings" style="color:#fff;text-decoration:underline;">Settings &rarr; Billing</a> to restore full access.'
                        : '<i class="bi bi-exclamation-triangle-fill me-1"></i>Your organization\'s subscription has ended. The portal is read-only. Please contact your Org Admin to reactivate.';
                    banner.style.display = 'flex';
                })
                .catch(function() { /* non-fatal */ });
        } catch(e) { /* non-fatal */ }
    })();
    </script>
    @if (Context.Items.ContainsKey("ImpersonationBanner"))
    {
        var bannerMsg = Context.Items["ImpersonationBanner"]?.ToString();
        <div style="background:#7c3aed;color:#fff;padding:.6rem 1.25rem;font-size:.82rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem">
            <span><i class="bi bi-person-fill-gear"></i> @bannerMsg</span>
            <button onclick="stopImpersonation()" style="background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);color:#fff;border-radius:6px;padding:.2rem .75rem;font-size:.78rem;cursor:pointer;font-family:inherit">
                Stop impersonating
            </button>
        </div>
        <script>
        function stopImpersonation() {
            // Call the local stop endpoint; send XSRF-TOKEN cookie value as header for CSRF validation
            var xsrf = (document.cookie.match(/XSRF-TOKEN=([^;]+)/) || [])[1] || '';
            fetch('/api/auth/impersonate/stop', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': decodeURIComponent(xsrf) }
            }).then(function(r){ return r.json(); }).then(function(d){
                window.location.href = d.redirectUrl || '/superadmin';
            });
        }
        </script>
    }
    <main style="flex:1;">
        @RenderBody()
    </main>
    <footer class="cp-footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <div class="footer-brand">
                        <i class="bi bi-bar-chart-fill me-2"></i><strong>AI Insights 365</strong>
                    </div>
                    <p class="footer-tagline">AI-Powered Data Conversations</p>
                </div>
                <div class="col-md-4 text-center">
                    <div class="footer-links">
                        <a href="/">Home</a>
                        <a href="/about">About</a>
                        <a href="/docs">Docs</a>
                        <a href="/blog">Blog</a>
                        <a href="/home/sla">SLA</a>
                        <a href="/home/support">Support</a>
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <div class="gdpr-badge">
                        <i class="bi bi-shield-check me-1"></i>GDPR Compliant
                    </div>
                    &copy; @DateTime.Now.Year AI Insights 365. All rights reserved.
                    <span class="footer-separator">·</span>
                    <a href="mailto:support@AIInsights365.net" style="color:var(--cp-text-muted);text-decoration:none;">support@AIInsights365.net</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/js/app.js"></script>
    <script src="~/js/cp-toast.js"></script>
    <script src="~/js/cp-confirm.js" asp-append-version="true"></script>
    <script src="~/js/cp-about.js" asp-append-version="true"></script>
    <script>
        // Fetch plan feature flags for the current user once per page load so gated
        // features (AI auto-report, Explain by AI) can be hidden client-side.
        (function () {
            try {
                var u = JSON.parse(localStorage.getItem('cp_user') || 'null');
                if (!u || !u.id) return;
                fetch('/api/subscription/' + u.id, { credentials: 'same-origin' })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (p) {
                        if (!p) return;
                        window.cpPlanFeatures = {
                            plan: p.plan,
                            canUseAiReportGeneration: p.canUseAiReportGeneration !== false,
                            canUseAiChartExplain: p.canUseAiChartExplain !== false,
                            monthlyTokenBudget: p.monthlyTokenBudget || 0,
                            maxWorkspaces: p.maxWorkspaces || 1
                        };
                        document.dispatchEvent(new CustomEvent('cp:plan-features-loaded', { detail: window.cpPlanFeatures }));
                    })
                    .catch(function () { /* non-fatal */ });
            } catch (e) { /* non-fatal */ }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)

  
</body>
</html>
