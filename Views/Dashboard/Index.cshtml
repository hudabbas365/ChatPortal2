        <text>window.currentDatasourceId = @ViewBag.DatasourceId;</text>
    }
    @if (ViewBag.DatasourceType != null)
    {
        <text>window.currentDatasourceType = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.DatasourceType));</text>
    }
    @if (ViewBag.AgentGuid != null)
    {
        <text>window.currentAgentGuid = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.AgentGuid));</text>
    }
    @if (ViewBag.WorkspaceGuid != null)
    {
        <text>window.currentWorkspaceGuid = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.WorkspaceGuid));</text>
    }
    @if (ViewBag.OrganizationGuid != null)
    {
        <text>window.currentOrganizationGuid = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.OrganizationGuid));</text>
    }

    document.addEventListener('DOMContentLoaded', async function() {
        // If editing an existing report, show View Report button
        if (window._currentReportGuid) {
            const viewBtn = document.getElementById('viewReportBtn');
            if (viewBtn) {
                viewBtn.style.display = '';
                viewBtn.onclick = () => window.open('/report/view/' + window._currentReportGuid, '_blank');
            }
        }

        // Pre-populate topnav from server-side workspace context so it's visible immediately
        @if (ViewBag.WorkspaceGuid != null)
        {
            <text>
        (function() {
            const topnav = document.getElementById('reportTopnav');
            if (topnav) topnav.style.display = '';
            const wsTag = document.getElementById('reportWsTag');
            const wsName = document.getElementById('reportWsName');
            if (wsTag) wsTag.style.display = '';
            if (wsName) wsName.textContent = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.WorkspaceName ?? ""));
            @if (ViewBag.DatasourceName != null)
            {
                <text>
            var dsTag = document.getElementById('reportDsTag');
            var dsEl = document.getElementById('reportDsName');
            var dsSep = document.getElementById('reportDsSep');
            if (dsTag) dsTag.style.display = '';
            if (dsEl) dsEl.textContent = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.DatasourceName ?? ""));
            if (dsSep) dsSep.style.display = '';
