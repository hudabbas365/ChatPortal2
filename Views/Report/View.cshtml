@{
    ViewData["Title"] = ViewBag.ReportName ?? "Report";
    Layout = null;
    var reportName = ViewBag.ReportName as string ?? "Report";
    var canvasJson = ViewBag.CanvasJson as string ?? "{}";
    var workspaceName = ViewBag.WorkspaceName as string;
    var workspaceGuid = ViewBag.WorkspaceGuid as string;
    var datasourceName = ViewBag.DatasourceName as string;
    var agentName = ViewBag.AgentName as string;
    var datasourceId = ViewBag.DatasourceId as int?;
    var status = ViewBag.Status as string ?? "Draft";
    var reportGuid = ViewBag.ReportGuid as string;
    var savedAt = ViewBag.UpdatedAt as DateTime?;
    var workspaceRole = ViewBag.WorkspaceRole as string;
    var isViewOnly = workspaceRole == "Viewer";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@reportName — AI Insights</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dashboard-shapes.css" />
    <link rel="stylesheet" href="~/css/report-viewer.css" />
    <link rel="stylesheet" href="~/css/report-qa-enhanced.css" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body class="rv-body">
    <nav class="rv-navbar">
        <a href="/" class="rv-brand">
            <i class="bi bi-bar-chart-fill text-primary"></i>
            <span class="rv-brand-text">AIInsights</span>
        </a>
        <div class="rv-breadcrumb">
            <span class="rv-sep"><i class="bi bi-chevron-right"></i></span>
            @if (!string.IsNullOrEmpty(workspaceGuid) && !string.IsNullOrEmpty(workspaceName))
            {
                <a href="/chat?workspace=@workspaceGuid">@workspaceName</a>
                <span class="rv-sep"><i class="bi bi-chevron-right"></i></span>
            }
            <span class="rv-current">@reportName</span>
            <span class="rv-badge @(status == "Published" ? "rv-badge-published" : "rv-badge-draft")">@status</span>
            @if (isViewOnly)
            {
                <span class="rv-badge" style="background:#f3f4f6;color:#6b7280;border:1px solid #d1d5db;margin-left:6px;"><i class="bi bi-eye me-1"></i>View Only</span>
            }
        </div>
        <div class="rv-meta" style="margin-left: 16px;">
            @if (!string.IsNullOrEmpty(datasourceName))
            {
                <span><i class="bi bi-database-fill me-1"></i>@datasourceName</span>
            }
            @if (!string.IsNullOrEmpty(agentName))
            {
                <span><i class="bi bi-robot me-1"></i>@agentName</span>
            }
        </div>
        <div class="rv-toolbar">
            @if (!string.IsNullOrEmpty(workspaceGuid))
            {
                <a class="btn" href="/chat?workspace=@workspaceGuid" title="Back to Workspace">
                    <i class="bi bi-arrow-left"></i> Workspace
                </a>
                @if (!isViewOnly)
                {
                    <a class="btn" href="/dashboard?workspace=@workspaceGuid&report=@reportGuid" title="Edit in Dashboard">
                        <i class="bi bi-pencil-square"></i> Edit
                    </a>
                }
            }
            @if (!isViewOnly)
            {
                <button class="btn" onclick="openShareModal()" title="Share Report">
                    <i class="bi bi-share"></i> Share
                </button>
            }
            <button class="btn" onclick="window.print()" title="Print Report">
                <i class="bi bi-printer"></i> Print
            </button>
            <button class="btn btn-primary-rv" onclick="exportPDF()" title="Export as PDF">
                <i class="bi bi-file-earmark-pdf"></i> Export PDF
            </button>
        </div>
    </nav>

    @if (!isViewOnly)
    {
        <div class="rv-share-overlay" id="rvShareOverlay">
            <div class="rv-share-box">
                <h5><i class="bi bi-link-45deg me-2"></i>Share Report</h5>
                <p style="font-size:0.82rem;color:#475569;margin-bottom:14px;">
                    Generate a share link to invite people as <strong>viewers</strong> of this report in
                    <strong id="rvShareWsName">this workspace</strong>.
                </p>
                <div class="rv-share-url" style="display:none">
                    <input type="text" id="rvShareUrlInput" readonly onclick="this.select()">
                    <button id="rvShareCopyBtn"><i class="bi bi-clipboard me-1"></i>Copy</button>
                </div>
                <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:6px;padding:10px 14px;font-size:0.78rem;color:#0369a1;margin-bottom:14px;">
                    <i class="bi bi-info-circle-fill me-1"></i>
                    Anyone who opens this link and is signed in will be added as a <strong>Viewer</strong> to the workspace.
                </div>
                <div id="rvShareStatus" style="font-size:0.78rem;margin-bottom:10px;display:none;"></div>
                <div style="display:flex;gap:8px;justify-content:flex-end;">
                    <button class="rv-share-close" id="rvShareCloseBtn">Close</button>
                    <button id="rvShareGenerateBtn" class="rv-share-url button" style="font-size:0.78rem;padding:5px 14px;border-radius:6px;border:1px solid var(--cp-primary,#4A90D9);background:var(--cp-primary,#4A90D9);color:#fff;cursor:pointer;font-weight:500;">
                        <i class="bi bi-link-45deg me-1"></i>Generate Link
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="rv-export-overlay" id="rvExportOverlay">
        <div class="rv-export-box">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Generating PDF…</p>
        </div>
    </div>

    <div class="rv-layout" id="rvLayout">
        <!-- Left page navigation sidebar -->
        <aside class="rv-page-nav" id="rvPageNav">
            <div class="rv-page-nav-header">
                <i class="bi bi-journal-text"></i>
                <span>Pages</span>
            </div>
            <ul class="rv-page-nav-list" id="rvPageNavList">
                <!-- Populated by JS -->
            </ul>
        </aside>

        <!-- Main canvas viewport -->
        <div class="rv-canvas-wrap" id="rvCanvasWrap">
            <div class="rv-empty" id="rvEmpty" style="display:none">
                <i class="bi bi-bar-chart"></i>
                <p>This report has no charts.</p>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="rv-footer">
        <span><i class="bi bi-bar-chart-fill" style="color:var(--cp-primary)"></i> Powered by AIInsights</span>
        @if (savedAt.HasValue)
        {
            <span><i class="bi bi-clock"></i> Last saved: @savedAt.Value.ToString("MMM d, yyyy 'at' h:mm tt")</span>
        }
    </footer>

    <!-- Q&A FAB -->
    <button class="rv-qa-fab" id="rv-qa-fab" title="Ask about this report" aria-label="Open AI Q&amp;A">
        <i class="bi bi-stars"></i>
    </button>

    <!-- Q&A Panel -->
    <div class="rv-qa-panel" id="rv-qa-panel" role="dialog" aria-label="AI Q&amp;A">
        <div class="rv-qa-header">
            <div class="rv-qa-header-icon"><i class="bi bi-stars"></i></div>
            <div class="rv-qa-header-info">
                <div class="rv-qa-header-title">Ask AI about this report</div>
                <div class="rv-qa-header-sub">@reportName</div>
            </div>
            <button class="rv-qa-close" aria-label="Close Q&amp;A panel"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="rv-qa-chips"></div>
        <div class="rv-qa-messages" id="rv-qa-messages"></div>
        <div class="rv-qa-input-area">
            <textarea class="rv-qa-textarea" placeholder="Ask a question about this report…" rows="1" maxlength="1000"></textarea>
            <button class="rv-qa-stop-btn" title="Stop generating" style="display:none;"><i class="bi bi-stop-circle-fill"></i></button>
            <button class="rv-qa-send-btn" title="Send"><i class="bi bi-send-fill"></i></button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.54.0/dist/apexcharts.min.js"></script>
    <script src="~/js/chartRenderer.js" asp-append-version="true"></script>
    <script src="~/js/shapeManager.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
    <script src="~/js/aiStream.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.1.7/dist/purify.min.js"></script>
    <script>
    // Global context for Q&A panel and share
    window._rvReportGuid     = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(reportGuid ?? ""));
    window._rvWorkspaceGuid  = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(workspaceGuid ?? ""));
    window._rvDatasourceId   = @Html.Raw(datasourceId.HasValue ? datasourceId.Value.ToString() : "null");
    window._rvReportName     = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(reportName));
    window._rvWorkspaceName  = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(workspaceName ?? ""));
    </script>
    <script src="~/js/report-qa-panel.js" asp-append-version="true"></script>
    <script src="~/js/report-share.js" asp-append-version="true"></script>
    <script>
    (function() {
        'use strict';

        const canvasJson = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(canvasJson));
        const datasourceId = @Html.Raw(datasourceId.HasValue ? datasourceId.Value.ToString() : "null");
        const wrap = document.getElementById('rvCanvasWrap');
        const navList = document.getElementById('rvPageNavList');

        // Set global datasource context so chartRenderer can fetch real data
        if (datasourceId) window.currentDatasourceId = datasourceId;
        @if (ViewBag.DatasourceType != null)
        {
            <text>window.currentDatasourceType = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.DatasourceType));</text>
        }

        let parsed;
        try { parsed = JSON.parse(canvasJson); } catch { parsed = {}; }

        const pages = parsed.pages || [];
        if (!pages.length) {
            document.getElementById('rvEmpty').style.display = '';
            document.getElementById('rvPageNav').style.display = 'none';
            return;
        }

        // Use the same formula as the dashboard canvas manager so charts
        // render at identical pixel sizes regardless of the surrounding layout.
        function colsToPixels(width) {
            var baseWidth = Math.min(window.innerWidth - 600, 900);
            var pct = (parseInt(width) || 6) / 12;
            return Math.round(Math.max(200, baseWidth * pct));
        }

        // Track page elements and rendered state
        const pageElements = [];
        const pageRendered = [];

        // Build left nav items and page containers
        pages.forEach((page, pi) => {
            const charts = page.charts || [];
            const pageName = page.name || ('Page ' + (pi + 1));
            const chartCount = charts.length;

            // Create nav item
            const li = document.createElement('li');
            li.className = 'rv-page-nav-item' + (pi === 0 ? ' active' : '');
            li.dataset.pageIndex = pi;
            li.innerHTML =
                '<div class="rv-page-nav-num">' + (pi + 1) + '</div>' +
                '<div class="rv-page-nav-info">' +
                    '<span class="rv-page-nav-name">' + pageName.replace(/</g, '&lt;') + '</span>' +
                    '<span class="rv-page-nav-count">' + chartCount + ' chart' + (chartCount !== 1 ? 's' : '') + '</span>' +
                '</div>';
            li.addEventListener('click', function() { switchToPage(pi); });
            navList.appendChild(li);

            // Create page container (hidden except first)
            const pageEl = document.createElement('div');
            pageEl.className = 'rv-page';
            pageEl.id = 'rvPage-' + pi;
            pageEl.style.position = 'relative';
            if (page.background) pageEl.style.background = page.background;
            if (pi !== 0) pageEl.style.display = 'none';

            if (pages.length > 1) {
                const title = document.createElement('div');
                title.className = 'rv-page-title';
                title.textContent = pageName;
                pageEl.appendChild(title);
            }

            // Calculate page height from chart positions
            const titleOffset = (pages.length > 1) ? 44 : 0;
            let maxBottom = 400;
            let maxRight = 0;
            charts.forEach(c => {
                const ch = (parseInt(c.height) || 300) + 40;
                const bottom = (c.posY !== undefined ? c.posY : 20) + ch + 20 + titleOffset;
                if (bottom > maxBottom) maxBottom = bottom;

                const w = colsToPixels(c.width || 6);
                const right = (c.posX !== undefined ? c.posX : 20) + w + 20;
                if (right > maxRight) maxRight = right;
            });
            pageEl.style.minHeight = maxBottom + 'px';
            if (maxRight > 0) pageEl.style.minWidth = maxRight + 'px';

            // Build card DOM (but defer chart rendering until page is shown)
            charts.forEach(c => {
                const isShape = window.ShapeManager && ShapeManager.isShape(c.chartType);
                const isNavigation = c.chartType === 'navigation';
                const cardWidth = colsToPixels(c.width || 6);
                const cardHeight = parseInt(c.height) || (isNavigation ? 80 : 300);
                const posX = c.posX !== undefined ? c.posX : 20;
                const posY = (c.posY !== undefined ? c.posY : 20) + titleOffset;
                const zIdx = c.zIndex || 1;

                const card = document.createElement('div');
                card.className = 'chart-card' + (isShape ? ' shape-card' : '') + (isNavigation ? ' navigation-card' : '');
                card.style.cssText = 'position:absolute;left:' + posX + 'px;top:' + posY + 'px;width:' + cardWidth + 'px;z-index:' + zIdx + ';';

                if (isShape) {
                    const canvasWrap = document.createElement('div');
                    canvasWrap.className = 'chart-canvas-wrap';
                    canvasWrap.style.height = cardHeight + 'px';
                    card.appendChild(canvasWrap);
                    pageEl.appendChild(card);
                    card.dataset.shapeReady = '1';
                    card._shapeDef = c;
                    card._shapeWrap = canvasWrap;
                } else if (isNavigation) {
                    const canvasWrap = document.createElement('div');
                    canvasWrap.className = 'chart-canvas-wrap';
                    canvasWrap.style.height = cardHeight + 'px';
                    card.appendChild(canvasWrap);
                    pageEl.appendChild(card);

                    if (!c.datasourceId && datasourceId) c.datasourceId = datasourceId;
                    card.dataset.navReady = '1';
                    card._chartDef = Object.assign({}, c);
                    card._canvasWrap = canvasWrap;
                } else {
                    const header = document.createElement('div');
                    header.className = 'chart-card-header';
                    const titleSpan = document.createElement('span');
                    titleSpan.className = 'chart-title';
                    titleSpan.textContent = c.title || c.chartType || 'Chart';
                    header.appendChild(titleSpan);
                    if (c.chartType) {
                        const sub = document.createElement('span');
                        sub.className = 'chart-subtitle';
                        sub.textContent = c.chartType;
                        header.appendChild(sub);
                    }
                    card.appendChild(header);

                    const canvasWrap = document.createElement('div');
                    canvasWrap.className = 'chart-canvas-wrap';
                    canvasWrap.style.height = cardHeight + 'px';
                    canvasWrap.style.width = '100%';
                    canvasWrap.style.position = 'relative';
                    card.appendChild(canvasWrap);
                    pageEl.appendChild(card);

                    if (!c.datasourceId && datasourceId) c.datasourceId = datasourceId;

                    // Store chart def on the card for lazy rendering
                    card.dataset.chartReady = '1';
                    card._chartDef = Object.assign({}, c);
                    card._canvasWrap = canvasWrap;
                }
            });

            wrap.appendChild(pageEl);
            pageElements.push(pageEl);
            pageRendered.push(false);
        });

        // Render charts for a given page index
        function renderPageCharts(pi) {
            if (pageRendered[pi]) return;
            pageRendered[pi] = true;
            const pageEl = pageElements[pi];
            const cards = pageEl.querySelectorAll('.chart-card');
            cards.forEach(card => {
                if (card.dataset.shapeReady === '1' && card._shapeDef) {
                    requestAnimationFrame(() => ShapeManager.render(card._shapeWrap, card._shapeDef));
                }
                if (card.dataset.navReady === '1' && card._chartDef) {
                    const def = card._chartDef;
                    const canvasWrap = card._canvasWrap;
                    setTimeout(() => {
                        if (window.chartRenderer) {
                            chartRenderer.render(def, canvasWrap);
                        }
                    }, 50);
                }
                if (card.dataset.chartReady === '1' && card._chartDef) {
                    const def = card._chartDef;
                    const canvasWrap = card._canvasWrap;
                    const canvasEl = document.createElement('canvas');
                    canvasEl.id = 'canvas-' + (def.id || '');
                    canvasWrap.appendChild(canvasEl);
                    setTimeout(() => {
                        if (window.chartRenderer) {
                            chartRenderer.render(def, canvasEl);
                        }
                    }, 50);
                }
            });
        }

        // Switch to a specific page
        function switchToPage(pi) {
            // Update nav
            navList.querySelectorAll('.rv-page-nav-item').forEach((item, idx) => {
                item.classList.toggle('active', idx === pi);
            });
            // Show/hide pages
            pageElements.forEach((el, idx) => {
                el.style.display = idx === pi ? '' : 'none';
            });
            // Lazy-render charts on first visit
            renderPageCharts(pi);
        }

        // Render the first page
        renderPageCharts(0);
    })();

    // PDF Export using html2canvas + jsPDF
    async function exportPDF() {
        const overlay = document.getElementById('rvExportOverlay');
        overlay.classList.add('active');
        try {
            const wrap = document.getElementById('rvCanvasWrap');
            // Wait a tick for charts to finish rendering
            await new Promise(r => setTimeout(r, 300));

            const canvas = await html2canvas(wrap, {
                scale: 2,
                useCORS: true,
                backgroundColor: '#f0f2f5',
                logging: false
            });

            const imgData = canvas.toDataURL('image/png');
            const { jsPDF } = window.jspdf;

            // Determine orientation from content aspect ratio
            const imgW = canvas.width;
            const imgH = canvas.height;
            const orientation = imgW > imgH ? 'landscape' : 'portrait';
            const pdf = new jsPDF({ orientation, unit: 'mm', format: 'a4' });

            const pageW = pdf.internal.pageSize.getWidth();
            const pageH = pdf.internal.pageSize.getHeight();
            const margin = 10;
            const contentW = pageW - margin * 2;
            const contentH = (imgH / imgW) * contentW;

            // If content fits on one page
            if (contentH <= pageH - margin * 2) {
                pdf.addImage(imgData, 'PNG', margin, margin, contentW, contentH);
            } else {
                // Multi-page: slice the image
                let yOffset = 0;
                const sliceH = pageH - margin * 2;
                const srcSliceH = (sliceH / contentH) * imgH;
                let pageIndex = 0;
                while (yOffset < imgH) {
                    if (pageIndex > 0) pdf.addPage();
                    const remaining = imgH - yOffset;
                    const thisSlice = Math.min(srcSliceH, remaining);
                    const thisContentH = (thisSlice / imgH) * contentH;

                    // Create a cropped canvas for this slice
                    const sliceCanvas = document.createElement('canvas');
                    sliceCanvas.width = imgW;
                    sliceCanvas.height = thisSlice;
                    const ctx = sliceCanvas.getContext('2d');
                    ctx.drawImage(canvas, 0, yOffset, imgW, thisSlice, 0, 0, imgW, thisSlice);
                    const sliceData = sliceCanvas.toDataURL('image/png');
                    pdf.addImage(sliceData, 'PNG', margin, margin, contentW, thisContentH);

                    yOffset += srcSliceH;
                    pageIndex++;
                }
            }

            const title = document.title.replace(/[^a-zA-Z0-9_\- ]/g, '').trim() || 'Report';
            pdf.save(title + '.pdf');
        } catch (e) {
            console.error('PDF export failed:', e);
            alert('Failed to export PDF. Please try printing instead.');
        } finally {
            overlay.classList.remove('active');
        }
    }
    </script>
</body>
</html>
