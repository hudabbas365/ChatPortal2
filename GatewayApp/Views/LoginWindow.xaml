<Window x:Class="GatewayApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Insights 365 Gateway Login"
        Width="900"
        Height="760"
        MinHeight="680"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Storyboard x:Key="GlowPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="BrandGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.35" To="0.8" Duration="0:0:2.5" />
        </Storyboard>

        <Storyboard x:Key="RightPanelFadeIn">
            <DoubleAnimation Storyboard.TargetName="RightPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.7" />
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource GlowPulseStoryboard}" />
            <BeginStoryboard Storyboard="{StaticResource RightPanelFadeIn}" />
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="20" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2A3958" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.15*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0A0F1E" Offset="0" />
                        <GradientStop Color="#111827" Offset="1" />
                    </LinearGradientBrush>
                </Grid.Background>

                <Canvas IsHitTestVisible="False" Margin="24">
                    <Ellipse Width="8" Height="8" Fill="#33FFFFFF" Canvas.Left="24" Canvas.Top="36" />
                    <Ellipse Width="6" Height="6" Fill="#4000D4FF" Canvas.Left="64" Canvas.Top="78" />
                    <Ellipse Width="10" Height="10" Fill="#2200D4FF" Canvas.Left="290" Canvas.Top="60" />
                    <Rectangle Width="80" Height="1" Fill="#3000D4FF" Canvas.Left="220" Canvas.Top="122" />
                    <Rectangle Width="55" Height="1" Fill="#25FFFFFF" Canvas.Left="48" Canvas.Top="380" />
                </Canvas>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
                    <Grid Width="120" Height="120" Margin="0,0,0,22">
                        <Ellipse x:Name="BrandGlow" Width="120" Height="120">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#8000D4FF" Offset="0" />
                                    <GradientStop Color="#0000D4FF" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <Path Data="M60,18 L92,36 L92,74 L60,92 L28,74 L28,36 Z" Stretch="Fill" Width="92" Height="92" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0EA5E9" Offset="0" />
                                    <GradientStop Color="#00D4FF" Offset="1" />
                                </LinearGradientBrush>
                            </Path.Fill>
                        </Path>
                        <Path Data="M34,58 L52,42 L66,56 L84,40" Stroke="#E6FFFFFF" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Grid>

                    <TextBlock Text="AI Insights 365" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                    <TextBlock Text="Gateway Control Center" FontSize="18" Margin="0,8,0,0" Foreground="#00D4FF" HorizontalAlignment="Center" />
                    <TextBlock Text="Secure · Connected · Intelligent" FontSize="13" Margin="0,14,0,0" Foreground="#8093B4" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <Grid x:Name="RightPanel" Grid.Column="1" Opacity="0" Background="#131B2E">
                <Grid.Margin>
                    <Thickness Left="46" Right="46" Top="34" Bottom="34" />
                </Grid.Margin>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Content="✕"
                        Width="34"
                        Height="34"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseButton_Click"
                        Background="#00FFFFFF"
                        BorderBrush="#00FFFFFF"
                        Foreground="#A6B4D0"
                        FontSize="16"
                        Cursor="Hand" />

                <StackPanel Grid.Row="1" Margin="0,14,0,0">
                    <TextBlock Text="Welcome Back" Foreground="White" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="Sign in to your organization gateway" Foreground="#8B9DC3" FontSize="14" Margin="0,8,0,0" />
                </StackPanel>

                <TextBlock Grid.Row="2" Text="Email" Style="{StaticResource LabelStyle}" Margin="0,26,0,6" />
                <Border Grid.Row="3" CornerRadius="8" Background="#1E2A3D" BorderBrush="#2C3A55" BorderThickness="1" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" Foreground="#8B9DC3" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="White"
                                 CaretBrush="#00D4FF"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>

                <TextBlock Grid.Row="4" Text="Password" Style="{StaticResource LabelStyle}" Margin="0,16,0,6" />
                <Border Grid.Row="5" CornerRadius="8" Background="#1E2A3D" BorderBrush="#2C3A55" BorderThickness="1" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <PasswordBox x:Name="PasswordInput"
                                         PasswordChanged="PasswordInput_PasswordChanged"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="White"
                                         CaretBrush="#00D4FF"
                                         VerticalContentAlignment="Center" />
                            <TextBox x:Name="PasswordRevealInput"
                                     Visibility="Collapsed"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="White"
                                     CaretBrush="#00D4FF"
                                     VerticalContentAlignment="Center" />
                        </Grid>
                        <Button Grid.Column="1"
                                Click="TogglePassword_Click"
                                Background="#00FFFFFF"
                                BorderBrush="#00FFFFFF"
                                Cursor="Hand"
                                Padding="6,0">
                            <TextBlock x:Name="EyeIcon" Text="&#xE722;" FontFamily="Segoe MDL2 Assets" Foreground="#8B9DC3" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="6" Margin="0,18,0,0" Style="{StaticResource CaptchaBoxStyle}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="CAPTCHA" Foreground="#8B9DC3" FontWeight="SemiBold" DockPanel.Dock="Left" />
                            <Button Content="Refresh ↺"
                                    Command="{Binding RefreshCaptchaCommand}"
                                    DockPanel.Dock="Right"
                                    Background="#1E2A3D"
                                    Foreground="#00D4FF"
                                    BorderBrush="#1E3A5A"
                                    Padding="8,4"
                                    Cursor="Hand" />
                        </DockPanel>

                        <Border CornerRadius="6" BorderBrush="#294163" BorderThickness="1" Background="#F0F4F8" Padding="2">
                            <Canvas x:Name="CaptchaCanvas" Height="88" ClipToBounds="True" />
                        </Border>

                        <TextBox Margin="0,10,0,0"
                                 Style="{StaticResource InputStyle}"
                                 Text="{Binding CaptchaAnswer, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Enter CAPTCHA answer" />
                    </StackPanel>
                </Border>

                <ProgressBar Grid.Row="7"
                             Height="4"
                             Margin="0,14,0,0"
                             IsIndeterminate="True"
                             Foreground="#00D4FF"
                             Background="#2A3958"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button Grid.Row="8"
                        Margin="0,16,0,0"
                        Content="Sign In"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="LoginButton_Click"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />

                <TextBlock Grid.Row="9"
                           Margin="0,8,0,0"
                           Text="{Binding ErrorMessage}"
                           Foreground="#FF6B6B"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="10"
                           Margin="0,8,0,0"
                           Text="{Binding AppVersion}"
                           Foreground="#6F84A7"
                           FontSize="12" />
            </Grid>
        </Grid>
    </Border>
</Window>
