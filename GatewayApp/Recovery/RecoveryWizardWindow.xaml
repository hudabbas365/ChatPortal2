<Window x:Class="GatewayApp.Recovery.RecoveryWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recovery Wizard"
        Height="420"
        Width="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}">
    <DockPanel Margin="16">
        <TabControl SelectedIndex="{Binding StepIndex}" IsEnabled="False" BorderThickness="0" Background="Transparent">
            <TabItem Header="Step 1">
                <StackPanel Margin="10">
                    <TextBlock Text="Choose Recovery Action" FontWeight="Bold" Margin="0,0,0,10" />
                    <RadioButton Content="Backup Now" IsChecked="{Binding IsBackupSelected}" GroupName="Operation" />
                    <RadioButton Content="Restore from Backup" IsChecked="{Binding IsBackupSelected, Converter={StaticResource InverseBooleanConverter}}" GroupName="Operation" Margin="0,8,0,0" />
                </StackPanel>
            </TabItem>
            <TabItem Header="Step 2">
                <StackPanel Margin="10">
                    <TextBlock Text="Confirm / Select backup file" Margin="0,0,0,10" />
                    <TextBox Text="{Binding BackupFilePath}" IsEnabled="{Binding IsBackupSelected, Converter={StaticResource InverseBooleanConverter}}" />
                    <Button Content="Browse" Width="100" Margin="0,8,0,0" Command="{Binding BrowseCommand}" IsEnabled="{Binding IsBackupSelected, Converter={StaticResource InverseBooleanConverter}}" />
                </StackPanel>
            </TabItem>
            <TabItem Header="Step 3">
                <StackPanel Margin="10">
                    <TextBlock Text="Summary" FontWeight="Bold" />
                    <TextBlock Text="{Binding ResultMessage}" Margin="0,10,0,0" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Back" Width="80" Margin="0,0,8,0" Command="{Binding BackCommand}" />
            <Button Content="Next" Width="80" Command="{Binding NextCommand}" />
        </StackPanel>
    </DockPanel>
</Window>
