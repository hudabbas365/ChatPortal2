<!-- Phase 28-B9: Keyboard Shortcuts Modal -->
<div class="modal fade" id="keyboardShortcutsModal" tabindex="-1" aria-labelledby="keyboardShortcutsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px;border:1px solid var(--cp-border);background:var(--cp-surface);">
            <div class="modal-header" style="border-bottom:1px solid var(--cp-border);padding:16px 20px;">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-keyboard" style="font-size:1.2rem;color:var(--cp-primary);"></i>
                    <h6 class="modal-title mb-0" id="keyboardShortcutsModalLabel" style="font-weight:600;">Keyboard Shortcuts</h6>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding:16px 20px;">
                <table class="table table-sm mb-0" style="font-size:0.85rem;">
                    <tbody>
                        <tr><td style="width:45%"><kbd>Del</kbd> / <kbd>Backspace</kbd></td><td class="text-muted">Delete selected chart</td></tr>
                        <tr><td><kbd>Ctrl</kbd>+<kbd>D</kbd></td><td class="text-muted">Duplicate selected chart</td></tr>
                        <tr><td><kbd>&uarr;</kbd> <kbd>&darr;</kbd> <kbd>&larr;</kbd> <kbd>&rarr;</kbd></td><td class="text-muted">Nudge selected chart 1&nbsp;px</td></tr>
                        <tr><td><kbd>Shift</kbd>+arrows</td><td class="text-muted">Nudge 10&nbsp;px</td></tr>
                        <tr><td><kbd>Ctrl</kbd>+<kbd>S</kbd></td><td class="text-muted">Save draft</td></tr>
                        <tr><td><kbd>Ctrl</kbd>+<kbd>G</kbd></td><td class="text-muted">Group selection</td></tr>
                        <tr><td><kbd>Ctrl</kbd>+<kbd>Shift</kbd>+<kbd>G</kbd></td><td class="text-muted">Ungroup</td></tr>
                        <tr><td><kbd>Esc</kbd></td><td class="text-muted">Clear selection</td></tr>
                        <tr><td><kbd>?</kbd></td><td class="text-muted">Open this help</td></tr>
                    </tbody>
                </table>
                <div class="text-muted mt-3" style="font-size:0.75rem;">
                    <i class="bi bi-info-circle me-1"></i>Shortcuts are ignored while typing in an input, textarea, or editable text box.
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Phase 28-B9 + B12: Bootstrap tooltips init + global keyboard shortcuts.
(function () {
    function initTooltips() {
        if (!window.bootstrap || !bootstrap.Tooltip) return;
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
            if (!bootstrap.Tooltip.getInstance(el)) new bootstrap.Tooltip(el);
        });
    }
    function isTyping(t) {
        if (!t) return false;
        var tag = t.tagName;
        return tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || t.isContentEditable;
    }
    function persistChartPos(chart) {
        try {
            fetch(_chartApiUrl('/api/chart/' + chart.id), {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(chart)
            }).catch(function () {});
        } catch (e) {}
    }
    function handleKeydown(e) {
        // '?' opens the shortcuts modal regardless of selection.
        if (e.key === '?' && !isTyping(e.target)) {
            e.preventDefault();
            var modalEl = document.getElementById('keyboardShortcutsModal');
            if (modalEl && window.bootstrap) bootstrap.Modal.getOrCreateInstance(modalEl).show();
            return;
        }
        if (isTyping(e.target)) return;
        var cm = window.canvasManager;
        if (!cm) return;
        var id = cm.selectedChartId;
        if (!id) return;
        var chart = cm.charts.find(function (c) { return c.id === id; });
        if (!chart) return;
        var step = e.shiftKey ? 10 : 1;

        if (e.key === 'Delete' || e.key === 'Backspace') {
            e.preventDefault();
            cm.deleteChart(id);
        } else if ((e.ctrlKey || e.metaKey) && (e.key === 'd' || e.key === 'D')) {
            e.preventDefault();
            cm.duplicateChart(id);
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowRight' || e.key === 'ArrowUp' || e.key === 'ArrowDown') {
            e.preventDefault();
            if (e.key === 'ArrowLeft')  chart.posX = Math.max(0, (chart.posX || 0) - step);
            if (e.key === 'ArrowRight') chart.posX = (chart.posX || 0) + step;
            if (e.key === 'ArrowUp')    chart.posY = Math.max(0, (chart.posY || 0) - step);
            if (e.key === 'ArrowDown')  chart.posY = (chart.posY || 0) + step;
            var card = document.querySelector('.chart-card[data-chart-id="' + id + '"]');
            if (card) { card.style.left = chart.posX + 'px'; card.style.top = chart.posY + 'px'; }
            clearTimeout(handleKeydown._t);
            handleKeydown._t = setTimeout(function () { persistChartPos(chart); }, 250);
        } else if (e.key === 'Escape') {
            cm.selectedChartId = null;
            document.querySelectorAll('.chart-card.selected').forEach(function (el) { el.classList.remove('selected'); });
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTooltips);
    } else {
        initTooltips();
    }
    // Re-init when the properties panel rebuilds its DOM (MutationObserver-lite).
    var propsHost = document.querySelector('.properties-panel') || document.body;
    if (window.MutationObserver && propsHost) {
        new MutationObserver(function () { initTooltips(); })
            .observe(propsHost, { childList: true, subtree: true });
    }
    document.addEventListener('keydown', handleKeydown);
})();
</script>
