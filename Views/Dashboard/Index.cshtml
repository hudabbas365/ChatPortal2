@model AIInsights.Models.CanvasState
@{
    ViewData["Title"] = "Report Designer";
    Layout = null;
    var canvasName = ViewBag.CanvasName as string ?? "My Report";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — AI Insights</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dashboard-chart-transfer.css" />
    <link rel="stylesheet" href="~/css/dashboard-chat-panel.css" />
    <link rel="stylesheet" href="~/css/dashboard-shapes.css" />
    <link rel="stylesheet" href="~/css/dashboard-filter-panel.css" />
    <link rel="stylesheet" href="~/css/dashboard-group-layout.css" />
    <link rel="stylesheet" href="~/css/workspace-roles.css" />
    <link rel="stylesheet" href="~/css/auto-report.css" />
    <link rel="stylesheet" href="~/css/chart-library-enhanced.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/explain-chart.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body class="dashboard-body">

<div class="app-shell">
    <!-- Top Navbar -->
    <nav class="app-navbar">
        <div class="navbar-brand">
            <a href="/" class="brand-link">
                <i class="bi bi-bar-chart-fill text-primary me-2"></i>
                <span class="brand-text">AI Insights</span>
            </a>
        </div>
        <div class="navbar-title">
            <span id="canvas-name-display" class="canvas-name">@canvasName</span>
            <button class="btn btn-xs btn-ghost ms-2" onclick="promptRename()" title="Rename">
                <i class="bi bi-pencil-square"></i>
            </button>
        </div>
        <div class="navbar-actions ms-auto">
            <button type="button" class="btn btn-sm btn-outline-secondary me-2" id="add-navigation-widget-btn" title="Add navigation hyperlink widget">
                <i class="bi bi-link-45deg me-1"></i>Navigation
            </button>
            <div class="dropdown me-2">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-droplet-half me-1"></i>Theme
                </button>
                <div class="dropdown-menu dropdown-menu-end p-2" style="min-width:280px">
                    <label class="form-label mb-1 small">Chart Theme</label>
                    <select class="form-select form-select-sm mb-2" id="dashboard-theme-select">
                        <option value="ocean">🎨 Ocean</option>
                        <option value="sunset">🎨 Sunset</option>
                        <option value="forest">🎨 Forest</option>
                        <option value="midnight">🎨 Midnight</option>
                        <option value="pastel">🎨 Pastel</option>
                        <option value="corporate">🎨 Corporate</option>
                        <option value="retro">🎨 Retro</option>
                        <option value="neon">🎨 Neon</option>
                        <option value="earth">🎨 Earth</option>
                        <option value="monochrome">🎨 Monochrome</option>
                        <option value="custom">✏️ Custom</option>
                    </select>
                    <div id="dashboard-theme-preview" class="d-flex gap-1 mb-2 flex-wrap"></div>
                    <div id="dashboard-theme-custom-colors" class="d-none">
                        <div class="d-flex gap-1 mb-2">
                            <input type="color" class="form-control form-control-color" data-custom-theme-color value="#4A90D9" style="width:36px;height:30px">
                            <input type="color" class="form-control form-control-color" data-custom-theme-color value="#E87C3E" style="width:36px;height:30px">
                            <input type="color" class="form-control form-control-color" data-custom-theme-color value="#4CAF50" style="width:36px;height:30px">
                            <input type="color" class="form-control form-control-color" data-custom-theme-color value="#9C27B0" style="width:36px;height:30px">
                            <input type="color" class="form-control form-control-color" data-custom-theme-color value="#FFC107" style="width:36px;height:30px">
                        </div>
                    </div>
                    <button type="button" class="btn btn-sm cp-btn-gradient w-100" id="dashboard-theme-apply-btn">Apply Theme</button>
                </div>
            </div>
            <button type="button" class="btn btn-sm btn-outline-cp me-2" id="dcpToggleBtn" title="Open AI Report Assistant">
                <i class="bi bi-chat-dots me-1"></i>Chat
            </button>
            <button type="button" class="btn btn-sm cp-btn-gradient me-2" id="auto-report-toolbar-btn" title="Auto Generate or Redesign Report with AI">
                <i class="bi bi-magic me-1"></i>Auto Report
            </button>
            <button type="button" class="btn btn-sm btn-outline-cp me-2" id="filter-panel-toggle" title="Toggle Filters">
                <i class="bi bi-funnel me-1"></i>Filters
            </button>
            <button class="btn btn-sm btn-outline-secondary me-1" onclick="exportManager.exportXml()" title="Export XML">
                <i class="bi bi-file-code me-1"></i>XML
            </button>
            <label class="btn btn-sm btn-outline-secondary me-2" title="Import XML">
                <i class="bi bi-upload me-1"></i>Import XML
                <input type="file" accept=".xml" onchange="exportManager.importXml(this.files[0])" style="display:none">
            </label>
            <button class="btn btn-sm btn-danger" onclick="canvasManager.resetCanvas()" title="Reset">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary ms-2" id="keyboard-shortcuts-btn" title="Keyboard shortcuts & help" data-bs-toggle="modal" data-bs-target="#keyboardShortcutsModal">
                <i class="bi bi-question-circle"></i>
            </button>
        </div>
    </nav>

    <!-- Report Context Bar — Workspace + Datasource -->
    <div class="report-topnav" id="reportTopnav" style="display:none">
        <nav class="report-breadcrumb" aria-label="Report context">
            <span class="report-crumb workspace" id="reportWsTag" style="display:none">
                <i class="bi bi-folder-fill"></i><span id="reportWsName">—</span>
            </span>
            <i class="bi bi-chevron-right report-crumb-sep" id="reportDsSep" style="display:none"></i>
            <span class="report-crumb datasource" id="reportDsTag" style="display:none">
                <i class="bi bi-database-fill"></i><span id="reportDsName">—</span>
            </span>
            <i class="bi bi-chevron-right report-crumb-sep" id="reportAgentSep" style="display:none"></i>
            <span class="report-crumb agent" id="reportAgentTag" style="display:none">
                <i class="bi bi-robot"></i><span id="reportAgentName">—</span>
            </span>
        </nav>
        <div class="report-topnav-actions">
            <button class="btn btn-sm btn-outline-primary" id="viewReportBtn" title="View saved report" style="display:none;margin-right:6px">
                <i class="bi bi-eye me-1"></i>View Report
            </button>
            <button class="btn btn-sm btn-outline-secondary" id="saveDraftBtn" title="Save as Draft (auto-save current state)" style="margin-right:6px">
                <i class="bi bi-file-earmark-medical me-1"></i>Save Draft
            </button>
            <button class="btn btn-sm btn-outline-success" id="saveReportBtn" title="Save as Report">
                <i class="bi bi-file-earmark-check me-1"></i>Save Report
            </button>
        </div>
    </div>

    <div class="app-body">
        <!-- Left Panel: Chart Library -->
        <aside class="library-panel">
            <div class="panel-header">
                <h6 class="mb-0"><i class="bi bi-collection me-2"></i>Chart Library</h6>
                <span class="badge bg-primary">72</span>
                <button id="toggle-library-panel" class="panel-toggle-btn ms-1" title="Collapse panel"><i class="bi bi-chevron-left"></i></button>
            </div>
            <div class="search-wrap p-2">
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" id="chart-search" class="form-control" placeholder="Search charts...">
                </div>
            </div>
            <div id="chart-library-container" class="library-scroll"></div>
        </aside>

        <!-- Middle Panel: Canvas -->
        <main class="canvas-panel">
            <div class="canvas-toolbar">
                <span class="text-muted small">Drag from library or double-click to add charts</span>
                <!-- Group Actions (visible when 2+ items selected) -->
                <div class="group-actions hidden" id="group-actions">
                    <button class="layout-btn" id="btn-group-items" title="Group (Ctrl+G)"><i class="bi bi-collection"></i></button>
                    <button class="layout-btn" id="btn-ungroup-items" title="Ungroup (Ctrl+Shift+G)"><i class="bi bi-collection-fill"></i></button>
                </div>
                <!-- Layout Toolbar (visible when 2+ items selected) -->
                <div class="layout-toolbar hidden" id="layout-toolbar">
                    <button class="layout-btn" id="btn-align-left" title="Align Left"><i class="bi bi-align-start"></i></button>
                    <button class="layout-btn" id="btn-align-center" title="Align Center"><i class="bi bi-align-center"></i></button>
                    <button class="layout-btn" id="btn-align-right" title="Align Right"><i class="bi bi-align-end"></i></button>
                    <span class="layout-sep"></span>
                    <button class="layout-btn" id="btn-align-top" title="Align Top"><i class="bi bi-align-top"></i></button>
                    <button class="layout-btn" id="btn-align-middle" title="Align Middle"><i class="bi bi-align-middle"></i></button>
                    <button class="layout-btn" id="btn-align-bottom" title="Align Bottom"><i class="bi bi-align-bottom"></i></button>
                    <span class="layout-sep"></span>
                    <button class="layout-btn" id="btn-dist-h" title="Distribute Horizontal"><i class="bi bi-distribute-horizontal"></i></button>
                    <button class="layout-btn" id="btn-dist-v" title="Distribute Vertical"><i class="bi bi-distribute-vertical"></i></button>
                    <span class="layout-sep"></span>
                    <button class="layout-btn" id="btn-tidy-row" title="Tidy into a row (uniform gap)"><i class="bi bi-layout-three-columns"></i></button>
                    <button class="layout-btn" id="btn-tidy-col" title="Tidy into a column (uniform gap)"><i class="bi bi-layout-split"></i></button>
                    <span class="layout-sep"></span>
                    <button class="layout-btn" id="btn-same-width" title="Same Width"><i class="bi bi-arrows"></i></button>
                    <button class="layout-btn" id="btn-same-height" title="Same Height"><i class="bi bi-arrows-vertical"></i></button>
                </div>
                <div class="ms-auto d-flex gap-2 align-items-center">
                    <button class="layout-btn" id="btn-snap-grid" title="Snap to Grid"><i class="bi bi-grid-3x3"></i></button>
                    <button class="layout-btn" id="btn-rulers" title="Toggle rulers"><i class="bi bi-rulers"></i></button>
                    <button class="layout-btn" id="btn-auto-arrange" title="Auto Arrange"><i class="bi bi-grid"></i></button>
                    <span class="layout-sep"></span>
                    <button class="layout-btn" id="btn-bring-forward" title="Bring Forward"><i class="bi bi-front"></i></button>
                    <button class="layout-btn" id="btn-send-backward" title="Send Backward"><i class="bi bi-back"></i></button>
                    <span class="layout-sep"></span>
                    <button class="layout-btn" id="btn-undo-history" title="Undo history"><i class="bi bi-clock-history"></i></button>
                    <button class="layout-btn" id="btn-revisions" title="Revision history (server-saved)"><i class="bi bi-clock-history" style="color:var(--cp-primary)"></i></button>
                    <button class="layout-btn" id="btn-snapshots" title="Named snapshots"><i class="bi bi-bookmark-star"></i></button>
                    <span class="small text-muted" id="chart-count-label"></span>
                </div>
            </div>
            <div class="canvas-scroll">
                <div id="chart-canvas-drop" class="chart-grid p-0"></div>
                <div id="canvas-empty-state" class="empty-state" style="display:none">
                    <i class="bi bi-bar-chart-line-fill display-1 text-muted mb-4"></i>
                </div>
            </div>
            <div class="page-tabs-bar">
                <div class="page-tabs" id="page-tabs"></div>
                <button class="btn btn-xs page-add-btn" id="add-page-btn" title="Add page">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>
        </main>

        <!-- Right Panels Container -->
        <div class="right-panels-container">
                <!-- Right Panel 1: Properties -->
           <aside class="properties-panel" id="properties-aside">
                    <div class="panel-header">
                        <i class="bi bi-gear me-1" style="color:var(--cp-primary)"></i>
                        <h6 class="mb-0">Properties</h6>
                        <button id="pp-expand-all-btn" class="panel-toggle-btn ms-auto" title="Expand / collapse all sections" style="display:none"><i class="bi bi-arrows-expand"></i></button>
                        <button id="toggle-properties-panel" class="panel-toggle-btn ms-1" title="Collapse panel"><i class="bi bi-chevron-left"></i></button>
                    </div>
                    <div class="right-panel-section-body" id="properties-section-body">
                        <!-- Canvas / Page Properties (always visible) -->
                        <div class="canvas-props-section" id="canvasPropsSection">
                            <div class="prop-section-title">Canvas Properties</div>
                            <div class="canvas-props-row">
                                <div class="flex-fill">
                                    <label class="form-label" style="font-size:0.72rem">Width (px)</label>
                                    <input type="number" id="canvas-prop-width" class="form-control form-control-sm" value="1200" min="600" max="3000" step="50">
                                </div>
                                <div class="flex-fill">
                                    <label class="form-label" style="font-size:0.72rem">Height (px)</label>
                                    <input type="number" id="canvas-prop-height" class="form-control form-control-sm" value="900" min="400" max="3000" step="50">
                                </div>
                            </div>
                            <div class="mb-2">
                                <label class="form-label" style="font-size:0.72rem">Background</label>
                                <div class="d-flex gap-2">
                                    <input type="color" id="canvas-prop-bg" class="form-control form-control-color form-control-sm" value="#ffffff" style="width:40px;height:32px">
                                    <input type="text" id="canvas-prop-bg-text" class="form-control form-control-sm" value="#ffffff" style="flex:1">
                                </div>
                            </div>
                            <div class="mb-2">
                                <label class="form-label" style="font-size:0.72rem">Background Style</label>
                                <select id="canvas-prop-bg-mode" class="form-select form-select-sm">
                                    <option value="solid">Solid Color</option>
                                    <option value="gradient">Gradient Preset</option>
                                    <option value="pattern">Subtle Pattern</option>
                                </select>
                            </div>
                            <div class="mb-2 d-none" id="canvas-prop-bg-preset-wrap">
                                <label class="form-label" style="font-size:0.72rem">Preset</label>
                                <select id="canvas-prop-bg-preset" class="form-select form-select-sm">
                                    <option value="linear-gradient(135deg, #f8fafc 0%, #dbeafe 100%)">Sky</option>
                                    <option value="linear-gradient(135deg, #fef3c7 0%, #fed7aa 100%)">Warm</option>
                                    <option value="linear-gradient(135deg, #e0f2fe 0%, #cffafe 100%)">Ocean Mist</option>
                                    <option value="radial-gradient(circle at top, #ede9fe 0%, #e0e7ff 60%, #dbeafe 100%)">Aurora</option>
                                    <option value="repeating-linear-gradient(45deg, #f8fafc, #f8fafc 12px, #eef2ff 12px, #eef2ff 24px)">Diagonal Weave</option>
                                    <option value="repeating-radial-gradient(circle at 10px 10px, #f8fafc 0, #f8fafc 5px, #e2e8f0 5px, #e2e8f0 10px)">Dot Pattern</option>
                                </select>
                            </div>
                        </div>
                        <div id="properties-empty" class="empty-state-small">
                            <i class="bi bi-cursor" style="font-size:2.2rem;opacity:0.4"></i>
                            <small style="font-size:0.8rem;line-height:1.5">Select a chart to<br>edit its properties</small>
                        </div>
                        <div id="properties-form" style="display:none">
                            <!-- Phase 29-B3: Filter properties by label -->
                            <div class="pp-search-wrap" id="pp-search-wrap">
                                <i class="bi bi-search pp-search-icon"></i>
                                <input type="text" id="pp-search-input" class="form-control form-control-sm" placeholder="Search properties…" autocomplete="off">
                                <button type="button" id="pp-search-clear" class="pp-search-clear" title="Clear" style="display:none"><i class="bi bi-x"></i></button>
                            </div>
                            <div id="properties-tab-content" class="properties-scroll">
                                <div class="p-3">
                                    <!-- Basic -->
                                    <div class="prop-section">
                                        <div class="prop-section-title" data-section="basic">Basic</div>
                                        <div class="mb-2">
                                            <label class="form-label">Title</label>
                                            <input type="text" id="prop-title" class="form-control form-control-sm">
                                        </div>
                                        <div class="mb-2 chart-only-section">
                                            <label class="form-label">Chart Type</label>
                                            <select id="prop-chart-type" class="form-select form-select-sm">
                                                <optgroup label="Basic">
                                                    <option value="bar">Bar Chart</option>
                                                    <option value="horizontalBar">Horizontal Bar</option>
                                                    <option value="stackedBar">Stacked Bar</option>
                                                    <option value="line">Line Chart</option>
                                                    <option value="area">Area Chart</option>
                                                    <option value="pie">Pie Chart</option>
                                                    <option value="donut">Donut Chart</option>
                                                    <option value="scatter">Scatter Plot</option>
                                                    <option value="bubble">Bubble Chart</option>
                                                    <option value="radar">Radar Chart</option>
                                                    <option value="card">Card</option>
                                                </optgroup>
                                                <optgroup label="Advanced">
                                                    <option value="mixedBarLine">Mixed Bar+Line</option>
                                                    <option value="groupedBar">Grouped Bar</option>
                                                    <option value="waterfall">Waterfall</option>
                                                    <option value="funnel">Funnel Chart</option>
                                                    <option value="gauge">Gauge Chart</option>
                                                    <option value="treemap">Treemap</option>
                                                    <option value="heatmap">Heatmap</option>
                                                    <option value="sankey">Sankey Diagram</option>
                                                    <option value="sunburst">Sunburst</option>
                                                    <option value="polarArea">Polar Area</option>
                                                </optgroup>
                                                <optgroup label="Statistical">
                                                    <option value="histogram">Histogram</option>
                                                    <option value="boxPlot">Box Plot</option>
                                                    <option value="violin">Violin Plot</option>
                                                    <option value="bellCurve">Bell Curve</option>
                                                    <option value="pareto">Pareto Chart</option>
                                                    <option value="controlChart">Control Chart</option>
                                                    <option value="regressionLine">Regression Line</option>
                                                    <option value="confidenceBand">Confidence Band</option>
                                                    <option value="errorBar">Error Bar</option>
                                                    <option value="stemLeaf">Stem and Leaf</option>
                                                </optgroup>
                                                <optgroup label="Time Series">
                                                    <option value="timeLine">Time Line</option>
                                                    <option value="candlestick">Candlestick</option>
                                                    <option value="ohlc">OHLC Chart</option>
                                                    <option value="rangeArea">Range Area</option>
                                                    <option value="stepLine">Step Line</option>
                                                    <option value="streamGraph">Stream Graph</option>
                                                    <option value="eventTimeline">Event Timeline</option>
                                                    <option value="gantt">Gantt Chart</option>
                                                    <option value="burnDown">Burn Down</option>
                                                    <option value="velocityChart">Velocity Chart</option>
                                                </optgroup>
                                                <optgroup label="Comparison">
                                                    <option value="bulletChart">Bullet Chart</option>
                                                    <option value="marimekko">Marimekko</option>
                                                    <option value="dotPlot">Dot Plot</option>
                                                    <option value="lollipop">Lollipop Chart</option>
                                                    <option value="dumbbell">Dumbbell Chart</option>
                                                    <option value="slope">Slope Chart</option>
                                                    <option value="divergingBar">Diverging Bar</option>
                                                    <option value="spanChart">Span Chart</option>
                                                    <option value="pairedBar">Paired Bar</option>
                                                    <option value="populationPyramid">Population Pyramid</option>
                                                </optgroup>
                                                <optgroup label="Geographic">
                                                    <option value="choropleth">Choropleth Map</option>
                                                    <option value="bubbleMap">Bubble Map</option>
                                                    <option value="heatMapGeo">Heat Map Geographic</option>
                                                    <option value="flowMap">Flow Map</option>
                                                    <option value="spikeMap">Spike Map</option>
                                                </optgroup>
                                                <optgroup label="Relationship">
                                                    <option value="networkGraph">Network Graph</option>
                                                    <option value="chordDiagram">Chord Diagram</option>
                                                    <option value="arcDiagram">Arc Diagram</option>
                                                    <option value="forceDirected">Force-Directed</option>
                                                    <option value="matrix">Matrix Chart</option>
                                                </optgroup>
                                                <optgroup label="Part-to-Whole">
                                                    <option value="stackedBar100">100% Stacked Bar</option>
                                                    <option value="stackedArea100">100% Stacked Area</option>
                                                    <option value="waffleChart">Waffle Chart</option>
                                                    <option value="pictograph">Pictograph</option>
                                                    <option value="nightingaleRose">Nightingale Rose</option>
                                                </optgroup>
                                                <optgroup label="KPI / Metrics">
                                                    <option value="kpiCard">KPI Card</option>
                                                    <option value="sparkline">Sparkline</option>
                                                    <option value="progressBar">Progress Bar</option>
                                                    <option value="radialProgress">Radial Progress</option>
                                                    <option value="metricTile">Metric Tile</option>
                                                </optgroup>
                                                <optgroup label="Data / Interactive">
                                                    <option value="table">Table Chart</option>
                                                    <option value="slicer">Slicer</option>
                                                    <option value="navigation">Navigation Link</option>
                                                </optgroup>
                                            </select>
                                        </div>
                                        <div class="row g-2">
                                            <div class="col-6">
                                                <label class="form-label">Width (cols)</label>
                                                <select id="prop-width" class="form-select form-select-sm">
                                                    <option value="2">2</option>
                                                    <option value="3">3</option>
                                                    <option value="4">4</option>
                                                    <option value="5">5</option>
                                                    <option value="6" selected>6</option>
                                                    <option value="8">8</option>
                                                    <option value="12">12</option>
                                                </select>
                                            </div>
                                            <div class="col-6">
                                                <label class="form-label">Height (px)</label>
                                                <input type="number" id="prop-height" class="form-control form-control-sm" min="150" max="800" step="50">
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Data (chart-only) -->
                                    <div class="prop-section chart-only-section">
                                        <div class="prop-section-title" data-section="data">Data</div>
                                        <div class="mb-2">
                                        <div class="prop-subgroup">
                                            <div class="mb-2">
                                                <label class="form-label">Table</label>
                                                <select id="prop-dataset" class="form-select form-select-sm" onchange="propertiesPanel.datasetChanged()">
                                                    <option value="">-- Select table --</option>
                                                </select>
                                            </div>
                                            <div class="mb-2">
                                                <label class="form-label">Legend Field</label>
                                                <select id="prop-label-field" class="form-select form-select-sm field-select"></select>
                                            </div>
                                            <div class="mb-2">
                                                <label class="form-label mb-0">Value Field</label>
                                                <div class="d-flex gap-1 align-items-center">
                                                    <select id="prop-value-field" class="form-select form-select-sm field-select" style="flex:1"></select>
                                                    <select id="prop-value-field-agg" class="form-select form-select-sm value-field-agg-select" style="width:auto;min-width:90px;font-size:0.72rem;" title="Aggregation">
                                                        <option value="None">No Agg</option>
                                                        <option value="SUM" selected>Sum</option>
                                                        <option value="AVG">Average</option>
                                                        <option value="COUNT">Count</option>
                                                        <option value="COUNT_DISTINCT">Count (Distinct)</option>
