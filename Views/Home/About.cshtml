@{
    ViewData["Title"] = "About";
}

<section class="cp-section cp-page-hero">
    <div class="container">
        <h1 class="page-title">About ChatPortal2</h1>
        <p class="page-subtitle">Our mission is to democratize data analytics with AI-powered conversations.</p>
    </div>
</section>

<section class="cp-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="content-card glass-card">
                    <h2><i class="bi bi-bullseye me-2 text-primary"></i>Our Mission</h2>
                    <p>We believe everyone should be able to understand their data without needing to write SQL or hire a data scientist. ChatPortal2 makes data conversations as natural as chatting with a colleague.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="content-card glass-card">
                    <h2><i class="bi bi-lightning-fill me-2 text-primary"></i>Our Technology</h2>
                    <p>Built on ASP.NET Core 8, powered by Cohere AI, with 72+ chart types from Chart.js. We use the latest LLMs to understand your questions and translate them into accurate data queries.</p>
                </div>
            </div>
        </div>
    </div>
</section>
