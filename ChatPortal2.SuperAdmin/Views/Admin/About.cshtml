@{
    ViewData["Title"] = "About";
    ViewData["ActivePage"] = "about";
}

<div class="page-header">
    <h1 class="page-title">About ChatPortal2</h1>
    <p class="page-desc">Platform overview, version information, and project summary.</p>
</div>

<div class="row g-4" style="display:flex;flex-wrap:wrap;gap:1.25rem;">
    <!-- Project Overview -->
    <div style="flex:1;min-width:320px;">
        <div class="card-panel" style="height:100%;">
            <div class="card-panel-title"><i class="bi bi-lightbulb" style="margin-right:.35rem;"></i>Project Overview</div>
            <p style="font-size:.88rem;line-height:1.7;color:var(--text-dim);">
                <strong style="color:#1e3a5f;">ChatPortal2</strong> is an AI-powered team collaboration and analytics platform
                that brings together real-time chat, intelligent agents, dynamic dashboards, and automated reporting
                in a single unified workspace.
            </p>
            <p style="font-size:.88rem;line-height:1.7;color:var(--text-dim);margin-top:.75rem;">
                Organizations can create workspaces, connect data sources (SQL Server, PostgreSQL, MySQL),
                build AI agents powered by Cohere LLMs, generate interactive dashboards and reports — all through
                natural language conversations.
            </p>
        </div>
    </div>

    <!-- Version Info -->
    <div style="flex:0 0 280px;">
        <div class="card-panel" style="height:100%;">
            <div class="card-panel-title"><i class="bi bi-tag" style="margin-right:.35rem;"></i>Version</div>
            <div style="text-align:center;padding:1rem 0;">
                <div style="font-size:2rem;font-weight:700;color:#4a8ec9;">v1.0</div>
                <div style="font-size:.78rem;color:var(--text-muted);margin-top:.3rem;">AI Insights Release</div>
                <div style="font-size:.75rem;color:var(--text-muted);margin-top:.15rem;">.NET 8 · ASP.NET Core</div>
            </div>
            <div style="border-top:1px solid var(--border);padding-top:.75rem;margin-top:.5rem;">
                <div style="display:flex;justify-content:space-between;font-size:.8rem;margin-bottom:.4rem;">
                    <span style="color:var(--text-muted);">Framework</span>
                    <span style="color:var(--text);font-weight:600;">.NET 8.0</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:.8rem;margin-bottom:.4rem;">
                    <span style="color:var(--text-muted);">Database</span>
                    <span style="color:var(--text);font-weight:600;">SQL Server</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:.8rem;margin-bottom:.4rem;">
                    <span style="color:var(--text-muted);">AI Engine</span>
                    <span style="color:var(--text);font-weight:600;">Cohere</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:.8rem;">
                    <span style="color:var(--text-muted);">Auth</span>
                    <span style="color:var(--text);font-weight:600;">JWT + Identity</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Key Features -->
