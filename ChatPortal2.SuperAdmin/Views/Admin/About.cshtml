            <div>
                <div style="font-weight:600;font-size:.85rem;color:#1e3a5f;">AI Chat</div>
                <div style="font-size:.78rem;color:var(--text-muted);">Natural language queries against your connected data sources with Cohere-powered agents.</div>
            </div>
        </div>
        <div style="display:flex;gap:.65rem;align-items:flex-start;">
            <div class="stat-icon" style="background:rgba(52,211,153,.1);color:#34d399;flex-shrink:0;width:34px;height:34px;font-size:.85rem;"><i class="bi bi-bar-chart-fill"></i></div>
