@model List<ChatPortal2.Models.SeoEntry>
@{
    ViewData["Title"] = "SEO Management";
    ViewData["ActivePage"] = "seo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-search me-2 text-primary"></i>SEO Management</h2>
    <button class="btn btn-sa btn-sm" onclick="openAddModal()"><i class="bi bi-plus-lg me-1"></i>Add Entry</button>
</div>

<div id="saveAlert" class="alert alert-success d-none mb-3">Changes saved successfully.</div>

<div class="sa-card p-0">
    <table class="sa-table">
        <thead>
            <tr>
                <th>Page URL</th>
                <th>Title</th>
                <th>Meta Description</th>
                <th>Last Updated</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in Model)
            {
                <tr>
                    <td><code>@entry.PageUrl</code></td>
                    <td>@entry.Title</td>
                    <td class="text-muted" style="font-size:0.8rem">@(entry.MetaDescription?.Length > 80 ? entry.MetaDescription[..80] + "…" : entry.MetaDescription)</td>
                    <td class="text-muted">@entry.LastModified.ToString("MMM d, yyyy")</td>
                    <td>
                        <button class="btn btn-sa btn-sm" onclick='editEntry(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(entry)))'>
                            <i class="bi bi-pencil-square"></i> Edit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Edit/Add Modal -->
<div class="modal fade" id="seoModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="background:#1e293b;color:#e2e8f0;border:1px solid rgba(255,255,255,0.12)">
            <div class="modal-header border-bottom" style="border-color:rgba(255,255,255,0.1)!important">
                <h5 class="modal-title fw-bold" id="modalTitle">Edit SEO Entry</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="entryId" value="0" />
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small text-muted">Page URL</label>
                        <input type="text" id="entryPageUrl" class="form-control form-control-sm sa-input" placeholder="/page-path" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Title</label>
                        <input type="text" id="entryTitle" class="form-control form-control-sm sa-input" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">OG Title</label>
                        <input type="text" id="entryOgTitle" class="form-control form-control-sm sa-input" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted">Meta Description</label>
                        <textarea id="entryMetaDescription" class="form-control form-control-sm sa-input" rows="2"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted">OG Description</label>
                        <textarea id="entryOgDescription" class="form-control form-control-sm sa-input" rows="2"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Meta Keywords</label>
                        <input type="text" id="entryMetaKeywords" class="form-control form-control-sm sa-input" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Robots Directive</label>
                        <select id="entryRobots" class="form-select form-select-sm sa-input">
                            <option>index, follow</option>
                            <option>noindex, follow</option>
                            <option>index, nofollow</option>
                            <option>noindex, nofollow</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top" style="border-color:rgba(255,255,255,0.1)!important">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sa btn-sm" onclick="saveSeoEntry()"><i class="bi bi-check-lg me-1"></i>Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<style>
    .sa-input { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); color: #e2e8f0; }
    .sa-input:focus { background: rgba(255,255,255,0.1); color: #e2e8f0; border-color: #60a5fa; box-shadow: none; }
    .sa-input option { background: #1e293b; color: #e2e8f0; }
</style>
<script>
var seoModal;
document.addEventListener('DOMContentLoaded', function () {
    seoModal = new bootstrap.Modal(document.getElementById('seoModal'));
});

function openAddModal() {
    document.getElementById('modalTitle').textContent = 'Add SEO Entry';
    document.getElementById('entryId').value = 0;
    document.getElementById('entryPageUrl').value = '';
    document.getElementById('entryTitle').value = '';
    document.getElementById('entryOgTitle').value = '';
    document.getElementById('entryMetaDescription').value = '';
    document.getElementById('entryOgDescription').value = '';
    document.getElementById('entryMetaKeywords').value = '';
    document.getElementById('entryRobots').value = 'index, follow';
    seoModal.show();
}

function editEntry(entry) {
    document.getElementById('modalTitle').textContent = 'Edit SEO Entry';
    document.getElementById('entryId').value = entry.id;
    document.getElementById('entryPageUrl').value = entry.pageUrl || '';
    document.getElementById('entryTitle').value = entry.title || '';
    document.getElementById('entryOgTitle').value = entry.ogTitle || '';
    document.getElementById('entryMetaDescription').value = entry.metaDescription || '';
    document.getElementById('entryOgDescription').value = entry.ogDescription || '';
    document.getElementById('entryMetaKeywords').value = entry.metaKeywords || '';
    document.getElementById('entryRobots').value = entry.robotsDirective || 'index, follow';
    seoModal.show();
}

async function saveSeoEntry() {
    const payload = {
        id: parseInt(document.getElementById('entryId').value),
        pageUrl: document.getElementById('entryPageUrl').value,
        title: document.getElementById('entryTitle').value,
        ogTitle: document.getElementById('entryOgTitle').value,
        metaDescription: document.getElementById('entryMetaDescription').value,
        ogDescription: document.getElementById('entryOgDescription').value,
        metaKeywords: document.getElementById('entryMetaKeywords').value,
        robotsDirective: document.getElementById('entryRobots').value
    };
    try {
        const res = await fetch('/superadmin/seo/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        if (res.ok) {
            seoModal.hide();
            var alert = document.getElementById('saveAlert');
            alert.classList.remove('d-none');
            setTimeout(() => { alert.classList.add('d-none'); location.reload(); }, 1500);
        } else {
            alert('Save failed. Please try again.');
        }
    } catch (e) {
        alert('Network error: ' + e.message);
    }
}
</script>
}
