@{
    ViewData["Title"] = "Org Health Score";
    ViewData["ActivePage"] = "health";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .filter-row { display:flex;gap:.75rem;flex-wrap:wrap;align-items:flex-end; }
    .score-bar-wrap { display:flex;align-items:center;gap:.5rem;min-width:140px; }
    .score-bar { flex:1;background:rgba(0,0,0,.08);border-radius:4px;height:6px }
    .score-fill { height:6px;border-radius:4px;transition:width .4s }
    .detail-panel { background:rgba(74,142,201,.04);border:1px solid var(--border);border-radius:10px;padding:1rem;
                    margin-top:.5rem;display:none }
    .sub-row { display:flex;justify-content:space-between;padding:.3rem 0;border-bottom:1px solid var(--border-light);font-size:.82rem }
    .sub-row:last-child { border-bottom:none }
    .tip { color:var(--text-muted);font-size:.78rem;padding:.25rem 0; display:flex;gap:.4rem;align-items:baseline }
    .tip i { color:#f59e0b;flex-shrink:0 }
</style>

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title">Org Health Score</h1>
        <p class="page-desc">Composite score (0–100) per organisation — cached for 10 min. Click any row for details.</p>
    </div>
    <button class="btn-ghost-sm" onclick="loadHealth()"><i class="bi bi-arrow-clockwise"></i>Refresh</button>
</div>

<div class="card-panel" style="overflow-x:auto">
    <table class="tbl" id="healthTable">
        <thead>
            <tr>
                <th id="th-org" style="cursor:pointer">Organization ↕</th>
                <th id="th-plan" style="cursor:pointer">Plan ↕</th>
                <th id="th-score" style="cursor:pointer">Score ↕</th>
                <th>Activity</th>
                <th>Engagement</th>
                <th>Support</th>
                <th>Payments</th>
                <th>Adoption</th>
                <th>Active Users</th>
            </tr>
        </thead>
        <tbody>
            <tr><td colspan="9" style="text-align:center;color:var(--text-muted);padding:2rem">Loading…</td></tr>
        </tbody>
    </table>
</div>

@section Scripts {
<script>
(function() {
    let rows = [];
    let sortCol = 'score', sortAsc = false;

    function scoreColor(s) {
        if (s >= 70) return '#34d399';
        if (s >= 40) return '#f59e0b';
        return '#fb7185';
    }
    function scoreBadge(s) {
        const cls = s >= 70 ? 'badge-emerald' : s >= 40 ? 'badge-amber' : 'badge-rose';
        return `<span class="badge-sm ${cls}" style="font-size:.78rem;min-width:36px;justify-content:center;display:inline-flex">${s}</span>`;
    }
    function subBar(val, max) {
        const pct = Math.round(val / max * 100);
        return `<div class="score-bar" style="width:60px;display:inline-block;vertical-align:middle;margin-left:.3rem">
                    <div class="score-fill" style="width:${pct}%;background:${scoreColor(pct)}"></div>
                </div>`;
    }
    function planBadge(p) { return `<span class="badge-sm badge-indigo">${p}</span>`; }

    function renderTable() {
        const sorted = [...rows].sort((a,b) => {
            const av = a[sortCol], bv = b[sortCol];
            return typeof av === 'string'
                ? (sortAsc ? av.localeCompare(bv) : bv.localeCompare(av))
                : (sortAsc ? av - bv : bv - av);
        });
        const tbody = document.querySelector('#healthTable tbody');
        while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
        if (!sorted.length) {
            const tr = tbody.insertRow(); const td = tr.insertCell();
            td.colSpan = 9; td.style.cssText = 'text-align:center;color:var(--text-muted)';
            td.textContent = 'No data.';
            return;
        }

        sorted.forEach((r, i) => {
            // Main data row
            const tr = tbody.insertRow();
            tr.style.cursor = 'pointer';
            tr.dataset.idx  = i;
            tr.addEventListener('click', () => toggleDetail(i));

            const c0 = tr.insertCell(); c0.style.cssText = 'font-weight:600;color:#1e3a5f'; c0.textContent = r.orgName;
            const c1 = tr.insertCell(); c1.innerHTML = planBadge(r.plan); // plan badge is static markup, not user data
            const c2 = tr.insertCell(); c2.innerHTML = `<div class="score-bar-wrap">${scoreBadge(r.healthScore)}<div class="score-bar"><div class="score-fill" style="width:${r.healthScore}%;background:${scoreColor(r.healthScore)}"></div></div></div>`;
            const c3 = tr.insertCell(); c3.innerHTML = r.activityScore + '/30 ' + subBar(r.activityScore, 30);
            const c4 = tr.insertCell(); c4.innerHTML = r.engagementScore + '/20 ' + subBar(r.engagementScore, 20);
            const c5 = tr.insertCell(); c5.innerHTML = r.supportScore + '/15 ' + subBar(r.supportScore, 15);
            const c6 = tr.insertCell(); c6.innerHTML = r.paymentScore + '/20 ' + subBar(r.paymentScore, 20);
            const c7 = tr.insertCell(); c7.innerHTML = r.adoptionScore + '/15 ' + subBar(r.adoptionScore, 15);
            const c8 = tr.insertCell(); c8.textContent = r.activeUsers + '/' + r.totalUsers;

            // Detail expand row
            const detailTr = document.createElement('tr');
            detailTr.id = 'detail-' + i;
            detailTr.style.display = 'none';
            const detailTd = document.createElement('td');
            detailTd.colSpan = 9;
            detailTd.style.cssText = 'padding:.25rem 1rem 1rem';

            const panel = document.createElement('div');
            panel.className = 'detail-panel';
            panel.id = 'panel-' + i;

            const subHeader = document.createElement('div');
            subHeader.style.cssText = 'font-size:.78rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.5rem';
            subHeader.textContent = 'Sub-scores';
            panel.appendChild(subHeader);

            const hints = [
                ['Activity (30 pts)',    r.activityScore,   30, 'msgs/active-user/day in last 7 days'],
                ['Engagement (20 pts)',  r.engagementScore, 20, r.activeUsers + ' of ' + r.totalUsers + ' users active this week'],
                ['Support (15 pts)',     r.supportScore,    15, r.openTickets + ' open support ticket(s)'],
                ['Payments (20 pts)',    r.paymentScore,    20, r.lastPaymentAt ? 'Last payment: ' + new Date(r.lastPaymentAt).toLocaleDateString() : 'No payments'],
                ['Adoption (15 pts)',    r.adoptionScore,   15, 'Dashboard + datasource creation']
            ];
            hints.forEach(([label, val, max, hint]) => {
                const row2 = document.createElement('div'); row2.className = 'sub-row';
                const s1 = document.createElement('span'); s1.textContent = label;
                const s2 = document.createElement('span'); s2.style.cssText = 'display:flex;align-items:center;gap:.4rem';
                const s3 = document.createElement('span'); s3.style.cssText = 'font-weight:600;color:' + scoreColor(Math.round(val / max * 100)); s3.textContent = val + '/' + max;
                const s4 = document.createElement('span'); s4.style.cssText = 'color:var(--text-muted);font-size:.78rem'; s4.textContent = hint;
                s2.appendChild(s3); s2.appendChild(s4);
                row2.appendChild(s1); row2.appendChild(s2);
                panel.appendChild(row2);
            });

            if (r.tips && r.tips.length) {
                const tipWrap = document.createElement('div'); tipWrap.style.marginTop = '.75rem';
                r.tips.forEach(t => {
                    const tipDiv = document.createElement('div'); tipDiv.className = 'tip';
                    const icon = document.createElement('i'); icon.className = 'bi bi-lightbulb';
                    tipDiv.appendChild(icon);
                    tipDiv.appendChild(document.createTextNode(t)); // text node is safe
                    tipWrap.appendChild(tipDiv);
                });
                panel.appendChild(tipWrap);
            }

            detailTd.appendChild(panel);
            detailTr.appendChild(detailTd);
            tbody.appendChild(detailTr);
        });
    }

    window.toggleDetail = function(idx) {
        const row   = document.getElementById('detail-' + idx);
        const panel = document.getElementById('panel-' + idx);
        const show  = row.style.display === 'none';
        row.style.display   = show ? 'table-row' : 'none';
        panel.style.display = show ? 'block' : 'none';
    };

    ['org','plan','score'].forEach(col => {
        document.getElementById('th-' + col).addEventListener('click', () => {
            const key = { org:'orgName', plan:'plan', score:'healthScore' }[col];
            if (sortCol === key) sortAsc = !sortAsc; else { sortCol = key; sortAsc = col !== 'score'; }
            renderTable();
        });
    });

    window.loadHealth = function() {
        fetch('/api/superadmin/insights/health')
            .then(r => r.json())
            .then(data => { rows = data; renderTable(); })
            .catch(() => {
                document.querySelector('#healthTable tbody').innerHTML =
                    '<tr><td colspan="9" style="text-align:center;color:#fb7185">Failed to load data.</td></tr>';
            });
    };

    loadHealth();
})();
</script>
}
