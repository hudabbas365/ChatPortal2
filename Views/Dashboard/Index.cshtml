                }
            });
        });

        (function wireDashboardTheme() {
            const themeSelect = document.getElementById('dashboard-theme-select');
            const applyBtn = document.getElementById('dashboard-theme-apply-btn');
            const customWrap = document.getElementById('dashboard-theme-custom-colors');
            const customColorInputs = () => Array.from(document.querySelectorAll('[data-custom-theme-color]')).map(i => i.value);
            const presets = {
                ocean: 'ocean',
                sunset: 'sunset',
                forest: 'forest',
                midnight: 'midnight',
                pastel: 'pastel',
                corporate: 'corporate',
                retro: 'retro',
                neon: 'neon',
                earth: 'earth',
                monochrome: 'monochrome'
            };

            function selectedPalette() {
                const t = themeSelect?.value || 'ocean';
                if (t === 'custom') {
                    return 'custom:' + customColorInputs().join(',');
                }
                return presets[t] || 'default';
            }

            let _themeApplyInFlight = null;
            let _themeApplyPending = false;
            async function _doApplyTheme() {
                const palette = selectedPalette();
                localStorage.setItem('cp_dashboard_chart_theme', JSON.stringify({
                    theme: themeSelect?.value || 'ocean',
                    palette,
                    customColors: customColorInputs()
                }));
                const charts = (canvasManager?.charts || []).filter(c => !(window.ShapeManager && ShapeManager.isShape(c.chartType)) && c.chartType !== 'navigation');
                // Serialize chart updates so each completes before next render starts.
                // Prevents ApexCharts race where a destroyed instance's pending
                // microtasks throw "undefined.colors" against its freed state.
                for (const c of charts) {
                    c.style = c.style || {};
                    c.style.colorPalette = palette;
                    try { await canvasManager.updateChart(c); } catch (_) {}
                }
            }
            async function applyThemeToCharts() {
                // Coalesce rapid calls: if one pass is running, queue exactly one
                // follow-up pass using the latest palette selection.
                if (_themeApplyInFlight) { _themeApplyPending = true; return _themeApplyInFlight; }
                _themeApplyInFlight = (async () => {
                    try {
                        do {
                            _themeApplyPending = false;
                            await _doApplyTheme();
                        } while (_themeApplyPending);
                    } finally {
                        _themeApplyInFlight = null;
                    }
                })();
                return _themeApplyInFlight;
            }

            function syncCustomVisibility() {
                if (!customWrap || !themeSelect) return;
                customWrap.classList.toggle('d-none', themeSelect.value !== 'custom');
            }

            function renderThemePreview() {
                const preview = document.getElementById('dashboard-theme-preview');
                if (!preview || !window.chartRenderer) return;
                const t = themeSelect?.value || 'ocean';
                if (t === 'custom') { preview.innerHTML = ''; return; }
                const colors = window.chartRenderer.colorPalettes[t] || window.chartRenderer.colorPalettes.default;
                preview.innerHTML = colors.map(c =>
                    '<span style="width:24px;height:24px;border-radius:4px;background:' + c + ';display:inline-block;border:1px solid rgba(0,0,0,0.1);" title="' + c + '"></span>'
                ).join('');
            }

            themeSelect?.addEventListener('change', function() { syncCustomVisibility(); renderThemePreview(); });
            applyBtn?.addEventListener('click', applyThemeToCharts);
            renderThemePreview();

            try {
                const saved = JSON.parse(localStorage.getItem('cp_dashboard_chart_theme') || 'null');
                if (saved && themeSelect) {
                    themeSelect.value = saved.theme || 'ocean';
                    syncCustomVisibility();
                    if (saved.customColors && saved.customColors.length) {
                        document.querySelectorAll('[data-custom-theme-color]').forEach((el, idx) => {
                            if (saved.customColors[idx]) el.value = saved.customColors[idx];
                        });
                    }
                    applyThemeToCharts();
                }
            } catch {}
        })();

        // ── Report Topnav context ─────────────────────────────
        (function wireReportTopnav() {
            const params = new URLSearchParams(window.location.search);
            const wsGuid = params.get('workspace') || params.get('ws');
            const dsName = params.get('datasource') || params.get('ds');
            const agentName = params.get('agent');

            if (wsGuid) {
                const topnav = document.getElementById('reportTopnav');
                if (topnav) topnav.style.display = '';
                const wsTag = document.getElementById('reportWsTag');
                const wsName = document.getElementById('reportWsName');
                if (wsTag && wsName) {
                    wsName.textContent = wsGuid;
                    wsTag.style.display = '';
                    wsTag.title = 'Back to workspace';
                            wsTag.style.cursor = 'pointer';
                            wsTag.addEventListener('click', () => {
                                // Workspace landing page lives at root ('/') and auto-selects via
                                // ?workspace=<guid>; do NOT include ?agent= (that would route to the
                                // agent chat instead of the workspace overview).
                                window.location.href = '/?workspace=' + encodeURIComponent(wsGuid);
                            });
                    fetch('/api/workspaces/' + encodeURIComponent(wsGuid))
                        .then(r => r.ok ? r.json() : null)
                        .then(async data => {
                            if (data) {
                                wsName.textContent = data.name || wsGuid;
                                window._dashboardWsData = data;
                                // Auto-populate datasource and agent from workspace data
                                const dsList = data.datasources || [];
                                const agentList = data.agents || [];

                                // Resolve which agent to use: prefer URL ?agent= param, else first agent
                                const agentParam = params.get('agent');
                                let selectedAgent = agentList.length > 0 ? agentList[0] : null;
                                if (agentParam && agentList.length > 0) {
                                    const match = agentList.find(a => a.guid === agentParam || String(a.id) === agentParam);
                                    if (match) selectedAgent = match;
                                }

                                // Helper to apply agent + datasource context
                                async function applyAgentContext(agent) {
                                    if (!agent) return;
                                    window.currentAgentGuid = agent.guid || null;
                                    const agentDs = agent.datasourceId
                                        ? (dsList.find(d => d.id === agent.datasourceId) || null)
                                        : null;
                                    if (agentDs) {
                                        window.currentDatasourceId = agentDs.id;
                                        if (agentDs.type) window.currentDatasourceType = agentDs.type;
                                        // Update datasource breadcrumb
                                        const dsEl = document.getElementById('reportDsName');
                                        const dsTag = document.getElementById('reportDsTag');
                                        const dsSep = document.getElementById('reportDsSep');
                                        if (dsEl) dsEl.textContent = agentDs.name;
                                        if (dsTag) { dsTag.style.display = ''; dsTag.title = 'Datasource: ' + agentDs.name; }
                                        if (dsSep) dsSep.style.display = '';
                                        // Reload tables FIRST, then load fields (sequential to avoid race)
                                        const tableNames = await loadDatasourceTables(agentDs.id);
                                        if (tableNames && tableNames.length > 0) {
                                            const chips = document.querySelectorAll('#dcpMessages .dcp-chip');
                                            const t1 = tableNames[0] || 'data';
                                            const t2 = tableNames.length > 1 ? tableNames[1] : t1;
                                            const suggestions = [
                                                'Show a bar chart from ' + t1,
                                                'Summarize ' + t2 + ' data',
                                                'Add a trend line chart',
                                                'Compare top records in ' + t1
                                            ];
                                            chips.forEach(function(chip, i) {
                                                if (suggestions[i]) chip.textContent = suggestions[i];
                                            });
                                            // Load fields for the first table so Data Fields panel is populated
                                            if (window.propertiesPanel) await propertiesPanel.loadFields(tableNames[0]);
                                        } else {
                                            if (window.propertiesPanel) await propertiesPanel.loadFields('');
                                        }
                                    }
                                    // Update agent breadcrumb
                                    const agEl = document.getElementById('reportAgentName');
                                    const agTag = document.getElementById('reportAgentTag');
                                    const agSep = document.getElementById('reportAgentSep');
                                    if (agEl) agEl.textContent = agent.name;
                                    if (agTag) { agTag.style.display = ''; agTag.title = 'Agent: ' + agent.name; }
                                    if (agSep) agSep.style.display = '';
                                }

                                // Apply the initially selected agent
                                if (dsList.length > 0 || agentList.length > 0) {
                                    await applyAgentContext(selectedAgent);
                                }
                            }
                        }).catch(() => {});
                }
            }
            if (dsName) {
                const dsTag = document.getElementById('reportDsTag');
                const dsEl = document.getElementById('reportDsName');
                const dsSep = document.getElementById('reportDsSep');
                if (dsTag && dsEl) { dsEl.textContent = dsName; dsTag.style.display = ''; }
                if (dsSep) dsSep.style.display = '';
            }
            if (agentName) {
                const agTag = document.getElementById('reportAgentTag');
                const agEl = document.getElementById('reportAgentName');
                const agSep = document.getElementById('reportAgentSep');
                if (agTag && agEl) { agEl.textContent = agentName; agTag.style.display = ''; }
                if (agSep) agSep.style.display = '';
            }
        })();

        // ── Load real datasource tables into Dataset dropdown ─
        async function loadDatasourceTables(dsId) {
            try {
                const resp = await fetch('/api/datasources/' + dsId + '/tables');
                if (!resp.ok) return [];
                const tables = await resp.json();
                if (!tables || !tables.length) return [];
                // API returns objects {name, type, rowCount} or strings
                // Check for REST API errors in table entries
                const apiErr = tables.find(t => t.error);
                if (apiErr && apiErr.error) {
                    console.warn('Datasource error:', apiErr.error);
                    window._lastDatasourceError = apiErr.error;
                }
                const tableNames = tables
                    .map(t => typeof t === 'string' ? t : (t.name || t.Name || ''))
                    .filter(n => n);
                if (!tableNames.length) return [];
                // Store globally for other components
                window._realTableNames = tableNames;
                const ds = document.getElementById('prop-dataset');
                if (ds) {
                    ds.innerHTML = '<option value="">-- Select table --</option>';
                    tableNames.forEach(name => {
                        const opt = document.createElement('option');
                        opt.value = name;
                        opt.textContent = name;
                        ds.appendChild(opt);
                    });
                }
                // Auto-rebind existing charts whose datasetName doesn't match any real table
                if (canvasManager && canvasManager.charts && canvasManager.charts.length > 0) {
                    const lowerNames = tableNames.map(n => n.toLowerCase());
                    let needsRerender = false;
                    canvasManager.charts.forEach(chart => {
                        if (chart.datasetName && !lowerNames.includes(chart.datasetName.toLowerCase())) {
                            chart.datasetName = tableNames[0];
                            needsRerender = true;
                        }
                        if (!chart.datasourceId && window.currentDatasourceId) {
                            chart.datasourceId = window.currentDatasourceId;
                            needsRerender = true;
                        }
                    });
                    if (needsRerender) canvasManager.renderAll();
                }
                return tableNames;
            } catch(e) { console.warn('Could not load datasource tables:', e); return []; }
        }

        // ── Save Draft button (quick auto-save without modal, status stays Draft) ─
        document.getElementById('saveDraftBtn')?.addEventListener('click', async function() {
            const params = new URLSearchParams(window.location.search);
            const wsGuid = params.get('workspace') || params.get('ws');
            if (!wsGuid) { alert('Open this dashboard from a workspace to save drafts.'); return; }

            const btn = this;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Saving...';
            try {
                canvasManager.pages[canvasManager.activePageIndex].charts = canvasManager.charts;
                const canvasJson = JSON.stringify({
                    pages: canvasManager.pages,
                    activePageIndex: canvasManager.activePageIndex
                });
                const chartIds = canvasManager.charts.map(c => c.id);
                const wsData = window._dashboardWsData || {};
                const defaultName = document.getElementById('canvas-name-display')?.textContent || ('Draft — ' + new Date().toLocaleDateString());
                let resolvedGuid = window._currentReportGuid || null;

                // Try to find existing report for this (workspace, agent) pair. Scoping by
                // agent is critical — without it, saving a new report for Agent B would
                // upsert onto Agent A's existing report in the same workspace.
                const currentAgentId = window.currentAgentGuid
                    ? (((wsData.agents || []).find(a => a.guid === window.currentAgentGuid) || {}).id || null)
                    : null;
                if (!resolvedGuid && wsGuid) {
                    try {
                        let lookupUrl = '/api/reports?workspaceGuid=' + encodeURIComponent(wsGuid);
                        if (currentAgentId) lookupUrl += '&agentId=' + encodeURIComponent(currentAgentId);
                        else if (window.currentAgentGuid) lookupUrl += '&agentGuid=' + encodeURIComponent(window.currentAgentGuid);
                        const existing = await fetch(lookupUrl);
                        if (existing.ok) {
                            const reports = await existing.json();
                            // Defensive client-side filter: only adopt a report that matches
                            // the current agent. Fall back to reports[0] only when no agent
                            // context is set (legacy workspace-only reports).
                            const match = currentAgentId
                                ? reports.find(r => r.agentId === currentAgentId)
                                : (reports[0] || null);
                            if (match) {
                                resolvedGuid = match.guid;
                                window._currentReportGuid = resolvedGuid;
                            }
                        }
                    } catch { /* proceed with create */ }
                }

                let resp;
                if (resolvedGuid) {
                    resp = await fetch('/api/reports/' + encodeURIComponent(resolvedGuid), {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ name: defaultName, chartIds, canvasJson, status: 'Draft' })
                    });
                } else {
                    const user = JSON.parse(localStorage.getItem('cp_user') || 'null');
                    resp = await fetch('/api/reports', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            workspaceGuid: wsGuid,
                            name: defaultName,
                            chartIds,
                            canvasJson,
                            datasourceId: window.currentDatasourceId || (wsData.datasources || [])[0]?.id || null,
                            agentId: window.currentAgentGuid ? ((wsData.agents || []).find(a => a.guid === window.currentAgentGuid) || {}).id || null : (wsData.agents || [])[0]?.id || null,
                            createdBy: user?.id || null
                        })
                    });
                }
                if (!resp.ok) throw new Error();
                const report = await resp.json();
                window._currentReportGuid = report.guid;
                const viewBtn = document.getElementById('viewReportBtn');
                if (viewBtn) {
                    viewBtn.style.display = '';
                    viewBtn.onclick = () => window.open('/report/view/' + report.guid, '_blank');
                }
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Draft Saved!';
                setTimeout(() => {
                    btn.innerHTML = '<i class="bi bi-file-earmark-medical me-1"></i>Save Draft';
                    btn.disabled = false;
                }, 1200);
            } catch {
                alert('Failed to save draft.');
                btn.innerHTML = '<i class="bi bi-file-earmark-medical me-1"></i>Save Draft';
                btn.disabled = false;
            }
        });

        // ── Ctrl+S keyboard shortcut to save draft ─
        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                e.preventDefault();
                document.getElementById('saveDraftBtn')?.click();
            }
        });

        // ── Auto-save every 5 minutes when changes detected ─
        (function() {
            let _lastCanvasSnapshot = '';
            let _autoSaveReady = false;
            function getCanvasSnapshot() {
                try {
                    if (!canvasManager || !canvasManager.pages || !canvasManager.charts) return '';
                    // Read-only snapshot — do NOT mutate pages here
                    var pagesClone = canvasManager.pages.map(function(p, i) {
                        return { charts: i === canvasManager.activePageIndex ? canvasManager.charts : (p.charts || []) };
                    });
                    return JSON.stringify({ pages: pagesClone, activePageIndex: canvasManager.activePageIndex });
                } catch { return ''; }
            }
            // Take initial snapshot after workspace data has loaded
            setTimeout(function() { _lastCanvasSnapshot = getCanvasSnapshot(); _autoSaveReady = true; }, 15000);
            setInterval(function() {
                if (!_autoSaveReady) return;
                var current = getCanvasSnapshot();
                if (!current) return;
                if (current !== _lastCanvasSnapshot) {
                    _lastCanvasSnapshot = current;
                    document.getElementById('saveDraftBtn')?.click();
                }
            }, 5 * 60 * 1000);
        })();

        // ── Save Report button (upsert: update existing or create new) ─
        document.getElementById('saveReportBtn')?.addEventListener('click', async function() {
            const params = new URLSearchParams(window.location.search);
            const wsGuid = params.get('workspace') || params.get('ws');
            if (!wsGuid) { alert('Open this dashboard from a workspace to save reports.'); return; }

            const btn = this;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Saving...';
            try {
                // Save current page charts before serializing
                canvasManager.pages[canvasManager.activePageIndex].charts = canvasManager.charts;
                const chartIds = canvasManager.charts.map(c => c.id);
                const canvasJson = JSON.stringify({
                    pages: canvasManager.pages,
                    activePageIndex: canvasManager.activePageIndex
                });
                const defaultReportName = document.getElementById('canvas-name-display')?.textContent || ('Report — ' + new Date().toLocaleDateString());
                const reportName = await window._openSaveReportModal(defaultReportName);
                if (!reportName) {
                    btn.innerHTML = '<i class="bi bi-file-earmark-check me-1"></i>Save Report';
                    btn.disabled = false;
                    return;
                }
                const user = JSON.parse(localStorage.getItem('cp_user') || 'null');
                const wsData = window._dashboardWsData || {};
                const existingGuid = window._currentReportGuid || null;

                let resp;
                // If no existing guid, check if workspace already has a report for THIS agent.
                // Scoping by agent prevents overwriting another agent's report in the same workspace.
                let resolvedGuid = existingGuid;
                const currentAgentId = window.currentAgentGuid
                    ? (((wsData.agents || []).find(a => a.guid === window.currentAgentGuid) || {}).id || null)
                    : null;
                if (!resolvedGuid && wsGuid) {
                    try {
                        let lookupUrl = '/api/reports?workspaceGuid=' + encodeURIComponent(wsGuid);
                        if (currentAgentId) lookupUrl += '&agentId=' + encodeURIComponent(currentAgentId);
                        else if (window.currentAgentGuid) lookupUrl += '&agentGuid=' + encodeURIComponent(window.currentAgentGuid);
                        const existing = await fetch(lookupUrl);
                        if (existing.ok) {
                            const reports = await existing.json();
                            const match = currentAgentId
                                ? reports.find(r => r.agentId === currentAgentId)
                                : (reports[0] || null);
                            if (match) {
                                resolvedGuid = match.guid;
                                window._currentReportGuid = resolvedGuid;
                            }
                        }
                    } catch { /* proceed with create */ }
                }
                if (resolvedGuid) {
                    // Update existing report
                    resp = await fetch('/api/reports/' + encodeURIComponent(resolvedGuid), {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            name: reportName,
                            chartIds: chartIds,
                            canvasJson: canvasJson,
                            status: 'Published'
                        })
                    });
                } else {
                    // Create new report
                    resp = await fetch('/api/reports', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            workspaceGuid: wsGuid,
                            name: reportName,
                            chartIds: chartIds,
                            canvasJson: canvasJson,
                            datasourceId: window.currentDatasourceId || (wsData.datasources || [])[0]?.id || null,
                            agentId: window.currentAgentGuid ? ((wsData.agents || []).find(a => a.guid === window.currentAgentGuid) || {}).id || null : (wsData.agents || [])[0]?.id || null,
                            createdBy: user?.id || null
                        })
                    });
                }
                if (!resp.ok) throw new Error();
                const report = await resp.json();
                // Track the report guid for subsequent saves
                window._currentReportGuid = report.guid;
                // Show View Report button
                const viewBtn = document.getElementById('viewReportBtn');
                if (viewBtn) {
                    viewBtn.style.display = '';
                    viewBtn.onclick = () => window.open('/report/view/' + report.guid, '_blank');
                }
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Saved!';
                setTimeout(() => {
                    btn.innerHTML = '<i class="bi bi-file-earmark-check me-1"></i>Save Report';
                    btn.disabled = false;
                }, 1200);
            } catch {
                alert('Failed to save report.');
                btn.innerHTML = '<i class="bi bi-file-earmark-check me-1"></i>Save Report';
                btn.disabled = false;
            }
        });
    });
})();

function promptRename() {
    const current = document.getElementById('canvas-name-display').textContent;
    const name = prompt('Enter canvas name:', current);
    if (name && name.trim()) {
        document.getElementById('canvas-name-display').textContent = name.trim();
        fetch(_chartApiUrl('/api/chart/rename'), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name.trim() })
        });
    }
}
</script>

<!-- Save Report Modal -->
<div class="modal fade" id="saveReportModal" tabindex="-1" aria-labelledby="saveReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px;border:1px solid var(--cp-border);background:var(--cp-surface);">
            <div class="modal-header" style="border-bottom:1px solid var(--cp-border);padding:16px 20px;">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-file-earmark-check" style="font-size:1.2rem;color:var(--cp-primary);"></i>
                    <h6 class="modal-title mb-0" id="saveReportModalLabel" style="font-weight:600;">Save Report</h6>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding:20px;">
                <label for="saveReportNameInput" class="form-label" style="font-size:0.85rem;font-weight:500;">Report Name</label>
                <input type="text" class="form-control" id="saveReportNameInput" maxlength="200" placeholder="Enter a name for this report" autocomplete="off" />
                <div class="form-text mt-1" style="font-size:0.78rem;">Give your report a descriptive name so you can find it later.</div>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--cp-border);padding:12px 20px;gap:8px;">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" id="saveReportModalConfirm">
                    <i class="bi bi-check-lg me-1"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>
<script>
// Wire the Save Report modal confirm
(function() {
    let _saveResolve = null;
    const modal = document.getElementById('saveReportModal');
    const input = document.getElementById('saveReportNameInput');
    const confirmBtn = document.getElementById('saveReportModalConfirm');
    if (!modal || !input || !confirmBtn) return;
    const bsModal = new bootstrap.Modal(modal);

    // Expose a promise-based open function
    window._openSaveReportModal = function(defaultName) {
        return new Promise((resolve) => {
            _saveResolve = resolve;
            input.value = defaultName || '';
            bsModal.show();
            setTimeout(() => { input.focus(); input.select(); }, 300);
        });
    };
    confirmBtn.addEventListener('click', () => {
        const val = input.value.trim();
        if (!val) { input.classList.add('is-invalid'); return; }
        input.classList.remove('is-invalid');
        bsModal.hide();
        if (_saveResolve) { _saveResolve(val); _saveResolve = null; }
    });
    input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); confirmBtn.click(); }
        input.classList.remove('is-invalid');
    });
    modal.addEventListener('hidden.bs.modal', () => {
        if (_saveResolve) { _saveResolve(null); _saveResolve = null; }
    });
})();
</script>

