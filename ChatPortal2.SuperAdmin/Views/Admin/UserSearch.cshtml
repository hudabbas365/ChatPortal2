@model List<AIInsights.SuperAdmin.Controllers.InsightsController.UserSearchItem>
@{
    ViewData["Title"] = "User Search";
    ViewData["ActivePage"] = "users";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">User Search</h1>
        <p class="page-desc">Search by name or email — click a row to view the activity timeline.</p>
    </div>
</div>

<div class="card-panel" style="margin-bottom:1rem">
    <form method="get" action="/superadmin/users" class="d-flex gap-2 flex-wrap">
        <input type="text" name="search" value="@ViewBag.Search" placeholder="Search by email or name…"
               class="form-control" style="max-width:320px;border:1px solid var(--border);border-radius:8px;padding:.45rem .75rem;font-size:.85rem;outline:none;font-family:inherit" />
        <button type="submit" class="btn-primary-sm"><i class="bi bi-search"></i>Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a href="/superadmin/users" class="btn-ghost-sm">Clear</a>
        }
    </form>
</div>

<div class="card-panel" style="overflow-x:auto">
    <table class="tbl">
        <thead>
            <tr>
                <th>Name / Email</th>
                <th>Role</th>
                <th>Organization</th>
                <th>Joined</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="5" style="text-align:center;color:var(--text-muted);padding:2rem">
                    @(string.IsNullOrEmpty(ViewBag.Search as string) ? "Enter a name or email to search." : "No users found.")
                </td></tr>
            }
            @foreach (var u in Model)
            {
                var initials = ((u.FullName ?? "?").Length > 0 ? (u.FullName ?? "?")[0].ToString() : "?").ToUpper();
                <tr>
                    <td>
                        <div style="display:flex;align-items:center;gap:.6rem">
                            <div style="width:30px;height:30px;border-radius:8px;background:rgba(74,142,201,.15);
                                        color:var(--primary);font-size:.7rem;font-weight:700;
                                        display:flex;align-items:center;justify-content:center;flex-shrink:0">@initials</div>
                            <div>
                                <div style="font-weight:600;color:#1e3a5f;font-size:.84rem">@u.FullName</div>
                                <div style="color:var(--text-muted);font-size:.75rem">@u.Email</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        @{
                            var roleClass = u.Role switch { "SuperAdmin" => "badge-rose", "OrgAdmin" => "badge-amber", _ => "badge-indigo" };
                        }
                        <span class="badge-sm @roleClass">@u.Role</span>
                    </td>
                    <td>
                        @if (u.OrganizationId.HasValue)
                        {
                            <span style="font-size:.84rem;color:#1e3a5f">@(u.OrgName ?? $"Org #{u.OrganizationId}")</span>
                        }
                        else { <span style="color:var(--text-muted)">—</span> }
                    </td>
                    <td style="color:var(--text-muted);font-size:.8rem">@u.CreatedAt.ToString("MMM d, yyyy")</td>
                    <td>
                        <a href="/superadmin/users/@u.Id/timeline" class="btn-ghost-sm" style="padding:.3rem .7rem">
                            <i class="bi bi-clock-history"></i>Timeline
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (Model.Count == 100)
    {
        <p style="text-align:center;color:var(--text-muted);font-size:.8rem;margin-top:.75rem">
            Showing first 100 results — refine your search to narrow down.
        </p>
    }
</div>
