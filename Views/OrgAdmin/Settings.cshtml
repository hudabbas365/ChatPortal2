    // License Info
    function loadLicenseInfo() {
        if (!orgId) return;
        fetch(`/api/billing/license-info?organizationId=${orgId}`)
            .then(r => r.json())
            .then(data => {
                const proPurchased = Number(data.proPurchased ?? 0);
                const proAssigned = Number(data.proAssigned ?? 0);
                const proAvailable = Number(data.proAvailable ?? Math.max(0, proPurchased - proAssigned));
                const entPurchased = Number(data.enterprisePurchased ?? 0);
                const entAssigned = Number(data.enterpriseAssigned ?? 0);
                const entAvailable = Number(data.enterpriseAvailable ?? Math.max(0, entPurchased - entAssigned));
                const totalAvailable = proAvailable + entAvailable;
                const totalPurchased = Number(data.purchased ?? (proPurchased + entPurchased));

                const proEl = document.getElementById('licenseProStats');
                const entEl = document.getElementById('licenseEntStats');
                const availEl = document.getElementById('licenseAvailable');
                const planEl = document.getElementById('licensePlanType');
                if (proEl) proEl.textContent = `${proAssigned} / ${proPurchased}`;
                if (entEl) entEl.textContent = `${entAssigned} / ${entPurchased}`;
                if (availEl) availEl.textContent = totalAvailable;
                if (planEl) planEl.textContent = data.plan || '—';

                _licenseAvailability = { pro: proAvailable, enterprise: entAvailable };

                const hint = document.getElementById('licenseHint');
                if (hint) {
                    if (totalPurchased === 0) {
                        hint.innerHTML = '<i class="bi bi-info-circle me-1"></i>No licenses purchased yet. Buy licenses to assign paid plans to users.';
                    } else if (totalAvailable <= 0) {
                        hint.innerHTML = '<i class="bi bi-exclamation-triangle text-warning me-1"></i>No licenses available. Buy more to assign paid plans to users.';
                    } else {
                        hint.textContent = `${proAvailable} Professional and ${entAvailable} Enterprise license(s) available for assignment.`;
                    }
                }
            }).catch(() => {});
    }

